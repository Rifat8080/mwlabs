<% content_for :title, "Blog | Mwlabs" %>

<%= render "pages/shared/hero",
  eyebrow: "Blog",
  title: "Insights on Digital Growth",
  description: "Tips, strategies and updates from the M&W Labs team on web, marketing, branding and automation." %>

<% if @categories.any? %>
  <section class="border-b border-slate-100 bg-white py-8 sm:py-10">
    <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
      <div class="flex flex-wrap gap-2">
        <%= link_to blog_path,
          class: "inline-flex items-center rounded-full px-4 py-2 text-sm font-black transition #{@selected_category.blank? ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/20' : 'bg-slate-100 text-slate-700 hover:bg-blue-50 hover:text-blue-700'}" do %>
          All posts
        <% end %>
        <% @categories.each do |category| %>
          <%= link_to blog_path(category: category.slug),
            class: "inline-flex items-center rounded-full px-4 py-2 text-sm font-black transition #{@selected_category == category.slug ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/20' : 'bg-slate-100 text-slate-700 hover:bg-blue-50 hover:text-blue-700'}" do %>
            <%= category.name %>
          <% end %>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<% if @featured_post.present? %>
  <section class="bg-[radial-gradient(circle_at_top_right,_#eff6ff,_transparent_28rem),linear-gradient(180deg,_#ffffff_0%,_#f8fbff_100%)] py-12 sm:py-14">
    <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
      <p class="text-xs font-extrabold uppercase tracking-[0.2em] text-blue-600">Featured</p>
      <article class="mt-5 overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-xl shadow-blue-100/60 transition hover:-translate-y-1 hover:shadow-2xl hover:shadow-blue-100/80">
        <div class="grid gap-0 lg:grid-cols-[1.1fr_0.9fr]">
          <div class="relative min-h-[16rem] bg-slate-100 lg:min-h-[22rem]">
            <% if @featured_post.cover_image.attached? %>
              <%= blog_cover_image @featured_post,
                resize: [ 960, 640 ],
                class: "h-full w-full object-cover",
                alt: @featured_post.title,
                loading: "eager",
                fetchpriority: "high" %>
            <% else %>
              <div class="flex h-full min-h-[16rem] items-center justify-center bg-gradient-to-br from-blue-600 via-indigo-600 to-cyan-500 lg:min-h-[22rem]">
                <i class="fa-solid fa-newspaper text-5xl text-white/80"></i>
              </div>
            <% end %>
          </div>
          <div class="flex flex-col justify-center p-6 sm:p-8 lg:p-10">
            <p class="text-xs font-extrabold uppercase tracking-[0.2em] text-blue-600"><%= @featured_post.category %></p>
            <h2 class="mt-3 text-2xl font-black leading-tight text-slate-950 sm:text-4xl">
              <%= link_to @featured_post.title, blog_post_path(@featured_post.slug), class: "transition hover:text-blue-700" %>
            </h2>
            <% if @featured_post.excerpt.present? %>
              <p class="mt-4 text-base font-semibold leading-8 text-slate-600"><%= @featured_post.excerpt %></p>
            <% end %>
            <div class="mt-6 flex flex-wrap items-center gap-4 text-sm font-bold text-slate-500">
              <span><%= @featured_post.published_at.to_date.to_fs(:long) %></span>
              <span><%= @featured_post.read_time_minutes %> min read</span>
              <span><%= @featured_post.author.display_name %></span>
            </div>
            <%= link_to blog_post_path(@featured_post.slug), class: "mt-8 inline-flex w-fit items-center gap-2 rounded-xl bg-blue-600 px-5 py-3 text-sm font-extrabold text-white shadow-lg shadow-blue-600/20 transition hover:-translate-y-0.5 hover:bg-blue-700" do %>
              Read article
              <i class="fa-solid fa-arrow-right text-xs"></i>
            <% end %>
          </div>
        </div>
      </article>
    </div>
  </section>
<% end %>

<section class="bg-white py-14 sm:py-16">
  <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
    <% list_posts = @featured_post ? @posts.reject { |post| post.id == @featured_post.id } : @posts %>

    <% if list_posts.any? %>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <% list_posts.each do |post| %>
          <%= render "blog_posts/card", post: post %>
        <% end %>
      </div>
    <% elsif @featured_post.blank? %>
      <div class="rounded-[2rem] border border-dashed border-slate-200 bg-slate-50 px-6 py-16 text-center sm:px-10">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-blue-100 text-blue-600">
          <i class="fa-solid fa-newspaper text-2xl"></i>
        </div>
        <h2 class="mt-5 text-2xl font-black text-slate-950">No published posts yet</h2>
        <p class="mx-auto mt-3 max-w-xl text-sm font-semibold leading-7 text-slate-600">
          <% if @selected_category.present? %>
            We have not published anything in <%= @selected_category %> yet. Try another category or check back soon.
          <% else %>
            Fresh insights are on the way. Check back soon for strategies on web, marketing, branding, and automation.
          <% end %>
        </p>
        <% if @selected_category.present? %>
          <%= link_to "View all posts", blog_path, class: "mt-6 inline-flex items-center gap-2 rounded-xl bg-blue-600 px-5 py-3 text-sm font-extrabold text-white shadow-lg shadow-blue-600/20 transition hover:bg-blue-700" %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>

<%= render "pages/shared/cta" %>
