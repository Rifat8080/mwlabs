<article class="group overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:border-blue-100 hover:shadow-xl hover:shadow-blue-100/70">
  <%= link_to blog_post_path(post.slug), class: "block" do %>
    <div class="relative aspect-[16/10] overflow-hidden bg-slate-100">
      <% if post.cover_image.attached? %>
        <%= blog_cover_image post,
          resize: local_assigns.fetch(:image_size, [ 640, 400 ]),
          class: "h-full w-full object-cover transition duration-500 group-hover:scale-105",
          alt: post.title,
          loading: local_assigns.fetch(:loading, "lazy") %>
      <% else %>
        <div class="flex h-full items-center justify-center bg-gradient-to-br from-slate-100 to-blue-50">
          <i class="fa-solid fa-newspaper text-3xl text-blue-300"></i>
        </div>
      <% end %>
    </div>
    <div class="p-6">
      <p class="text-xs font-extrabold uppercase tracking-[0.2em] text-blue-600"><%= post.category %></p>
      <h2 class="mt-3 text-xl font-black leading-snug text-slate-950 transition group-hover:text-blue-700"><%= post.title %></h2>
      <% if post.excerpt.present? %>
        <p class="mt-3 line-clamp-3 text-sm font-semibold leading-7 text-slate-600"><%= post.excerpt %></p>
      <% end %>
      <div class="mt-5 flex flex-wrap items-center gap-3 text-xs font-bold uppercase tracking-[0.12em] text-slate-500">
        <span><%= post.published_at.to_date.to_fs(:long) %></span>
        <span><%= post.read_time_minutes %> min read</span>
      </div>
    </div>
  <% end %>
</article>
