<% content_for :title, "#{@post.seo_title} | Mwlabs" %>
<% content_for :head do %>
  <meta name="description" content="<%= @post.seo_description %>">
  <% if @post.cover_image.attached? %>
    <link rel="preload" as="image" href="<%= blog_cover_url(@post) %>">
  <% end %>
<% end %>

<article class="bg-white">
  <% if @post.cover_image.attached? %>
    <section class="relative isolate min-h-[28rem] overflow-hidden bg-slate-950 sm:min-h-[32rem] lg:min-h-[36rem]">
      <div class="absolute inset-0">
        <%= blog_cover_image @post,
          class: "h-full w-full object-cover",
          alt: "",
          loading: "eager",
          fetchpriority: "high",
          "aria-hidden": "true" %>
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/70 to-slate-900/30"></div>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(37,99,235,0.35),_transparent_40%)]"></div>
      </div>

      <div class="relative mx-auto flex min-h-[28rem] max-w-4xl flex-col justify-end px-4 pb-16 pt-10 sm:min-h-[32rem] sm:px-6 sm:pb-20 sm:pt-14 lg:min-h-[36rem] lg:px-8">
        <%= link_to blog_path, class: "inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/10 px-4 py-2 text-sm font-bold text-white backdrop-blur transition hover:bg-white/20" do %>
          <i class="fa-solid fa-arrow-left text-xs"></i>
          Back to blog
        <% end %>

        <p class="mt-8 text-xs font-extrabold uppercase tracking-[0.2em] text-blue-200"><%= @post.category %></p>
        <h1 class="mt-4 max-w-3xl text-3xl font-black leading-tight tracking-tight text-white sm:text-5xl lg:text-[3.4rem] lg:leading-[1.05]"><%= @post.title %></h1>

        <% if @post.excerpt.present? %>
          <p class="mt-5 max-w-2xl text-base font-medium leading-8 text-slate-200 sm:text-lg"><%= @post.excerpt %></p>
        <% end %>

        <div class="mt-8 flex flex-wrap items-center gap-3 text-sm font-bold text-slate-300">
          <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1.5 backdrop-blur">
            <i class="fa-regular fa-calendar text-blue-200"></i>
            <%= @post.published_at.to_date.to_fs(:long) %>
          </span>
          <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1.5 backdrop-blur">
            <i class="fa-regular fa-clock text-blue-200"></i>
            <%= @post.read_time_minutes %> min read
          </span>
          <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1.5 backdrop-blur">
            <i class="fa-regular fa-user text-blue-200"></i>
            <%= @post.author.display_name %>
          </span>
        </div>
      </div>
    </section>
  <% else %>
    <section class="border-b border-slate-100 bg-[radial-gradient(circle_at_top_right,_#eff6ff,_transparent_28rem),linear-gradient(180deg,_#ffffff_0%,_#f8fbff_100%)] py-12 sm:py-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <%= link_to blog_path, class: "inline-flex items-center gap-2 text-sm font-black text-blue-600 transition hover:text-blue-800" do %>
          <i class="fa-solid fa-arrow-left text-xs"></i>
          Back to blog
        <% end %>

        <p class="mt-8 text-xs font-extrabold uppercase tracking-[0.2em] text-blue-600"><%= @post.category %></p>
        <h1 class="mt-4 text-3xl font-black tracking-tight text-slate-950 sm:text-5xl"><%= @post.title %></h1>

        <% if @post.excerpt.present? %>
          <p class="mt-5 text-lg font-semibold leading-8 text-slate-600"><%= @post.excerpt %></p>
        <% end %>

        <div class="mt-8 flex flex-wrap items-center gap-4 border-t border-slate-100 pt-6 text-sm font-bold text-slate-500">
          <span><%= @post.published_at.to_date.to_fs(:long) %></span>
          <span><%= @post.read_time_minutes %> min read</span>
          <span>By <%= @post.author.display_name %></span>
        </div>
      </div>
    </section>
  <% end %>

  <section class="relative z-10 <%= @post.cover_image.attached? ? "-mt-10 sm:-mt-12" : "" %>">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="<%= @post.cover_image.attached? ? "rounded-[2rem] border border-slate-200 bg-white p-6 shadow-2xl shadow-slate-200/60 sm:p-10 lg:p-12" : "py-10 sm:py-12" %>">
        <div class="blog-article-body trix-content text-[1.05rem] font-medium leading-8 text-slate-700">
          <%= @post.body %>
        </div>

        <div class="mt-10 flex flex-col gap-4 border-t border-slate-100 pt-8 sm:flex-row sm:items-center sm:justify-between">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-blue-600 to-cyan-500 text-sm font-black text-white shadow-lg shadow-blue-600/20">
              <%= @post.author.display_name.to_s.split.map { |part| part[0] }.join.first(2).upcase %>
            </div>
            <div>
              <p class="text-xs font-extrabold uppercase tracking-[0.16em] text-slate-400">Written by</p>
              <p class="text-base font-black text-slate-950"><%= @post.author.display_name %></p>
            </div>
          </div>

          <%= link_to blog_path(category: @post.category_slug), class: "inline-flex w-fit items-center gap-2 rounded-xl border border-blue-100 bg-blue-50 px-4 py-3 text-sm font-extrabold text-blue-700 transition hover:bg-blue-100" do %>
            More in <%= @post.category %>
            <i class="fa-solid fa-arrow-right text-xs"></i>
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <% if @related_posts.any? %>
    <section class="border-t border-slate-100 bg-slate-50 py-14 sm:py-16">
      <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="text-xs font-extrabold uppercase tracking-[0.2em] text-blue-600">Keep reading</p>
            <h2 class="mt-3 text-2xl font-black text-slate-950 sm:text-3xl">Related articles</h2>
          </div>
          <%= link_to blog_path(category: @post.category_slug), class: "inline-flex items-center gap-2 text-sm font-extrabold text-blue-600 transition hover:text-blue-800" do %>
            View all in <%= @post.category %>
            <i class="fa-solid fa-arrow-right text-xs"></i>
          <% end %>
        </div>

        <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          <% @related_posts.each do |related| %>
            <%= render "blog_posts/card", post: related %>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>
</article>

<%= render "pages/shared/cta" %>
