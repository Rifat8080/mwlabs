<% content_for :title, "#{@post.seo_title} | Mwlabs" %>
<% content_for :head do %>
  <meta name="description" content="<%= @post.seo_description %>">
  <% if @post.cover_image.attached? %>
    <link rel="preload" as="image" href="<%= url_for(@post.cover_image) %>">
  <% end %>
<% end %>

<article>
  <section class="border-b border-slate-100 bg-[radial-gradient(circle_at_top_right,_#eff6ff,_transparent_28rem),linear-gradient(180deg,_#ffffff_0%,_#f8fbff_100%)] py-12 sm:py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <%= link_to blog_path, class: "inline-flex items-center gap-2 text-sm font-black text-blue-600 transition hover:text-blue-800" do %>
        <i class="fa-solid fa-arrow-left text-xs"></i>
        Back to blog
      <% end %>

      <p class="mt-8 text-xs font-extrabold uppercase tracking-[0.2em] text-blue-600"><%= @post.category %></p>
      <h1 class="mt-4 text-3xl font-black tracking-tight text-slate-950 sm:text-5xl"><%= @post.title %></h1>

      <% if @post.excerpt.present? %>
        <p class="mt-5 text-lg font-semibold leading-8 text-slate-600"><%= @post.excerpt %></p>
      <% end %>

      <div class="mt-8 flex flex-wrap items-center gap-4 border-t border-slate-100 pt-6 text-sm font-bold text-slate-500">
        <span><%= @post.published_at.to_date.to_fs(:long) %></span>
        <span><%= @post.read_time_minutes %> min read</span>
        <span>By <%= @post.author.display_name %></span>
      </div>
    </div>
  </section>

  <% if @post.cover_image.attached? %>
    <section class="bg-white py-8 sm:py-10">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="overflow-hidden rounded-[2rem] border border-slate-200 shadow-xl shadow-blue-100/50">
          <%= blog_cover_image @post,
            resize: [ 1200, 630 ],
            class: "w-full object-cover",
            alt: @post.title,
            loading: "eager",
            fetchpriority: "high" %>
        </div>
      </div>
    </section>
  <% end %>

  <section class="bg-white py-10 sm:py-12">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg prose-slate max-w-none text-slate-700">
        <%= simple_format(sanitize(@post.body)) %>
      </div>
    </div>
  </section>

  <% if @related_posts.any? %>
    <section class="border-t border-slate-100 bg-slate-50 py-14 sm:py-16">
      <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
        <p class="text-xs font-extrabold uppercase tracking-[0.2em] text-blue-600">Related</p>
        <h2 class="mt-3 text-2xl font-black text-slate-950 sm:text-3xl">More in <%= @post.category %></h2>

        <div class="mt-8 grid gap-6 md:grid-cols-3">
          <% @related_posts.each do |related| %>
            <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-blue-100 hover:shadow-xl hover:shadow-blue-100/70">
              <p class="text-xs font-extrabold uppercase tracking-[0.2em] text-blue-600"><%= related.category %></p>
              <h3 class="mt-3 text-lg font-black leading-snug text-slate-950">
                <%= link_to related.title, blog_post_path(related.slug), class: "transition hover:text-blue-700" %>
              </h3>
              <p class="mt-4 text-xs font-bold uppercase tracking-[0.12em] text-slate-500"><%= related.published_at.to_date.to_fs(:long) %></p>
            </article>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>
</article>

<%= render "pages/shared/cta" %>
