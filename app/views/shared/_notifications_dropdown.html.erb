<div id="notifications-menu" class="relative" data-controller="notification-menu">
  <% unread_count = current_user.notifications.unread.count %>
  <button type="button" class="relative inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-slate-200 bg-white/90 text-slate-700 shadow-sm transition hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700 focus:outline-none focus:ring-4 focus:ring-blue-100" aria-expanded="false" aria-controls="notifications-dropdown" title="Notifications" data-notification-menu-target="button" data-action="click->notification-menu#toggle">
    <span class="sr-only">Open notifications</span>
    <i class="fa-solid fa-bell"></i>
    <% if unread_count.positive? %>
      <span id="notifications-badge" class="absolute -right-1 -top-1 inline-flex h-5 min-w-5 items-center justify-center rounded-full border-2 border-white bg-rose-600 px-1 text-[0.65rem] font-black text-white shadow-lg shadow-rose-600/20"><%= unread_count %></span>
    <% else %>
      <span id="notifications-badge" class="hidden absolute -right-1 -top-1 inline-flex h-5 min-w-5 items-center justify-center rounded-full border-2 border-white bg-rose-600 px-1 text-[0.65rem] font-black text-white shadow-lg shadow-rose-600/20">0</span>
    <% end %>
  </button>

  <div id="notifications-dropdown" class="absolute right-0 z-50 mt-3 hidden max-h-[min(80vh,36rem)] w-[calc(100vw-2rem)] max-w-[26rem] overflow-hidden rounded-3xl border border-slate-100 bg-white shadow-2xl shadow-slate-300/50 sm:right-0" data-notification-menu-target="panel">
    <div class="flex-shrink-0 border-b border-slate-100 bg-[radial-gradient(circle_at_top_right,_#dbeafe,_transparent_14rem),linear-gradient(135deg,_#ffffff,_#f8fbff)] px-5 py-4">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-sm font-black text-slate-950">Notifications</h3>
          <p class="mt-0.5 text-xs font-semibold text-slate-500">Latest workspace activity</p>
        </div>
        <span id="notifications-unread-pill" class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-1 text-xs font-black text-blue-700">
          <%= unread_count %> new
        </span>
      </div>
    </div>
    <div id="notifications-list" class="max-h-[26rem] overflow-y-auto divide-y divide-slate-100">
      <% notifications = current_user.notifications.order(created_at: :desc).limit(15) %>
      <% if notifications.exists? %>
        <% notifications.each do |n| %>
          <%= render partial: "shared/notification_item", locals: { notification: n, dom_id: "dropdown_notification_#{n.id}" } %>
        <% end %>
      <% else %>
        <div id="empty-notification-state" class="flex flex-col items-center justify-center py-12 text-center">
          <i class="fa-solid fa-inbox text-3xl text-slate-300 mb-3"></i>
          <p class="text-sm text-slate-500">No notifications yet</p>
        </div>
      <% end %>
    </div>
    <div class="flex-shrink-0 border-t border-slate-100 bg-slate-50/80 px-3 py-3 flex gap-2">
      <% if unread_count.positive? %>
        <%= button_to "Mark all read", mark_all_admin_notifications_path, method: :patch, class: "flex-1 text-center rounded-xl px-3 py-2.5 text-xs font-black text-slate-700 bg-white hover:bg-slate-100 border border-slate-200 transition", form: { data: { turbo: true } } %>
      <% end %>
      <%= link_to "View all", admin_notifications_path, class: "flex-1 text-center rounded-xl px-3 py-2.5 text-xs font-black text-blue-700 bg-blue-50 hover:bg-blue-100 border border-blue-200 transition" %>
    </div>
  </div>
</div>
