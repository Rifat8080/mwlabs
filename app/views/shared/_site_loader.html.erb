<div class="site-loader fixed inset-0 z-[100] grid place-items-center bg-white/95 backdrop-blur-xl" role="status" aria-live="polite" aria-label="Loading M&W Labs">
  <div class="relative flex h-36 w-36 items-center justify-center">
    <div class="site-loader-ring absolute inset-0 rounded-full border border-blue-100 border-t-blue-600 shadow-[0_0_80px_rgba(37,99,235,0.18)]"></div>
    <div class="absolute inset-3 rounded-full border border-cyan-100"></div>
    <div class="site-loader-mark relative flex h-24 w-24 items-center justify-center rounded-[1.75rem] border border-slate-100 bg-white shadow-2xl shadow-blue-200/50">
      <%= tag.img src: "/images/mwlogo-navbar-cropped.png", alt: "M&W Labs", class: "h-14 w-auto object-contain" %>
    </div>
  </div>
  <span class="sr-only">Loading</span>
</div>
