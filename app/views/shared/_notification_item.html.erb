<% item_id = local_assigns.fetch(:dom_id, "notification_#{notification.id}") %>
<% border_class = case notification.level
  when "danger" then "border-rose-500"
  when "success" then "border-emerald-500"
  when "warning" then "border-amber-500"
  else "border-blue-500"
end %>
<% accent_class = case notification.level
  when "danger" then "bg-rose-500"
  when "success" then "bg-emerald-500"
  when "warning" then "bg-amber-500"
  else "bg-blue-500"
end %>
<% variant = local_assigns.fetch(:variant, :compact) %>

<% if variant == :page %>
  <div id="<%= item_id %>" data-controller="notification" class="group relative bg-white px-5 py-5 transition hover:bg-slate-50/80 <%= 'opacity-75' if notification.read_at.present? %>">
    <span class="absolute left-0 top-0 h-full w-1 <%= accent_class %> <%= notification.read_at.present? ? 'opacity-30' : 'opacity-100' %>"></span>
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start">
      <div class="flex items-start gap-4 sm:flex-1">
        <span class="relative inline-flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-2xl <%= notification.badge_class %> ring-1 ring-inset ring-current/10">
          <i class="fa-solid <%= notification.icon_class %> text-lg"></i>
          <% if notification.read_at.blank? %>
            <span class="absolute -right-1 -top-1 h-3 w-3 rounded-full border-2 border-white bg-blue-600"></span>
          <% end %>
        </span>

        <div class="min-w-0 flex-1">
          <div class="flex flex-wrap items-center gap-2">
            <p class="font-black text-slate-950"><%= notification.action %></p>
            <% if notification.read_at.blank? %>
              <span class="rounded-full bg-blue-50 px-2 py-0.5 text-[0.68rem] font-black uppercase tracking-[0.14em] text-blue-700">New</span>
            <% else %>
              <span class="rounded-full bg-slate-100 px-2 py-0.5 text-[0.68rem] font-black uppercase tracking-[0.14em] text-slate-500">Read</span>
            <% end %>
          </div>

          <% if notification.params["details"].present? %>
            <p class="mt-1.5 text-sm font-medium leading-6 text-slate-600"><%= sanitize(notification.params["details"]) %></p>
          <% end %>

          <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs font-bold text-slate-400">
            <span class="inline-flex items-center gap-1.5">
              <i class="fa-regular fa-clock"></i>
              <%= time_ago_in_words(notification.created_at) %> ago
            </span>
            <% if notification.read_at.present? %>
              <span class="inline-flex items-center gap-1.5">
                <i class="fa-solid fa-check"></i>
                Read <%= time_ago_in_words(notification.read_at) %> ago
              </span>
            <% end %>
          </div>

          <% if notification.notifiable.present? %>
            <div class="mt-4">
              <% if notification.url.present? %>
                <%= link_to notification.notifiable.try(:display_name) || notification.notifiable.class.name, open_admin_notification_path(notification), class: "inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-black text-slate-700 shadow-sm transition hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700" %>
              <% else %>
                <span class="inline-flex items-center rounded-xl bg-slate-50 px-3 py-2 text-sm font-bold text-slate-500"><%= notification.notifiable.try(:display_name) || notification.notifiable.class.name %></span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="flex items-center gap-2 sm:flex-shrink-0">
        <% if notification.read_at.blank? %>
          <button type="button" title="Mark as read" class="inline-flex items-center justify-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-xs font-black text-slate-600 shadow-sm transition hover:border-emerald-200 hover:bg-emerald-50 hover:text-emerald-700" data-action="click->notification#markAsRead" data-notification-url="<%= admin_notification_path(notification) %>">
            <i class="fa-solid fa-check"></i>
            Mark read
          </button>
        <% end %>
        <% if notification.url.present? %>
          <%= link_to open_admin_notification_path(notification), class: "inline-flex items-center justify-center gap-2 rounded-xl bg-slate-950 px-3 py-2 text-xs font-black text-white shadow-lg shadow-slate-900/10 transition hover:bg-blue-700", title: "Go to item and mark read" do %>
            Open
            <i class="fa-solid fa-arrow-right text-xs"></i>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
<% else %>
  <div id="<%= item_id %>" data-controller="notification" class="border-l-4 <%= border_class %> bg-white p-4 transition hover:bg-slate-50 flex items-start gap-3 sm:gap-4 <%= 'opacity-75' if notification.read_at.present? %>">
    <div class="flex-shrink-0 pt-0.5">
      <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg <%= notification.badge_class %>">
        <i class="fa-solid <%= notification.icon_class %> text-lg"></i>
      </span>
    </div>
    <div class="min-w-0 flex-1">
      <div class="flex items-start justify-between gap-2">
        <div class="min-w-0 flex-1">
          <p class="break-words font-semibold text-slate-900"><%= notification.action %></p>
          <% if notification.params["details"].present? %>
            <p class="mt-1 break-words text-sm text-slate-600"><%= sanitize(notification.params["details"]) %></p>
          <% end %>
          <% if notification.notifiable.present? %>
            <div class="mt-2 min-w-0">
              <% if notification.url.present? %>
                <%= link_to notification.notifiable.try(:display_name) || notification.notifiable.class.name, open_admin_notification_path(notification), class: 'inline-block max-w-full break-words text-sm text-blue-600 hover:text-blue-700 hover:underline' %>
              <% else %>
                <span class="break-words text-sm text-slate-500"><%= notification.notifiable.try(:display_name) || notification.notifiable.class.name %></span>
              <% end %>
            </div>
          <% end %>
          <p class="text-xs text-slate-400 mt-2">
            <%= time_ago_in_words(notification.created_at) %> ago
            <% if notification.read_at.present? %>
              • <span class="text-slate-500">Read <%= time_ago_in_words(notification.read_at) %> ago</span>
            <% end %>
          </p>
        </div>
        <div class="flex items-center gap-2 flex-shrink-0">
          <% if notification.read_at.blank? %>
            <button type="button" title="Mark as read" class="p-1 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded transition" data-action="click->notification#markAsRead" data-notification-url="<%= admin_notification_path(notification) %>">
              <i class="fa-solid fa-circle text-xs"></i>
            </button>
          <% end %>
          <% if notification.url.present? %>
            <%= link_to open_admin_notification_path(notification), class: "p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded transition", title: "Go to item and mark read" do %>
              <i class="fa-solid fa-arrow-right text-sm"></i>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
