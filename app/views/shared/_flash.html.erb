<% flash.each do |type, message| %>
  <% next if message.blank? %>

  <% styles = type.to_s == "alert" ? "border-red-200 bg-red-50 text-red-800" : "border-blue-200 bg-blue-50 text-blue-800" %>

  <div class="mb-4 rounded-lg border px-4 py-3 text-sm <%= styles %>" role="status">
    <%= message %>
  </div>
<% end %>
