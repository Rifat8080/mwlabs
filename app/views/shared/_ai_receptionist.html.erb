<div class="fixed bottom-24 left-3 z-50 sm:bottom-6 sm:left-6" data-controller="ai-receptionist" data-ai-receptionist-endpoint-value="<%= ai_receptionist_messages_path %>">
  <section id="ai-receptionist-panel" data-ai-receptionist-target="panel" class="mb-3 hidden max-w-sm overflow-hidden rounded-lg border border-slate-200 bg-slate-50 shadow-2xl shadow-slate-900/20" style="width: min(24rem, calc(100vw - 1.5rem));">
    <header class="flex items-center justify-between border-b border-slate-200 bg-white px-4 py-3">
      <div class="flex items-center gap-3">
        <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-600 text-white">
          <i class="fa-solid fa-headset text-sm"></i>
        </span>
        <div>
          <p class="text-sm font-black text-slate-950">M&W Labs Reception</p>
          <p class="text-xs font-bold text-emerald-600" data-ai-receptionist-target="status">Local AI ready</p>
        </div>
      </div>

      <button type="button" class="flex h-9 w-9 items-center justify-center rounded-lg text-slate-500 transition hover:bg-slate-100 hover:text-slate-900" aria-label="Close receptionist chat" data-action="ai-receptionist#close">
        <i class="fa-solid fa-xmark text-sm"></i>
      </button>
    </header>

    <div class="h-80 space-y-3 overflow-y-auto bg-slate-50 p-4" data-ai-receptionist-target="messages">
      <div class="flex justify-start">
        <div class="max-w-xs rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm font-semibold leading-6 text-slate-700">
          Hi, this is M&W Labs. What are you looking to build or grow today?
        </div>
      </div>
    </div>

    <form class="border-t border-slate-200 bg-white p-3" data-action="submit->ai-receptionist#submit">
      <label for="ai-receptionist-message" class="sr-only">Message M&W Labs reception</label>
      <div class="flex items-end gap-2">
        <textarea id="ai-receptionist-message" rows="2" class="min-h-12 flex-1 resize-none rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-semibold leading-6 text-slate-800 shadow-sm transition placeholder:text-slate-400 focus:border-blue-300 focus:bg-white focus:outline-none focus:ring-4 focus:ring-blue-50" placeholder="Type your message..." data-ai-receptionist-target="input"></textarea>
        <button type="submit" class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-blue-600 text-white shadow-lg shadow-blue-600/20 transition hover:bg-blue-700" aria-label="Send message">
          <i class="fa-solid fa-paper-plane text-sm"></i>
        </button>
      </div>
    </form>
  </section>

  <button type="button" class="flex items-center gap-3 rounded-lg bg-slate-950 px-4 py-3 text-sm font-black text-white shadow-2xl shadow-slate-900/25 transition hover:-translate-y-0.5 hover:bg-blue-600" aria-expanded="false" aria-controls="ai-receptionist-panel" data-ai-receptionist-target="launcher" data-action="ai-receptionist#toggle">
    <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/10">
      <i class="fa-solid fa-comments text-sm"></i>
    </span>
    AI Reception
  </button>
</div>
