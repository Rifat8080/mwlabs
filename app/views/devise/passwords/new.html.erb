<% content_for :title, "Reset Password | M&W Labs" %>
<% content_for :meta_description, "Reset access to your M&W Labs portal account with secure instructions sent to your registered email address." %>

<%= render "devise/shared/auth_panel",
  title: "Recover access to your M&W Labs workspace.",
  description: "Enter the email connected to your account and we will send secure instructions to reset your password.",
  eyebrow: "Password Recovery",
  form_title: "Reset your password",
  form_description: "For security, reset links are sent only to the email address registered with your portal account." do %>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-5" }) do |form| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= form.label :email, "Account email", class: "mb-2 block text-sm font-black text-slate-700" %>
      <%= form.email_field :email, autofocus: true, autocomplete: "email", class: "block w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm transition focus:border-blue-300 focus:bg-white focus:outline-none focus:ring-4 focus:ring-blue-50", placeholder: "you@company.com" %>
    </div>

    <div class="rounded-2xl border border-blue-100 bg-blue-50 p-4">
      <div class="flex items-start gap-3">
        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-white text-blue-600 shadow-sm">
          <i class="fa-solid fa-shield-halved"></i>
        </span>
        <div>
          <p class="text-sm font-black text-slate-950">Secure recovery process</p>
          <p class="mt-1 text-xs font-semibold leading-5 text-slate-600">If the email exists in our system, you will receive password reset instructions shortly.</p>
        </div>
      </div>
    </div>

    <%= form.submit "Send Reset Instructions", class: "w-full rounded-xl bg-blue-600 px-5 py-3.5 text-sm font-extrabold text-white shadow-xl shadow-blue-600/20 transition hover:-translate-y-0.5 hover:bg-blue-700" %>
  <% end %>

  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 text-center shadow-sm">
    <p class="text-sm font-semibold text-slate-700">Remember your password?</p>
    <%= link_to "Back to login", new_session_path(resource_name), class: "mt-1 inline-flex text-sm font-black text-blue-700 hover:text-blue-800" %>
  </div>
<% end %>
