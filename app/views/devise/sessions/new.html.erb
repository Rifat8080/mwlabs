<% content_for :title, "Login | M&W Labs" %>
<% content_for :meta_description, "Sign in to your M&W Labs workspace to view projects, quotes, invoices, files, and growth updates from the team." %>

<%= render "devise/shared/auth_panel",
  title: "Welcome back to your M&W Labs workspace.",
  description: "Sign in to view projects, quotes, invoices, files, and growth updates from the M&W Labs team.",
  eyebrow: "Secure Login",
  form_title: "Sign in to continue",
  form_description: "Use the email connected to your client portal or team account." do %>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |form| %>
    <div>
      <%= form.label :email, class: "mb-2 block text-sm font-black text-slate-700" %>
      <%= form.email_field :email, autofocus: true, autocomplete: "email", class: "block w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm transition focus:border-blue-300 focus:bg-white focus:outline-none focus:ring-4 focus:ring-blue-50", placeholder: "you@company.com" %>
    </div>

    <div>
      <div class="mb-2 flex items-center justify-between gap-3">
        <%= form.label :password, class: "block text-sm font-black text-slate-700" %>
        <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-xs font-extrabold text-blue-600 hover:text-blue-700" %>
      </div>
      <%= form.password_field :password, autocomplete: "current-password", class: "block w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm transition focus:border-blue-300 focus:bg-white focus:outline-none focus:ring-4 focus:ring-blue-50", placeholder: "Enter your password" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <label class="flex items-center gap-3 rounded-xl border border-slate-100 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-600">
        <%= form.check_box :remember_me, class: "h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500" %>
        Keep me signed in on this device
      </label>
    <% end %>

    <%= form.submit "Login", class: "w-full rounded-xl bg-blue-600 px-5 py-3.5 text-sm font-extrabold text-white shadow-xl shadow-blue-600/20 transition hover:-translate-y-0.5 hover:bg-blue-700" %>
  <% end %>

  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="flex items-start gap-3">
      <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-slate-100 text-slate-600">
        <i class="fa-solid fa-key"></i>
      </span>
      <div>
        <p class="text-sm font-black text-slate-950">Forgot your password?</p>
        <p class="mt-1 text-xs font-semibold leading-5 text-slate-500">Reset access securely using your account email.</p>
        <%= link_to "Reset password", new_password_path(resource_name), class: "mt-3 inline-flex text-sm font-black text-blue-700 hover:text-blue-800" %>
      </div>
    </div>
  </div>

  <div class="mt-6 rounded-2xl border border-blue-100 bg-blue-50 p-4 text-center">
    <p class="text-sm font-semibold text-slate-700">New here?</p>
    <%= link_to "Create your client portal account", new_registration_path(resource_name), class: "mt-1 inline-flex text-sm font-black text-blue-700 hover:text-blue-800" %>
  </div>
<% end %>
