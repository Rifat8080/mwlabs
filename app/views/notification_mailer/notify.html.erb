<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <style>
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.6; color: #1e293b; }
      .container { max-width: 600px; margin: 0 auto; padding: 20px; }
      .header { border-bottom: 2px solid #0ea5e9; padding-bottom: 20px; margin-bottom: 20px; }
      .logo { font-size: 24px; font-weight: bold; color: #0ea5e9; }
      .content { background: #f8fafc; padding: 20px; border-radius: 8px; margin: 20px 0; }
      .action-box { background: #0ea5e9; color: white; padding: 15px; border-radius: 8px; margin: 20px 0; }
      .action-box strong { font-size: 18px; }
      .details { margin: 15px 0; padding: 15px; background: white; border-left: 4px solid #0ea5e9; border-radius: 4px; }
      .item-link { display: inline-block; margin: 10px 0; padding: 10px 15px; background: #e0f2fe; color: #0369a1; text-decoration: none; border-radius: 6px; }
      .cta-button { display: inline-block; margin: 20px 0; padding: 12px 30px; background: #0ea5e9; color: white; text-decoration: none; border-radius: 6px; font-weight: 600; }
      .footer { color: #64748b; font-size: 12px; margin-top: 30px; padding-top: 20px; border-top: 1px solid #e2e8f0; }
      .level-warning { border-left-color: #f59e0b; } .level-danger { border-left-color: #ef4444; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <div class="logo">M&W Labs</div>
        <p style="margin: 10px 0 0 0; color: #64748b;">Agency Operations Platform</p>
      </div>

      <p>Hi <%= current_user&.display_name || 'there' %>,</p>

      <div class="action-box">
        <strong><%= @action %></strong>
      </div>

      <% if @details.present? %>
        <div class="details">
          <%= simple_format(@details) %>
        </div>
      <% end %>

      <% if @notifiable.present? %>
        <p><strong>Regarding:</strong> <span style="color: #0369a1;"><%= @notifiable.try(:display_name) || @notifiable.class.name %></span></p>
      <% end %>

      <% if defined?(notification_url) && notification_url.present? %>
        <div>
          <a href="<%= notification_url %>" class="cta-button">View Details →</a>
        </div>
      <% end %>

      <p style="margin-top: 30px; color: #64748b;">
        You received this notification because you're involved in this activity.
      </p>

      <div class="footer">
        <p>© 2026 M&W Labs. All rights reserved.</p>
        <p style="margin-top: 5px;">You can manage your notification preferences in your dashboard settings.</p>
      </div>
    </div>
  </body>
</html>
