<section class="border-b border-slate-100 bg-[radial-gradient(circle_at_top_right,_#eff6ff,_transparent_28rem),linear-gradient(180deg,_#ffffff_0%,_#f8fbff_100%)] py-14 sm:py-16">
  <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
    <p class="text-sm font-extrabold uppercase tracking-[0.25em] text-blue-600"><%= eyebrow %></p>
    <h1 class="mt-3 max-w-4xl text-3xl font-black tracking-tight text-slate-950 sm:text-5xl"><%= title %></h1>
    <% if local_assigns[:description].present? %>
      <p class="mt-5 max-w-3xl text-base font-semibold leading-8 text-slate-600 sm:text-lg"><%= description %></p>
    <% end %>
  </div>
</section>
