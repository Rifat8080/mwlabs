<% seo_page = local_assigns[:seo_page] %>

<% content_for :head do %>
  <link rel="preload" as="image" href="/images/hero-1600.webp" imagesrcset="/images/hero-800.webp 800w, /images/hero-1600.webp 1600w" imagesizes="(min-width: 1024px) 52rem, 94vw" fetchpriority="high">
<% end %>

<section class="relative isolate overflow-hidden bg-[radial-gradient(circle_at_18%_18%,_rgba(219,234,254,0.95),_transparent_30rem),radial-gradient(circle_at_88%_20%,_rgba(207,250,254,0.82),_transparent_34rem),linear-gradient(180deg,_#ffffff_0%,_#f8fbff_100%)]">
  <div class="absolute inset-x-0 top-0 -z-10 h-px bg-gradient-to-r from-transparent via-blue-200 to-transparent"></div>
  <div class="aurora-blob absolute left-8 top-28 -z-10 h-80 w-80 rounded-full bg-blue-100/70 blur-3xl"></div>
  <div class="aurora-blob-slow absolute right-0 top-24 -z-10 h-[34rem] w-[34rem] rounded-full bg-cyan-100/60 blur-3xl"></div>
  <div class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-44 bg-[linear-gradient(180deg,_rgba(255,255,255,0.95),_rgba(255,255,255,0))]"></div>

  <div class="mx-auto grid max-w-[104rem] items-center gap-10 px-4 pb-14 pt-8 sm:px-6 sm:pt-10 lg:grid-cols-[0.86fr_1.14fr] lg:gap-20 lg:px-12 lg:pb-24 lg:pt-16 2xl:px-16" data-parallax-host>
    <div class="text-center lg:text-left">
      <div class="mx-auto inline-flex items-center gap-2 rounded-full border border-blue-100/80 bg-white/90 px-4 py-2 text-[0.68rem] font-extrabold uppercase tracking-[0.18em] text-blue-700 shadow-[0_18px_45px_rgba(37,99,235,0.10)] backdrop-blur sm:text-xs lg:mx-0">
        <span class="relative flex h-5 w-5 items-center justify-center rounded-full bg-blue-600 text-[0.58rem] text-white shadow-lg shadow-blue-500/25">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-blue-400 opacity-40"></span>
          +
        </span>
        <% if seo_page %>
          <%= seo_page[:hero_eyebrow] %>
        <% else %>
          Full-service digital agency for growing businesses
        <% end %>
      </div>

      <% if seo_page %>
        <h1 class="mx-auto mt-7 max-w-3xl text-3xl font-black leading-[1.02] tracking-tight text-slate-950 sm:text-5xl lg:mx-0 lg:text-6xl <%= "xl:text-5xl" if seo_page[:keyword].length > 45 %>">
          <span class="text-shimmer bg-gradient-to-r from-blue-600 via-cyan-500 to-blue-700 bg-clip-text text-transparent"><%= seo_page[:heading] %></span>
        </h1>

        <p class="mx-auto mt-7 max-w-xl text-base font-medium leading-8 text-slate-600 sm:text-lg lg:mx-0">
          <%= seo_page[:hero_intro] %>
        </p>
      <% else %>
        <h1 class="mx-auto mt-7 max-w-3xl text-4xl font-black leading-[0.95] tracking-tight text-slate-950 sm:text-6xl lg:mx-0 lg:text-7xl">
          Build. Market.<br>
          Automate. <span class="text-shimmer bg-gradient-to-r from-blue-600 via-cyan-500 to-blue-700 bg-clip-text text-transparent">Grow.</span>
        </h1>

        <p class="mx-auto mt-7 max-w-xl text-base font-medium leading-8 text-slate-600 sm:text-lg lg:mx-0">
          M&W Labs is a full-service digital agency helping businesses launch, grow, and scale. We build websites and software, run marketing that wins customers, craft brands and content, and automate operations with AI.
        </p>
      <% end %>

      <div class="mt-9 flex flex-col justify-center gap-4 sm:flex-row lg:justify-start">
        <%= link_to contact_path, class: "btn-shine inline-flex items-center justify-center rounded-2xl bg-blue-600 px-7 py-4 text-sm font-extrabold text-white shadow-xl shadow-blue-600/25 transition hover:-translate-y-0.5 hover:bg-blue-700 hover:shadow-2xl hover:shadow-blue-600/30" do %>
          Start Your Project
          <svg class="ms-3 h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 18 18">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 9h10m0 0-4-4m4 4-4 4"/>
          </svg>
        <% end %>

        <%= link_to work_path, class: "inline-flex items-center justify-center rounded-2xl border border-blue-200 bg-white/90 px-7 py-4 text-sm font-extrabold text-blue-700 shadow-lg shadow-blue-100/50 backdrop-blur transition hover:-translate-y-0.5 hover:border-blue-300 hover:bg-blue-50" do %>
          View Our Work
          <svg class="ms-3 h-4 w-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 18 18">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 9h10m0 0-4-4m4 4-4 4"/>
          </svg>
        <% end %>
      </div>

      <div class="mt-10 flex flex-col items-center gap-5 sm:flex-row sm:justify-center lg:justify-start">
        <div class="flex -space-x-3">
          <% ["AM", "RS", "TN", "MK", "JL"].each_with_index do |initials, index| %>
            <% colors = ["bg-blue-100 text-blue-700", "bg-slate-200 text-slate-700", "bg-cyan-100 text-cyan-700", "bg-indigo-100 text-indigo-700", "bg-rose-100 text-rose-700"] %>
            <span class="flex h-10 w-10 items-center justify-center rounded-full border-2 border-white text-xs font-black shadow-sm transition duration-300 hover:-translate-y-1 hover:z-10 <%= colors[index] %>"><%= initials %></span>
          <% end %>
        </div>

        <div>
          <div class="flex gap-0.5 text-yellow-400">
            <% 5.times do %>
              <svg class="h-4 w-4 fill-current" aria-hidden="true" viewBox="0 0 20 20">
                <path d="m10 1.5 2.6 5.3 5.9.9-4.3 4.2 1 5.9L10 15l-5.2 2.8 1-5.9-4.3-4.2 5.9-.9L10 1.5Z"/>
              </svg>
            <% end %>
          </div>
          <p class="mt-1 text-sm font-semibold leading-5 text-slate-600">Trusted by 200+<br>Businesses Worldwide</p>
        </div>
      </div>

    </div>

    <div class="hero-visual-stage relative mx-auto min-h-[380px] w-full max-w-2xl overflow-visible sm:min-h-[450px] lg:-mr-2 lg:min-h-[600px] lg:max-w-4xl xl:max-w-[58rem]" data-parallax-scene>
      <div class="scene-stage absolute inset-0">
        <div class="scene-layer absolute inset-0" style="--depth: 0.35;">
          <div class="hero-orbit absolute left-1/2 top-1/2 h-[78%] w-[91%] -translate-x-1/2 -translate-y-1/2 rounded-[50%] border border-blue-200/80"></div>
          <div class="absolute left-1/2 top-1/2 h-[66%] w-[78%] -translate-x-1/2 -translate-y-1/2 rounded-[50%] border border-cyan-200/60"></div>
          <div class="orbit-dot absolute left-[13%] top-[45%] h-2.5 w-2.5 rounded-full bg-blue-600 shadow-lg shadow-blue-500/40 sm:h-3 sm:w-3"></div>
          <div class="orbit-dot orbit-dot-delay absolute right-[28%] top-[17%] h-2.5 w-2.5 rounded-full bg-cyan-500 shadow-lg shadow-cyan-500/40 sm:h-3 sm:w-3"></div>
          <div class="orbit-dot absolute bottom-[12%] left-[56%] h-2.5 w-2.5 rounded-full bg-indigo-500 shadow-lg shadow-indigo-500/40 sm:h-3 sm:w-3"></div>
        </div>

        <div class="scene-layer absolute inset-0" style="--depth: 0.55;">
          <div class="hero-visual-card hero-sheen absolute left-1/2 top-[52%] h-[72%] w-[82%] -translate-x-1/2 -translate-y-1/2 overflow-hidden rounded-[2rem] border border-white/80 bg-white/45 shadow-[0_36px_100px_rgba(15,23,42,0.16)] backdrop-blur before:absolute before:inset-0 before:bg-[linear-gradient(135deg,_rgba(255,255,255,0.75),_rgba(219,234,254,0.24))] after:absolute after:-top-16 after:h-[130%] after:w-28 after:bg-white/30"></div>
        </div>

        <div class="scene-layer absolute left-1/2 top-1/2 z-10 w-[94%] -translate-x-1/2 -translate-y-1/2" style="--depth: 1; --z: 30px;">
          <div class="relative">
            <div class="absolute inset-x-[14%] bottom-4 h-16 rounded-full bg-blue-950/15 blur-2xl"></div>
            <%= tag.img src: "/images/hero-1600.webp",
              srcset: "/images/hero-800.webp 800w, /images/hero-1600.webp 1600w",
              sizes: "(min-width: 1024px) 52rem, 94vw",
              width: 1600,
              height: 1018,
              alt: "M&W Labs digital services",
              loading: "eager",
              fetchpriority: "high",
              decoding: "async",
              class: "relative w-full object-contain drop-shadow-2xl" %>
          </div>
        </div>

        <div class="scene-layer pointer-events-none absolute -left-[14%] top-[38%] z-30 hidden sm:-left-[12%] sm:top-[39%] sm:block" style="--depth: 1.6; --z: 60px;">
          <div class="rounded-2xl border border-white/80 bg-white/90 p-3 shadow-2xl shadow-blue-200/60 backdrop-blur">
            <div class="flex items-center gap-3">
              <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-blue-600 text-white">
                <i class="fa-solid fa-bolt"></i>
              </span>
              <div>
                <p class="text-[0.62rem] font-black uppercase tracking-[0.18em] text-slate-400">Launch Stack</p>
                <p class="mt-0.5 text-sm font-black text-slate-950">Strategy + Build + Growth</p>
              </div>
            </div>
          </div>
        </div>

        <div class="scene-layer pointer-events-none absolute right-[7%] top-[27%] z-30 hidden md:block" style="--depth: 1.8; --z: 70px;">
          <div class="rounded-2xl border border-white/80 bg-slate-950/90 p-3 text-white shadow-2xl shadow-slate-900/20 backdrop-blur">
            <p class="text-[0.62rem] font-black uppercase tracking-[0.18em] text-cyan-100">Optimized</p>
            <p class="mt-1 text-2xl font-black">98<span class="text-sm text-cyan-200">%</span></p>
          </div>
        </div>

        <% [
          [ "Web Development", "fa-code", "left-[8%] top-[12%] sm:left-[14%] sm:top-[11%]", "bg-blue-50 text-blue-600", "hero-float", "1.3", "44px" ],
          [ "Digital Marketing", "fa-chart-line", "right-[8%] top-[9%] sm:right-[12%] sm:top-[7%]", "bg-blue-50 text-blue-600", "hero-float-soft hero-float-delay", "1.5", "52px" ],
          [ "Branding & Design", "fa-pen-nib", "right-[6%] top-[45%] sm:right-[8%]", "bg-indigo-50 text-indigo-600", "hero-float", "1.2", "40px" ],
          [ "Video Editing", "fa-clapperboard", "right-[20%] bottom-[18%] sm:right-[28%] sm:bottom-[15%]", "bg-purple-50 text-purple-600", "hero-float-soft", "1.4", "48px" ],
          [ "AI Automation", "fa-robot", "left-[30%] bottom-[4%] sm:left-[34%] sm:bottom-[3%]", "bg-blue-50 text-blue-600", "hero-float hero-float-delay", "1.6", "56px" ],
          [ "Growth Strategy", "fa-bullseye", "left-[1%] bottom-[26%] sm:left-[4%] sm:bottom-[24%]", "bg-emerald-50 text-emerald-600", "hero-float-soft hero-float-delay", "1.25", "42px" ]
        ].each do |label, icon, position, color, animation, depth, z| %>
          <div class="scene-layer pointer-events-none absolute z-20 <%= position %>" style="--depth: <%= depth %>; --z: <%= z %>;">
            <div class="flex items-center gap-1.5 rounded-xl border border-white/80 bg-white/95 px-2 py-1.5 text-[0.52rem] font-extrabold text-slate-800 shadow-xl shadow-slate-200/80 backdrop-blur sm:gap-2 sm:rounded-2xl sm:px-3 sm:py-2 sm:text-[0.65rem] md:gap-3 md:px-4 md:py-3 md:text-xs <%= animation %>">
              <span class="flex h-6 w-6 items-center justify-center rounded-lg text-[0.65rem] sm:h-7 sm:w-7 sm:rounded-xl md:h-9 md:w-9 md:text-base <%= color %>">
                <i class="fa-solid <%= icon %>"></i>
              </span>
              <span><%= label %></span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mx-auto mb-12 max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16" data-reveal>
    <div class="rounded-2xl border border-slate-200 bg-white px-5 py-8 shadow-sm sm:px-8">
      <p class="text-center text-xs font-black uppercase tracking-[0.3em] text-slate-500">Trusted by businesses of all sizes</p>
      <div class="logo-marquee relative mt-7">
        <div class="logo-marquee-track items-center">
          <% 2.times do |copy| %>
            <% [
              [ "wave.svg", "Wave" ],
              [ "slack.svg", "Slack" ],
              [ "notion.svg", "Notion" ],
              [ "google.svg", "Google" ],
              [ "monday.svg", "Monday.com" ],
              [ "hubspot.svg", "HubSpot" ],
              [ "shopify.svg", "Shopify" ],
              [ "techtotherescue.svg", "Tech To The Rescue" ]
            ].each do |filename, name| %>
              <div class="mx-6 flex h-20 w-36 shrink-0 items-center justify-center transition duration-300 hover:scale-110 sm:mx-8 sm:w-40" <%= 'aria-hidden="true"'.html_safe if copy == 1 %>>
                <%= tag.img src: "/images/logos/#{filename}", alt: copy.zero? ? name : "", loading: "lazy", decoding: "async", class: "max-h-20 w-full object-contain" %>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="pointer-events-none fixed inset-x-3 bottom-4 z-50 translate-y-4 opacity-0 transition duration-500 sm:inset-x-auto sm:right-6 sm:bottom-6" data-controller="floating-cta" data-floating-cta>
  <div class="relative overflow-hidden rounded-[1.35rem] border border-white/70 bg-white/90 p-2 shadow-[0_24px_70px_rgba(15,23,42,0.18)] ring-1 ring-slate-900/5 backdrop-blur-xl sm:w-[19rem]">
    <div class="pointer-events-none absolute -right-10 -top-12 h-28 w-28 rounded-full bg-blue-100 blur-2xl"></div>
    <div class="pointer-events-none absolute -bottom-12 -left-10 h-28 w-28 rounded-full bg-emerald-100 blur-2xl"></div>

    <button type="button" class="absolute right-3 top-3 z-20 flex h-7 w-7 items-center justify-center rounded-full border border-slate-200 bg-white/90 text-xs text-slate-500 shadow-sm transition hover:-translate-y-0.5 hover:bg-slate-950 hover:text-white" aria-label="Close floating contact buttons" data-action="floating-cta#close">
      <i class="fa-solid fa-xmark"></i>
    </button>

    <div class="relative hidden border-b border-slate-100 px-3 pb-3 pt-2 sm:block">
      <p class="pr-8 text-xs font-black uppercase tracking-[0.2em] text-blue-600">Need a quick answer?</p>
      <p class="mt-1 text-sm font-extrabold text-slate-950">Talk to M&W Labs</p>
    </div>

    <div class="relative grid grid-cols-2 gap-2 sm:mt-2 sm:grid-cols-1">
      <a href="https://wa.me/8801704014210?text=Hi%20M%26W%20Labs%2C%20I%20want%20to%20discuss%20a%20project." target="_blank" rel="noopener" class="group inline-flex items-center justify-center gap-2 rounded-2xl bg-emerald-500 px-3 py-3 text-xs font-extrabold text-white shadow-lg shadow-emerald-500/25 transition hover:-translate-y-0.5 hover:bg-emerald-600 sm:justify-start sm:px-4 sm:py-3.5 sm:text-sm" data-floating-cta-whatsapp>
        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-white/20 text-lg transition group-hover:bg-white/25">
          <i class="fa-brands fa-whatsapp"></i>
        </span>
        <span class="leading-tight">
          WhatsApp
          <span class="hidden text-[0.68rem] font-bold text-emerald-50 sm:block">Fast project chat</span>
        </span>
      </a>

      <%= link_to contact_path, class: "group inline-flex items-center justify-center gap-2 rounded-2xl bg-slate-950 px-3 py-3 text-xs font-extrabold text-white shadow-lg shadow-slate-950/20 transition hover:-translate-y-0.5 hover:bg-blue-600 sm:justify-start sm:px-4 sm:py-3.5 sm:text-sm", data: { floating_cta_quote: true } do %>
        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-white/10 text-sm transition group-hover:bg-white/20">
          <i class="fa-solid fa-file-signature"></i>
        </span>
        <span class="leading-tight">
          Get a Quote
          <span class="hidden text-[0.68rem] font-bold text-slate-300 group-hover:text-blue-50 sm:block">Start your enquiry</span>
        </span>
      <% end %>
    </div>
  </div>
</div>

<section class="bg-white py-12">
  <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16" data-reveal>
    <div class="gradient-ring relative grid gap-5 overflow-hidden rounded-2xl bg-[radial-gradient(circle_at_top_right,_#eff6ff,_transparent_28rem),#ffffff] p-6 shadow-sm lg:grid-cols-[1fr_auto] lg:items-center lg:p-8">
      <div class="aurora-blob pointer-events-none absolute -right-16 -top-20 h-48 w-48 rounded-full bg-blue-100/70 blur-3xl"></div>

      <div class="relative">
        <p class="text-sm font-extrabold uppercase tracking-[0.25em] text-blue-600"><%= seo_page ? "Founder Growth Offer" : "Who We Are" %></p>
        <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">
          <% if seo_page %>
            <%= seo_page[:offer_heading] %>
          <% else %>
            A dedicated digital team behind your business growth.
          <% end %>
        </h2>
        <p class="mt-4 max-w-3xl text-sm font-semibold leading-8 text-slate-600">
          <% if seo_page %>
            <%= seo_page[:offer_body] %>
          <% else %>
            M&W Labs brings developers, marketers, designers, and strategists together as one team. From the first strategy session to launch and beyond, we plan, build, and grow digital products and campaigns that deliver measurable results for businesses worldwide.
          <% end %>
        </p>
      </div>

      <div class="relative flex flex-col gap-3 sm:flex-row lg:flex-col">
        <%= link_to contact_path, class: "btn-shine inline-flex items-center justify-center rounded-xl bg-blue-600 px-7 py-4 text-sm font-extrabold text-white shadow-xl shadow-blue-600/20 transition hover:-translate-y-0.5 hover:bg-blue-700" do %>
          Work With Us
          <i class="fa-solid fa-rocket ms-3 text-xs"></i>
        <% end %>
        <%= link_to about_path, class: "inline-flex items-center justify-center rounded-xl border border-blue-200 bg-white px-7 py-4 text-sm font-extrabold text-blue-700 shadow-sm transition hover:-translate-y-0.5 hover:bg-blue-50" do %>
          More About M&W Labs
          <i class="fa-solid fa-users ms-3 text-xs"></i>
        <% end %>
      </div>
    </div>
  </div>
</section>

<section id="services" class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <p class="text-sm font-extrabold uppercase tracking-[0.25em] text-blue-600">Our Services</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">
        <% if seo_page %>
          <%= seo_page[:services_heading] %>
        <% else %>
          Everything Your Business Needs to <span class="bg-gradient-to-r from-blue-600 to-cyan-500 bg-clip-text text-transparent">Grow Digitally</span>
        <% end %>
      </h2>
      <% if seo_page %>
        <p class="mx-auto mt-4 max-w-2xl text-sm font-semibold leading-7 text-slate-600 sm:text-base">
          <%= seo_page[:services_subheading] %>
        </p>
      <% end %>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6">
      <% [
        {
          icon: "fa-code",
          color: "bg-blue-600 text-white",
          title: "Web & Software Development",
          body: "Custom websites, web apps, SaaS platforms, dashboards and business systems.",
          slug: "web-development"
        },
        {
          icon: "fa-bullhorn",
          color: "bg-emerald-50 text-emerald-600",
          title: "Digital Marketing",
          body: "SEO, Google & Meta Ads, lead generation, funnels, email and WhatsApp marketing.",
          slug: "digital-marketing"
        },
        {
          icon: "fa-pen-nib",
          color: "bg-purple-50 text-purple-600",
          title: "Branding & Design",
          body: "Logo design, brand identity, social media creatives, brochures and more.",
          slug: "branding-design"
        },
        {
          icon: "fa-clapperboard",
          color: "bg-pink-50 text-pink-600",
          title: "Video Editing & Content",
          body: "Reels, YouTube videos, ads, corporate videos, motion graphics and more.",
          slug: "video-editing"
        },
        {
          icon: "fa-robot",
          color: "bg-amber-50 text-amber-600",
          title: "AI & Automation",
          body: "AI chatbots, automation, workflows, dashboards and smart integrations.",
          slug: "ai-automation"
        },
        {
          icon: "fa-bullseye",
          color: "bg-cyan-50 text-cyan-600",
          title: "Growth Strategy",
          body: "Business strategy, market research, competitor analysis and scaling plans.",
          slug: "growth-strategy"
        }
      ].each_with_index do |service, index| %>
        <div class="h-full" data-reveal data-reveal-delay="<%= index * 80 %>">
          <div class="tilt-3d tilt-glare relative flex h-full flex-col rounded-xl border border-slate-200 bg-white p-6 shadow-sm hover:border-blue-200 hover:shadow-2xl hover:shadow-blue-100/70" data-tilt>
            <div class="tilt-pop mb-6 flex h-14 w-14 items-center justify-center rounded-2xl shadow-lg shadow-slate-200/60 <%= service[:color] %>">
              <i class="fa-solid <%= service[:icon] %> text-2xl"></i>
            </div>

            <h3 class="text-lg font-black leading-snug text-slate-950"><%= service[:title] %></h3>
            <p class="mt-4 flex-1 text-sm font-medium leading-7 text-slate-600"><%= service[:body] %></p>

            <div class="mt-6 space-y-3">
              <%= link_to service_path(service[:slug]), class: "group inline-flex items-center text-sm font-extrabold text-blue-600 hover:text-blue-700" do %>
                Explore
                <i class="fa-solid fa-arrow-right ms-2 text-xs transition-transform duration-300 group-hover:translate-x-1"></i>
              <% end %>
              <%= link_to contact_path, class: "inline-flex w-full items-center justify-center rounded-xl border border-blue-100 bg-blue-50 px-4 py-3 text-xs font-extrabold text-blue-700 transition hover:bg-blue-100" do %>
                Get a Quote
                <i class="fa-solid fa-paper-plane ms-2 text-[0.65rem]"></i>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-10 text-center" data-reveal>
      <%= link_to contact_path, class: "btn-shine inline-flex items-center justify-center rounded-xl bg-blue-600 px-7 py-4 text-sm font-extrabold text-white shadow-xl shadow-blue-600/20 transition hover:-translate-y-0.5 hover:bg-blue-700" do %>
        Not Sure What You Need? Talk to Us
