    <div class="mt-4 flex justify-center gap-2" data-testimonials-dots>
      <% 3.times do |index| %>
        <button type="button" class="h-3 w-3 rounded-full transition <%= index.zero? ? "bg-blue-600" : "bg-blue-100" %>" data-testimonials-dot="<%= index %>" aria-label="Show testimonial <%= index + 1 %>" aria-pressed="<%= index.zero? %>"></button>
      <% end %>
    </div>

    <div class="mt-8 text-center" data-reveal>
      <%= link_to contact_path, class: "inline-flex items-center justify-center rounded-xl border border-blue-200 bg-white px-7 py-4 text-sm font-extrabold text-blue-700 shadow-sm transition hover:-translate-y-0.5 hover:bg-blue-50 hover:shadow-lg hover:shadow-blue-100" do %>
        Get Results Like These
        <i class="fa-solid fa-arrow-trend-up ms-3 text-xs"></i>
      <% end %>
    </div>

    <div class="relative mt-8 overflow-hidden rounded-2xl bg-gradient-to-r from-indigo-600 via-blue-600 to-cyan-500 px-6 py-9 text-white shadow-2xl shadow-blue-600/20 sm:px-10 lg:px-16" data-reveal="zoom">
      <div class="absolute left-0 top-0 h-full w-40 opacity-20 [background-image:radial-gradient(circle,_white_1px,_transparent_1px)] [background-size:12px_12px]"></div>
      <div class="aurora-blob pointer-events-none absolute -right-20 -top-24 h-72 w-72 rounded-full bg-cyan-300/30 blur-3xl"></div>
      <div class="aurora-blob-slow pointer-events-none absolute -bottom-24 left-1/4 h-64 w-64 rounded-full bg-indigo-300/25 blur-3xl"></div>
      <div class="absolute right-8 top-1/2 hidden -translate-y-1/2 text-white/90 lg:block">
        <i class="fa-solid fa-paper-plane text-8xl drop-shadow-2xl"></i>
      </div>

      <div class="relative z-10 grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center lg:pr-40">
        <div>
          <p class="text-sm font-extrabold text-blue-100">Ready to Grow Your Business?</p>
          <h3 class="mt-3 text-3xl font-black tracking-tight sm:text-4xl">
            <% if seo_page %>
              <%= seo_page[:cta_heading] %>
            <% else %>
              Let's Build Something Amazing Together!
            <% end %>
          </h3>
          <p class="mt-4 max-w-2xl text-base font-semibold leading-8 text-blue-50">
            <% if seo_page %>
              <%= seo_page[:cta_body] %>
            <% else %>
              Book a free strategy call and let's discuss how we can help you grow.
            <% end %>
          </p>
        </div>

        <div class="flex flex-col gap-4 sm:flex-row">
          <%= link_to contact_path, class: "btn-shine inline-flex items-center justify-center rounded-xl bg-white px-7 py-4 text-sm font-extrabold text-blue-700 shadow-xl shadow-blue-950/10 transition hover:-translate-y-0.5 hover:bg-blue-50" do %>
            Book a Free Call
            <i class="fa-solid fa-phone ms-3 text-xs"></i>
          <% end %>
          <%= link_to contact_path, class: "inline-flex items-center justify-center rounded-xl border border-white/30 bg-white/10 px-7 py-4 text-sm font-extrabold text-white shadow-sm backdrop-blur transition hover:-translate-y-0.5 hover:bg-white/20" do %>
            Request a Quote
            <i class="fa-solid fa-arrow-right ms-3 text-xs"></i>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
