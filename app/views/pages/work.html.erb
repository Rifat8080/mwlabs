<% content_for :title, "Our Work | Mwlabs" %>
<% content_for :meta_description, "Explore recent M&W Labs work across web development, digital marketing, branding, video content, SaaS dashboards, and automation projects." %>

<%= render "pages/shared/hero",
  eyebrow: "Our Work",
  title: "Projects That Drive Real Results",
  description: "Explore recent work across web development, marketing, branding, video and automation." %>

<section class="bg-white py-14 sm:py-16" data-project-section>
  <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
    <div class="flex flex-wrap gap-2" data-project-filters>
      <% [ "All", "Web Development", "Marketing", "Branding", "Video" ].each_with_index do |filter, index| %>
        <button type="button" class="rounded-lg border px-5 py-2.5 text-xs font-extrabold transition <%= index.zero? ? "border-blue-600 bg-blue-600 text-white shadow-lg shadow-blue-600/20" : "border-slate-200 bg-white text-slate-700 hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700" %>" data-project-filter="<%= filter %>" aria-pressed="<%= index.zero? %>">
          <%= filter %>
        </button>
      <% end %>
    </div>

    <div class="mt-9 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-project-grid>
      <% [
        [ "Fintech Website Development", "Web Development" ],
        [ "Lead Generation Campaign", "Marketing" ],
        [ "Coffee Brand Identity", "Branding" ],
        [ "YouTube Channel Editing", "Video" ],
        [ "SaaS Dashboard Development", "Web Development" ],
        [ "Instagram Ad Campaign", "Marketing" ]
      ].each do |title, category| %>
        <article class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-blue-100 hover:shadow-xl hover:shadow-blue-100/70" data-project-card data-project-category="<%= category %>">
          <h2 class="text-lg font-black text-slate-950"><%= title %></h2>
          <p class="mt-2 text-sm font-bold text-slate-500"><%= category %></p>
        </article>
      <% end %>
    </div>
  </div>
</section>

<%= render "pages/shared/cta" %>
