<% content_for :title, "Pricing | Mwlabs" %>

<%= render "pages/shared/hero",
  eyebrow: "Pricing",
  title: "Flexible Plans for Every Stage",
  description: "Transparent packages designed for startups, growing teams and established businesses." %>

<section class="bg-white py-14 sm:py-16">
  <div class="mx-auto grid max-w-[104rem] gap-6 px-4 sm:px-6 lg:grid-cols-3 lg:px-12 2xl:px-16">
    <% [
      [ "Starter", "$999", "Perfect for new businesses launching online.", [ "Landing page", "Basic SEO setup", "Brand consultation" ] ],
      [ "Growth", "$2,499", "For businesses ready to scale marketing and conversions.", [ "Custom website", "Marketing funnel", "Monthly reporting" ], true ],
      [ "Enterprise", "Custom", "Tailored solutions for complex growth systems.", [ "Full product build", "Dedicated team", "Automation & AI" ] ]
    ].each do |name, price, description, features, featured = false| %>
      <div class="rounded-2xl border <%= featured ? "border-blue-600 shadow-xl shadow-blue-100" : "border-slate-200 shadow-sm" %> bg-white p-8">
        <p class="text-sm font-extrabold uppercase tracking-[0.2em] text-blue-600"><%= name %></p>
        <p class="mt-4 text-4xl font-black text-slate-950"><%= price %></p>
        <p class="mt-4 text-sm font-semibold leading-7 text-slate-600"><%= description %></p>
        <ul class="mt-6 space-y-3 text-sm font-semibold text-slate-600">
          <% features.each do |feature| %>
            <li class="flex items-center gap-2"><i class="fa-solid fa-check text-blue-600"></i><%= feature %></li>
          <% end %>
        </ul>
        <%= link_to "Get Started", contact_path, class: "mt-8 inline-flex w-full items-center justify-center rounded-xl bg-blue-600 px-6 py-3 text-sm font-extrabold text-white hover:bg-blue-700" %>
      </div>
    <% end %>
  </div>
</section>

<%= render "pages/shared/cta" %>
