<% content_for :title, "Blog | Mwlabs" %>

<%= render "pages/shared/hero",
  eyebrow: "Blog",
  title: "Insights on Digital Growth",
  description: "Tips, strategies and updates from the M&W Labs team on web, marketing, branding and automation." %>

<section class="bg-white py-14 sm:py-16">
  <div class="mx-auto grid max-w-[104rem] gap-6 px-4 sm:px-6 md:grid-cols-2 lg:grid-cols-3 lg:px-12 2xl:px-16">
    <% [
      [ "How to Build a High-Converting Landing Page", "Web Development", "Jun 5, 2026" ],
      [ "5 Marketing Channels Every SaaS Should Test", "Digital Marketing", "May 28, 2026" ],
      [ "Why Brand Consistency Drives Trust Online", "Branding", "May 12, 2026" ]
    ].each do |title, category, date| %>
      <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-blue-100 hover:shadow-xl hover:shadow-blue-100/70">
        <p class="text-xs font-extrabold uppercase tracking-[0.2em] text-blue-600"><%= category %></p>
        <h2 class="mt-3 text-xl font-black leading-snug text-slate-950"><%= title %></h2>
        <p class="mt-4 text-sm font-semibold text-slate-500"><%= date %></p>
      </article>
    <% end %>
  </div>
</section>

<%= render "pages/shared/cta" %>
