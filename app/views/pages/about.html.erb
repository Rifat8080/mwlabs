<% content_for :title, "About Us | Mwlabs" %>
<% content_for :meta_description, "M&W Labs is a full-service digital agency helping businesses launch, grow and scale with websites, marketing, branding, content and automation." %>

<%= render "pages/shared/hero",
  eyebrow: "About Us",
  title: "We Build Digital Growth Systems",
  description: "M&W Labs is a full-service digital agency helping businesses launch, grow and scale with websites, marketing, branding, content and automation." %>

<section class="bg-white py-14 sm:py-16">
  <div class="mx-auto grid max-w-[104rem] gap-10 px-4 sm:px-6 lg:grid-cols-2 lg:items-center lg:px-12 2xl:px-16">
    <div>
      <h2 class="text-2xl font-black text-slate-950 sm:text-3xl">Who We Are</h2>
      <p class="mt-5 text-sm font-semibold leading-8 text-slate-600 sm:text-base">
        We are a team of strategists, designers, developers and marketers focused on building systems that drive measurable business growth. From startups to established brands, we partner with clients who want more than deliverables — they want results.
      </p>
      <p class="mt-4 text-sm font-semibold leading-8 text-slate-600 sm:text-base">
        Our approach blends creativity with data, ensuring every website, campaign and automation workflow is designed to perform.
      </p>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <% [ [ "500+", "Projects Delivered" ], [ "300+", "Happy Clients" ], [ "5+", "Years Experience" ], [ "20+", "Countries Served" ] ].each do |value, label| %>
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <p class="text-3xl font-black text-blue-600"><%= value %></p>
          <p class="mt-2 text-sm font-bold text-slate-500"><%= label %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%= render "pages/shared/cta" %>
