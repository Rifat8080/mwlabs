<% content_for :title, "#{@service[:title]} | Mwlabs" %>
<% content_for :meta_description, @service[:summary] %>
<% content_for :structured_data do %>
  <%= jsonld_tag service_jsonld(name: @service[:title], description: @service[:summary], url: service_url(params[:slug])) %>
<% end %>

<%= render "pages/shared/hero",
  eyebrow: @service[:eyebrow],
  title: @service[:title],
  description: @service[:summary] %>

<section class="bg-white py-14 sm:py-16">
  <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-extrabold uppercase tracking-[0.25em] text-blue-600">What's Included</p>
      <h2 class="mt-3 text-2xl font-black tracking-tight text-slate-950 sm:text-4xl">Everything You Get With Our <%= @service[:eyebrow] %> Service</h2>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      <% @service[:features].each do |feature| %>
        <div class="flex h-full flex-col rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-blue-200 hover:shadow-lg hover:shadow-blue-100/70">
          <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl shadow-lg shadow-slate-200/60 <%= @service[:color] %>">
            <i class="fa-solid <%= feature[:icon] %> text-lg"></i>
          </div>
          <h3 class="text-base font-black leading-snug text-slate-950"><%= feature[:title] %></h3>
          <p class="mt-3 flex-1 text-sm font-medium leading-7 text-slate-600"><%= feature[:body] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<section class="bg-slate-50 py-14 sm:py-16">
  <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-extrabold uppercase tracking-[0.25em] text-blue-600">How It Works</p>
      <h2 class="mt-3 text-2xl font-black tracking-tight text-slate-950 sm:text-4xl">Our <%= @service[:eyebrow] %> Process</h2>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      <% @service[:process].each_with_index do |step, index| %>
        <div class="relative rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-blue-600 text-sm font-black text-white"><%= index + 1 %></span>
          <h3 class="mt-5 text-base font-black text-slate-950"><%= step[:title] %></h3>
          <p class="mt-3 text-sm font-medium leading-7 text-slate-600"><%= step[:body] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<section class="bg-white py-14 sm:py-16">
  <div class="mx-auto grid max-w-[104rem] gap-10 px-4 sm:px-6 lg:grid-cols-2 lg:items-start lg:px-12 2xl:px-16">
    <div>
      <p class="text-sm font-extrabold uppercase tracking-[0.25em] text-blue-600">Tools & Technology</p>
      <h2 class="mt-3 text-2xl font-black tracking-tight text-slate-950 sm:text-3xl">What We Use to Deliver</h2>
      <p class="mt-5 text-sm font-semibold leading-8 text-slate-600 sm:text-base">
        <%= @service[:summary] %> We combine proven tools with an experienced team to deliver work that looks great and performs even better.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <% @service[:tools].each do |tool| %>
          <span class="rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-xs font-extrabold text-slate-700"><%= tool %></span>
        <% end %>
      </div>
      <div class="mt-8 flex flex-wrap gap-4">
        <%= link_to "Get a Free Strategy Call", contact_path, class: "inline-flex items-center justify-center rounded-xl bg-blue-600 px-7 py-4 text-sm font-extrabold text-white shadow-xl shadow-blue-600/20 hover:bg-blue-700" %>
        <%= link_to "View Our Work", work_path, class: "inline-flex items-center justify-center rounded-xl border border-blue-200 bg-white px-7 py-4 text-sm font-extrabold text-blue-700 hover:bg-blue-50" %>
      </div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
      <h2 class="text-xl font-black text-slate-950">Frequently Asked Questions</h2>
      <div class="mt-5 space-y-5">
        <% @service[:faqs].each do |faq| %>
          <div class="border-b border-slate-100 pb-5 last:border-0 last:pb-0">
            <h3 class="text-sm font-black text-slate-950"><%= faq[:q] %></h3>
            <p class="mt-2 text-sm font-medium leading-7 text-slate-600"><%= faq[:a] %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<section class="bg-slate-50 py-14 sm:py-16">
  <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
    <h2 class="text-2xl font-black text-slate-950">More Services</h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% PagesHelper::SERVICE_LINKS.reject { |_, slug| slug == params[:slug] }.each do |label, slug| %>
        <%= link_to service_path(slug), class: "rounded-xl border border-slate-200 bg-white p-5 text-sm font-extrabold text-slate-700 shadow-sm transition hover:border-blue-100 hover:text-blue-600 hover:shadow-lg hover:shadow-blue-100" do %>
          <%= label %>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<%= render "pages/shared/cta" %>
