<% content_for :title, "#{@project.title} Case Study | Mwlabs" %>
<% content_for :meta_description, @project.summary %>

<section class="border-b border-slate-100 bg-[radial-gradient(circle_at_top_right,_#eff6ff,_transparent_28rem),linear-gradient(180deg,_#ffffff_0%,_#f8fbff_100%)] py-14 sm:py-16">
  <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
    <%= link_to work_path, class: "inline-flex items-center gap-2 text-sm font-extrabold text-blue-600 hover:text-blue-700" do %>
      <i class="fa-solid fa-arrow-left text-xs"></i>
      Back to Our Work
    <% end %>

    <div class="mt-6 flex flex-wrap items-center gap-3">
      <span class="inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-xs font-extrabold uppercase tracking-wide <%= portfolio_category_color(@project.category) %>">
        <i class="fa-solid <%= portfolio_category_icon(@project.category) %>"></i>
        <%= @project.category %>
      </span>
      <% if @project.completed_on.present? %>
        <span class="text-xs font-extrabold uppercase tracking-wide text-slate-400"><%= @project.completed_on.strftime("%B %Y") %></span>
      <% end %>
    </div>

    <h1 class="mt-4 max-w-4xl text-3xl font-black tracking-tight text-slate-950 sm:text-5xl"><%= @project.title %></h1>
    <p class="mt-5 max-w-3xl text-base font-semibold leading-8 text-slate-600 sm:text-lg"><%= @project.summary %></p>

    <div class="mt-8 flex flex-wrap gap-4">
      <%= link_to "Get a Free Strategy Call", contact_path, class: "inline-flex items-center justify-center rounded-xl bg-blue-600 px-7 py-4 text-sm font-extrabold text-white shadow-xl shadow-blue-600/20 hover:bg-blue-700" %>
      <% if @project.project_url.present? %>
        <%= link_to @project.project_url, target: "_blank", rel: "noopener", class: "inline-flex items-center justify-center rounded-xl border border-blue-200 bg-white px-7 py-4 text-sm font-extrabold text-blue-700 hover:bg-blue-50" do %>
          Visit Live Site
          <i class="fa-solid fa-arrow-up-right-from-square ms-3 text-xs"></i>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<% gallery_images = portfolio_showcase_images(@project) %>
<% if gallery_images.any? %>
  <section class="bg-white py-14 sm:py-16">
    <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
      <div data-showcase>
        <div class="relative aspect-video overflow-hidden rounded-2xl bg-slate-950 shadow-2xl shadow-slate-900/10">
          <% gallery_images.each_with_index do |image, index| %>
            <%= image_tag image.variant(resize_to_limit: [ 1600, 900 ]), class: "absolute inset-0 h-full w-full object-cover transition-opacity duration-700 #{index.zero? ? 'opacity-100' : 'opacity-0'}", data: { showcase_slide: true }, alt: "#{@project.title} screenshot #{index + 1}" %>
          <% end %>

          <div class="absolute left-4 top-4 hidden items-center gap-2 rounded-full bg-slate-950/70 px-3 py-1.5 text-[0.65rem] font-extrabold uppercase tracking-wide text-white backdrop-blur" data-showcase-live-dot>
            <span class="relative flex h-1.5 w-1.5">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
            </span>
            Live preview
          </div>

          <% if gallery_images.size > 1 %>
            <button type="button" data-showcase-prev class="absolute left-4 top-1/2 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-slate-700 shadow-xl transition hover:bg-white" aria-label="Previous image">
              <i class="fa-solid fa-chevron-left"></i>
            </button>
            <button type="button" data-showcase-next class="absolute right-4 top-1/2 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-slate-700 shadow-xl transition hover:bg-white" aria-label="Next image">
              <i class="fa-solid fa-chevron-right"></i>
            </button>
          <% end %>
        </div>

        <% if gallery_images.size > 1 %>
          <div class="mt-4 flex gap-3 overflow-x-auto pb-2">
            <% gallery_images.each_with_index do |image, index| %>
              <button type="button" data-showcase-thumb="<%= index %>" class="h-16 w-24 shrink-0 overflow-hidden rounded-lg opacity-60 shadow-sm transition <%= index.zero? ? "ring-2 ring-blue-600 opacity-100" : "" %>">
                <%= image_tag image.variant(resize_to_fill: [ 200, 130 ]), class: "h-full w-full object-cover", alt: "Thumbnail #{index + 1}" %>
              </button>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<section class="bg-slate-50 py-14 sm:py-16">
  <div class="mx-auto grid max-w-[104rem] gap-10 px-4 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-start lg:px-12 2xl:px-16">
    <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
      <h2 class="text-2xl font-black text-slate-950 sm:text-3xl">The Story</h2>
      <div class="trix-content mt-5 max-w-none text-sm font-medium leading-8 text-slate-600 sm:text-base">
        <%= @project.story %>
      </div>
    </div>

    <div class="space-y-6">
      <% if @project.result_metric_value.present? %>
        <div class="rounded-2xl border border-blue-100 bg-gradient-to-br from-blue-600 to-cyan-500 p-7 text-white shadow-xl shadow-blue-600/20">
          <p class="text-xs font-extrabold uppercase tracking-[0.2em] text-blue-100">The Result</p>
          <div class="mt-3 flex items-baseline gap-2">
            <span class="text-5xl font-black" data-counter="<%= @project.result_metric_value %>" data-counter-suffix="<%= @project.result_metric_suffix %>">0<%= @project.result_metric_suffix %></span>
          </div>
          <p class="mt-2 text-sm font-bold text-blue-50"><%= @project.result_metric_label %></p>
        </div>
      <% end %>

      <div class="rounded-2xl border border-slate-200 bg-white p-7 shadow-sm">
        <h3 class="text-lg font-black text-slate-950">Project Details</h3>
        <dl class="mt-5 space-y-4 text-sm">
          <% if @project.client_name.present? %>
            <div class="flex items-center justify-between gap-3 border-b border-slate-100 pb-4">
              <dt class="font-bold text-slate-400">Client</dt>
              <dd class="font-extrabold text-slate-900"><%= @project.client_name %></dd>
            </div>
          <% end %>
          <div class="flex items-center justify-between gap-3 border-b border-slate-100 pb-4">
            <dt class="font-bold text-slate-400">Service</dt>
            <dd class="font-extrabold text-slate-900"><%= @project.category %></dd>
          </div>
          <% if @project.completed_on.present? %>
            <div class="flex items-center justify-between gap-3 border-b border-slate-100 pb-4 last:border-0 last:pb-0">
              <dt class="font-bold text-slate-400">Completed</dt>
              <dd class="font-extrabold text-slate-900"><%= @project.completed_on.strftime("%B %Y") %></dd>
            </div>
          <% end %>
        </dl>

        <% if @project.technology_list.any? %>
          <div class="mt-5 border-t border-slate-100 pt-5">
            <p class="text-xs font-black uppercase tracking-[0.16em] text-slate-400">Technologies</p>
            <div class="mt-3 flex flex-wrap gap-2">
              <% @project.technology_list.each do |tech| %>
                <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1.5 text-xs font-extrabold text-slate-700"><%= tech %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<% if @related_projects.any? %>
  <section class="bg-white py-14 sm:py-16">
    <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
      <h2 class="text-2xl font-black text-slate-950">More <%= @project.category %> Projects</h2>
      <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        <% @related_projects.each do |related| %>
          <%= link_to portfolio_project_path(related.slug), class: "group rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-blue-100 hover:shadow-xl hover:shadow-blue-100/70" do %>
            <h3 class="text-base font-black text-slate-950 transition group-hover:text-blue-700"><%= related.title %></h3>
            <p class="mt-2 text-xs font-extrabold uppercase tracking-wide text-slate-400"><%= related.client_name %></p>
            <p class="mt-3 text-sm font-medium leading-7 text-slate-600 line-clamp-2"><%= related.summary %></p>
          <% end %>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<%= render "pages/shared/cta" %>
