<% content_for :title, "Testimonials | Mwlabs" %>
<% content_for :meta_description, "Read testimonials from clients who trusted M&W Labs to build websites, run campaigns, improve branding, and scale their businesses." %>

<%= render "pages/shared/hero",
  eyebrow: "Testimonials",
  title: "Real People. Real Results.",
  description: "Hear from clients who trusted M&W Labs to build, market and scale their businesses." %>

<section class="bg-white py-14 sm:py-16" data-testimonials-section>
  <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
    <div class="relative">
      <button type="button" class="absolute -left-3 top-1/2 z-20 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-blue-100 bg-white text-blue-600 shadow-xl sm:-left-5" data-testimonials-prev aria-label="Previous testimonial">
        <i class="fa-solid fa-chevron-left text-sm"></i>
      </button>
      <div class="overflow-hidden px-1">
        <div class="flex snap-x snap-mandatory gap-5 overflow-x-auto scroll-smooth pb-2 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" data-testimonials-track>
          <% [
            [ "The team at M&W Labs is exceptional. They built our website, ran amazing ads and the results exceeded our expectations.", "Jessica Brown", "Marketing Manager, Brandco", "JB" ],
            [ "Highly professional and creative team. They understand our needs and deliver solutions that actually grow our business.", "Michael Lee", "Founder, Shopwise", "ML" ],
            [ "From branding to video editing, everything was top quality. Communication was smooth and timely.", "Sarah Johnson", "CEO, Skyhigh", "SJ" ]
          ].each do |quote, name, role, initials| %>
            <article class="min-w-full snap-start rounded-2xl border border-slate-200 bg-white p-7 shadow-sm sm:min-w-[calc(50%-0.625rem)] lg:min-w-[calc(33.333%-0.875rem)]">
              <i class="fa-solid fa-quote-left text-3xl text-blue-100"></i>
              <blockquote class="mt-2 min-h-24 text-sm font-semibold leading-7 text-slate-600"><%= quote %></blockquote>
              <div class="mt-6 flex items-center gap-4">
                <div class="flex h-12 w-12 items-center justify-center rounded-full bg-blue-600 text-sm font-black text-white"><%= initials %></div>
                <div>
                  <p class="font-black text-slate-950"><%= name %></p>
                  <p class="mt-1 text-xs font-bold text-slate-500"><%= role %></p>
                </div>
              </div>
            </article>
          <% end %>
        </div>
      </div>
      <button type="button" class="absolute -right-3 top-1/2 z-20 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-blue-100 bg-white text-blue-600 shadow-xl sm:-right-5" data-testimonials-next aria-label="Next testimonial">
        <i class="fa-solid fa-chevron-right text-sm"></i>
      </button>
    </div>
    <div class="mt-4 flex justify-center gap-2" data-testimonials-dots>
      <% 3.times do |index| %>
        <button type="button" class="h-3 w-3 rounded-full <%= index.zero? ? "bg-blue-600" : "bg-blue-100" %>" data-testimonials-dot="<%= index %>" aria-label="Show testimonial <%= index + 1 %>" aria-pressed="<%= index.zero? %>"></button>
      <% end %>
    </div>
  </div>
</section>

<%= render "pages/shared/cta" %>
