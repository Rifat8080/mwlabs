<% content_for :title, "Mwlabs" %>

<section class="relative isolate overflow-hidden bg-white">
  <div class="absolute left-1/2 top-16 -z-10 h-72 w-72 -translate-x-1/2 rounded-full bg-blue-100/50 blur-3xl"></div>

  <div class="mx-auto grid max-w-[90rem] items-center gap-10 px-4 py-12 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16 lg:px-10 lg:py-20">
    <div class="text-center lg:text-left">
      <div class="mx-auto inline-flex items-center gap-2 rounded-full border border-blue-100 bg-white px-4 py-2 text-[0.68rem] font-extrabold uppercase tracking-[0.18em] text-blue-700 shadow-sm sm:text-xs lg:mx-0">
        Digital solutions that drive real growth
        <span class="flex h-5 w-5 items-center justify-center rounded-full bg-blue-50 text-blue-600">+</span>
      </div>

      <h1 class="mx-auto mt-7 max-w-3xl text-4xl font-black leading-[0.95] tracking-tight text-slate-950 sm:text-6xl lg:mx-0 lg:text-7xl">
        Build. Market.<br>
        Automate. <span class="text-blue-600">Grow.</span>
      </h1>

      <p class="mx-auto mt-7 max-w-xl text-base font-medium leading-8 text-slate-600 sm:text-lg lg:mx-0">
        M&W Labs is a full-service digital agency helping businesses build powerful websites, run winning marketing campaigns, create stunning content, and automate for growth.
      </p>

      <div class="mt-9 flex flex-col justify-center gap-4 sm:flex-row lg:justify-start">
        <%= link_to new_user_session_path, class: "inline-flex items-center justify-center rounded-xl bg-blue-600 px-7 py-4 text-sm font-extrabold text-white shadow-xl shadow-blue-600/20 hover:bg-blue-700" do %>
          Start Your Project
          <svg class="ms-3 h-4 w-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 18 18">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 9h10m0 0-4-4m4 4-4 4"/>
          </svg>
        <% end %>

        <a href="#" class="inline-flex items-center justify-center rounded-xl border border-blue-200 bg-white px-7 py-4 text-sm font-extrabold text-blue-700 shadow-sm hover:bg-blue-50">
          View Our Services
          <svg class="ms-3 h-4 w-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 18 18">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 9h10m0 0-4-4m4 4-4 4"/>
          </svg>
        </a>
      </div>

      <div class="mt-10 flex flex-col items-center gap-5 sm:flex-row sm:justify-center lg:justify-start">
        <div class="flex -space-x-3">
          <% ["AM", "RS", "TN", "MK", "JL"].each_with_index do |initials, index| %>
            <% colors = ["bg-blue-100 text-blue-700", "bg-slate-200 text-slate-700", "bg-cyan-100 text-cyan-700", "bg-indigo-100 text-indigo-700", "bg-rose-100 text-rose-700"] %>
            <span class="flex h-10 w-10 items-center justify-center rounded-full border-2 border-white text-xs font-black shadow-sm <%= colors[index] %>"><%= initials %></span>
          <% end %>
        </div>

        <div>
          <div class="flex gap-0.5 text-yellow-400">
            <% 5.times do %>
              <svg class="h-4 w-4 fill-current" aria-hidden="true" viewBox="0 0 20 20">
                <path d="m10 1.5 2.6 5.3 5.9.9-4.3 4.2 1 5.9L10 15l-5.2 2.8 1-5.9-4.3-4.2 5.9-.9L10 1.5Z"/>
              </svg>
            <% end %>
          </div>
          <p class="mt-1 text-sm font-semibold leading-5 text-slate-600">Trusted by 200+<br>Businesses Worldwide</p>
        </div>
      </div>
    </div>

    <div class="relative mx-auto w-full max-w-xl lg:-mr-8 lg:max-w-4xl">
      <div class="absolute left-1/2 top-1/2 -z-10 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rounded-full bg-blue-200/40 blur-3xl animate-pulse"></div>
      <div class="absolute right-10 top-12 -z-10 h-32 w-32 rounded-full bg-cyan-200/50 blur-2xl animate-pulse"></div>
      <div class="absolute bottom-16 left-8 -z-10 h-28 w-28 rounded-full bg-purple-200/50 blur-2xl animate-pulse"></div>

      <%= tag.img src: "/images/hero.svg", alt: "M&W Labs digital services", class: "relative z-10 w-full object-contain" %>

      <% [
        [ "Web Development", "fa-code", "left-2 top-14 bg-blue-600 text-white animate-bounce" ],
        [ "Digital Marketing", "fa-chart-line", "right-6 top-10 bg-white text-blue-600 shadow-blue-100 animate-pulse" ],
        [ "Branding", "fa-pen-nib", "right-0 top-1/2 bg-white text-purple-600 shadow-purple-100 animate-bounce" ],
        [ "AI Automation", "fa-robot", "bottom-8 left-1/2 bg-white text-blue-600 shadow-blue-100 animate-pulse" ],
        [ "Growth Strategy", "fa-bullseye", "bottom-20 left-0 bg-white text-emerald-600 shadow-emerald-100 animate-bounce" ]
      ].each do |label, icon, classes| %>
        <div class="pointer-events-none absolute z-20 hidden items-center gap-2 rounded-2xl px-4 py-3 text-xs font-extrabold shadow-xl md:flex <%= classes %>">
          <i class="fa-solid <%= icon %>"></i>
          <span><%= label %></span>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mx-auto mb-12 max-w-[90rem] px-4 sm:px-6 lg:px-10">
    <div class="rounded-2xl border border-slate-200 bg-white px-5 py-8 shadow-sm sm:px-8">
      <p class="text-center text-xs font-black uppercase tracking-[0.3em] text-slate-500">Trusted by businesses of all sizes</p>
      <div class="mt-7 flex flex-wrap items-center justify-center gap-x-7 gap-y-6 sm:gap-x-10 lg:flex-nowrap lg:gap-x-6 xl:gap-x-8">
        <% [
          [ "wave.svg", "Wave" ],
          [ "slack.svg", "Slack" ],
          [ "notion.svg", "Notion" ],
          [ "google.svg", "Google" ],
          [ "monday.svg", "Monday.com" ],
          [ "hubspot.svg", "HubSpot" ],
          [ "shopify.svg", "Shopify" ]
        ].each do |filename, name| %>
          <div class="flex h-16 w-36 shrink-0 items-center justify-center sm:w-40 lg:w-28 xl:w-36">
            <%= tag.img src: "/images/logos/#{filename}", alt: name, class: "max-h-16 w-full object-contain" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<section class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-[90rem] px-4 sm:px-6 lg:px-10">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-extrabold uppercase tracking-[0.25em] text-blue-600">Our Services</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">
        Everything Your Business Needs to <span class="text-blue-600">Grow Digitally</span>
      </h2>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6">
      <% [
        {
          icon: "fa-code",
          color: "bg-blue-600 text-white",
          title: "Web & Software Development",
          body: "Custom websites, web apps, SaaS platforms, dashboards and business systems."
        },
        {
          icon: "fa-bullhorn",
          color: "bg-emerald-50 text-emerald-600",
          title: "Digital Marketing",
          body: "SEO, Google & Meta Ads, lead generation, funnels, email and WhatsApp marketing."
        },
        {
          icon: "fa-pen-nib",
          color: "bg-purple-50 text-purple-600",
          title: "Branding & Design",
          body: "Logo design, brand identity, social media creatives, brochures and more."
        },
        {
          icon: "fa-clapperboard",
          color: "bg-pink-50 text-pink-600",
          title: "Video Editing & Content",
          body: "Reels, YouTube videos, ads, corporate videos, motion graphics and more."
        },
        {
          icon: "fa-robot",
          color: "bg-amber-50 text-amber-600",
          title: "AI & Automation",
          body: "AI chatbots, automation, workflows, dashboards and smart integrations."
        },
        {
          icon: "fa-bullseye",
          color: "bg-cyan-50 text-cyan-600",
          title: "Growth Strategy",
          body: "Business strategy, market research, competitor analysis and scaling plans."
        }
      ].each do |service| %>
        <div class="flex h-full flex-col rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-blue-100 hover:shadow-xl hover:shadow-blue-100/60">
          <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl <%= service[:color] %>">
            <i class="fa-solid <%= service[:icon] %> text-2xl"></i>
          </div>

          <h3 class="text-lg font-black leading-snug text-slate-950"><%= service[:title] %></h3>
          <p class="mt-4 flex-1 text-sm font-medium leading-7 text-slate-600"><%= service[:body] %></p>

          <a href="#" class="mt-6 inline-flex items-center text-sm font-extrabold text-blue-600 hover:text-blue-700">
            Explore
            <i class="fa-solid fa-arrow-right ms-2 text-xs"></i>
          </a>
        </div>
      <% end %>
    </div>
  </div>
</section>
