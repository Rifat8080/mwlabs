<% content_for :title, "Mwlabs" %>

<section class="relative isolate overflow-hidden bg-[radial-gradient(circle_at_top_right,_#eff6ff,_transparent_34rem),linear-gradient(180deg,_#ffffff_0%,_#f8fbff_100%)]">
  <div class="absolute inset-x-0 top-0 -z-10 h-px bg-gradient-to-r from-transparent via-blue-200 to-transparent"></div>
  <div class="absolute left-8 top-28 -z-10 h-80 w-80 rounded-full bg-blue-100/70 blur-3xl"></div>
  <div class="absolute right-0 top-24 -z-10 h-[34rem] w-[34rem] rounded-full bg-cyan-100/60 blur-3xl"></div>

  <div class="mx-auto grid max-w-[104rem] items-center gap-10 px-4 pb-14 pt-8 sm:px-6 sm:pt-10 lg:grid-cols-[0.86fr_1.14fr] lg:gap-20 lg:px-12 lg:pb-24 lg:pt-16 2xl:px-16">
    <div class="text-center lg:text-left">
      <div class="mx-auto inline-flex items-center gap-2 rounded-full border border-blue-100 bg-white px-4 py-2 text-[0.68rem] font-extrabold uppercase tracking-[0.18em] text-blue-700 shadow-sm sm:text-xs lg:mx-0">
        Selected founders get MVP builds + marketing reports
        <span class="flex h-5 w-5 items-center justify-center rounded-full bg-blue-50 text-blue-600">+</span>
      </div>

      <h1 class="mx-auto mt-7 max-w-3xl text-4xl font-black leading-[0.95] tracking-tight text-slate-950 sm:text-6xl lg:mx-0 lg:text-7xl">
        Build. Market.<br>
        Automate. <span class="text-blue-600">Grow.</span>
      </h1>

      <p class="mx-auto mt-7 max-w-xl text-base font-medium leading-8 text-slate-600 sm:text-lg lg:mx-0">
        M&W Labs partners with ambitious founders and businesses through selected MVP builds, complimentary marketing reports, powerful websites, campaigns, content, and automation for growth.
      </p>

      <div class="mt-9 flex flex-col justify-center gap-4 sm:flex-row lg:justify-start">
        <%= link_to contact_path, class: "inline-flex items-center justify-center rounded-xl bg-blue-600 px-7 py-4 text-sm font-extrabold text-white shadow-xl shadow-blue-600/20 hover:bg-blue-700" do %>
          Apply for MVP Partnership
          <svg class="ms-3 h-4 w-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 18 18">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 9h10m0 0-4-4m4 4-4 4"/>
          </svg>
        <% end %>

        <%= link_to contact_path, class: "inline-flex items-center justify-center rounded-xl border border-blue-200 bg-white px-7 py-4 text-sm font-extrabold text-blue-700 shadow-sm hover:bg-blue-50" do %>
          Request Growth Report
          <svg class="ms-3 h-4 w-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 18 18">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 9h10m0 0-4-4m4 4-4 4"/>
          </svg>
        <% end %>
      </div>

      <div class="mt-10 flex flex-col items-center gap-5 sm:flex-row sm:justify-center lg:justify-start">
        <div class="flex -space-x-3">
          <% ["AM", "RS", "TN", "MK", "JL"].each_with_index do |initials, index| %>
            <% colors = ["bg-blue-100 text-blue-700", "bg-slate-200 text-slate-700", "bg-cyan-100 text-cyan-700", "bg-indigo-100 text-indigo-700", "bg-rose-100 text-rose-700"] %>
            <span class="flex h-10 w-10 items-center justify-center rounded-full border-2 border-white text-xs font-black shadow-sm <%= colors[index] %>"><%= initials %></span>
          <% end %>
        </div>

        <div>
          <div class="flex gap-0.5 text-yellow-400">
            <% 5.times do %>
              <svg class="h-4 w-4 fill-current" aria-hidden="true" viewBox="0 0 20 20">
                <path d="m10 1.5 2.6 5.3 5.9.9-4.3 4.2 1 5.9L10 15l-5.2 2.8 1-5.9-4.3-4.2 5.9-.9L10 1.5Z"/>
              </svg>
            <% end %>
          </div>
          <p class="mt-1 text-sm font-semibold leading-5 text-slate-600">Trusted by 200+<br>Businesses Worldwide</p>
        </div>
      </div>

    </div>

    <div class="relative mx-auto min-h-[360px] w-full max-w-2xl overflow-visible sm:min-h-[430px] lg:-mr-8 lg:min-h-[580px] lg:max-w-5xl">
      <div class="absolute left-1/2 top-1/2 h-[76%] w-[90%] -translate-x-1/2 -translate-y-1/2 rounded-[50%] border border-blue-200/80"></div>
      <div class="absolute left-[13%] top-[45%] h-2.5 w-2.5 rounded-full bg-blue-600 shadow-lg shadow-blue-500/40 sm:h-3 sm:w-3"></div>
      <div class="absolute right-[28%] top-[17%] h-2.5 w-2.5 rounded-full bg-blue-600 shadow-lg shadow-blue-500/40 sm:h-3 sm:w-3"></div>
      <div class="absolute bottom-[12%] left-[56%] h-2.5 w-2.5 rounded-full bg-blue-600 shadow-lg shadow-blue-500/40 sm:h-3 sm:w-3"></div>

      <%= tag.img src: "/images/hero.svg", alt: "M&W Labs digital services", class: "absolute left-1/2 top-1/2 z-10 w-[92%] -translate-x-1/2 -translate-y-1/2 object-contain drop-shadow-2xl sm:w-[94%]" %>

      <% [
        [ "Web Development", "fa-code", "left-[8%] top-[12%] sm:left-[14%] sm:top-[11%]", "bg-blue-50 text-blue-600", "hero-float" ],
        [ "Digital Marketing", "fa-chart-line", "right-[4%] top-[10%] sm:right-[7%] sm:top-[6%]", "bg-blue-50 text-blue-600", "hero-float-soft hero-float-delay" ],
        [ "Branding & Design", "fa-pen-nib", "right-[0%] top-[43%] sm:right-[2%]", "bg-indigo-50 text-indigo-600", "hero-float" ],
        [ "Video Editing", "fa-clapperboard", "right-[11%] bottom-[13%] sm:right-[17%] sm:bottom-[11%]", "bg-purple-50 text-purple-600", "hero-float-soft" ],
        [ "AI Automation", "fa-robot", "left-[38%] bottom-[5%] sm:left-[42%] sm:bottom-[4%]", "bg-blue-50 text-blue-600", "hero-float hero-float-delay" ],
        [ "Growth Strategy", "fa-bullseye", "left-[1%] bottom-[24%] sm:left-[3%] sm:bottom-[22%]", "bg-emerald-50 text-emerald-600", "hero-float-soft hero-float-delay" ]
      ].each do |label, icon, position, color, animation| %>
        <div class="pointer-events-none absolute z-20 flex items-center gap-1.5 rounded-xl border border-slate-100 bg-white/95 px-2 py-1.5 text-[0.52rem] font-extrabold text-slate-800 shadow-xl shadow-slate-200/80 backdrop-blur transition-transform duration-300 sm:gap-2 sm:rounded-2xl sm:px-3 sm:py-2 sm:text-[0.65rem] md:gap-3 md:px-4 md:py-3 md:text-xs <%= position %> <%= animation %>">
          <span class="flex h-6 w-6 items-center justify-center rounded-lg text-[0.65rem] sm:h-7 sm:w-7 sm:rounded-xl md:h-9 md:w-9 md:text-base <%= color %>">
            <i class="fa-solid <%= icon %>"></i>
          </span>
          <span><%= label %></span>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mx-auto mb-12 max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
    <div class="rounded-2xl border border-slate-200 bg-white px-5 py-8 shadow-sm sm:px-8">
      <p class="text-center text-xs font-black uppercase tracking-[0.3em] text-slate-500">Trusted by businesses of all sizes</p>
      <div class="mt-7 flex flex-wrap items-center justify-center gap-x-7 gap-y-6 sm:gap-x-10 lg:flex-nowrap lg:gap-x-6 xl:gap-x-8">
        <% [
          [ "wave.svg", "Wave" ],
          [ "slack.svg", "Slack" ],
          [ "notion.svg", "Notion" ],
          [ "google.svg", "Google" ],
          [ "monday.svg", "Monday.com" ],
          [ "hubspot.svg", "HubSpot" ],
          [ "shopify.svg", "Shopify" ],
          [ "techtotherescue.svg", "Tech To The Rescue" ]
        ].each do |filename, name| %>
          <div class="flex h-20 w-40 shrink-0 items-center justify-center sm:w-44 lg:w-32 xl:w-40">
            <%= tag.img src: "/images/logos/#{filename}", alt: name, class: "max-h-20 w-full object-contain" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<section class="bg-white py-12">
  <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
    <div class="grid gap-5 rounded-2xl border border-blue-100 bg-[radial-gradient(circle_at_top_right,_#eff6ff,_transparent_28rem),#ffffff] p-6 shadow-sm lg:grid-cols-[1fr_auto] lg:items-center lg:p-8">
      <div>
        <p class="text-sm font-extrabold uppercase tracking-[0.25em] text-blue-600">Founder Growth Offer</p>
        <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">
          Validate faster with a strategic launch advantage.
        </h2>
        <p class="mt-4 max-w-3xl text-sm font-semibold leading-8 text-slate-600">
          For selected ideas, we contribute MVP builds and complimentary marketing reports so founders can validate demand, clarify positioning, and see the highest-impact growth steps with expert guidance.
        </p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
        <%= link_to contact_path, class: "inline-flex items-center justify-center rounded-xl bg-blue-600 px-7 py-4 text-sm font-extrabold text-white shadow-xl shadow-blue-600/20 transition hover:-translate-y-0.5 hover:bg-blue-700" do %>
          Apply for MVP Partnership
          <i class="fa-solid fa-rocket ms-3 text-xs"></i>
        <% end %>
        <%= link_to contact_path, class: "inline-flex items-center justify-center rounded-xl border border-blue-200 bg-white px-7 py-4 text-sm font-extrabold text-blue-700 shadow-sm transition hover:-translate-y-0.5 hover:bg-blue-50" do %>
          Request Growth Report
          <i class="fa-solid fa-chart-line ms-3 text-xs"></i>
        <% end %>
      </div>
    </div>
  </div>
</section>

<section id="services" class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-extrabold uppercase tracking-[0.25em] text-blue-600">Our Services</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">
        Everything Your Business Needs to <span class="text-blue-600">Grow Digitally</span>
      </h2>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6">
      <% [
        {
          icon: "fa-code",
          color: "bg-blue-600 text-white",
          title: "Web & Software Development",
          body: "Custom websites, web apps, SaaS platforms, dashboards and business systems.",
          slug: "web-development"
        },
        {
          icon: "fa-bullhorn",
          color: "bg-emerald-50 text-emerald-600",
          title: "Digital Marketing",
          body: "SEO, Google & Meta Ads, lead generation, funnels, email and WhatsApp marketing.",
          slug: "digital-marketing"
        },
        {
          icon: "fa-pen-nib",
          color: "bg-purple-50 text-purple-600",
          title: "Branding & Design",
          body: "Logo design, brand identity, social media creatives, brochures and more.",
          slug: "branding-design"
        },
        {
          icon: "fa-clapperboard",
          color: "bg-pink-50 text-pink-600",
          title: "Video Editing & Content",
          body: "Reels, YouTube videos, ads, corporate videos, motion graphics and more.",
          slug: "video-editing"
        },
        {
          icon: "fa-robot",
          color: "bg-amber-50 text-amber-600",
          title: "AI & Automation",
          body: "AI chatbots, automation, workflows, dashboards and smart integrations.",
          slug: "ai-automation"
        },
        {
          icon: "fa-bullseye",
          color: "bg-cyan-50 text-cyan-600",
          title: "Growth Strategy",
          body: "Business strategy, market research, competitor analysis and scaling plans.",
          slug: "growth-strategy"
        }
      ].each do |service| %>
        <div class="flex h-full flex-col rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-blue-100 hover:shadow-xl hover:shadow-blue-100/60">
          <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl <%= service[:color] %>">
            <i class="fa-solid <%= service[:icon] %> text-2xl"></i>
          </div>

          <h3 class="text-lg font-black leading-snug text-slate-950"><%= service[:title] %></h3>
          <p class="mt-4 flex-1 text-sm font-medium leading-7 text-slate-600"><%= service[:body] %></p>

          <div class="mt-6 space-y-3">
            <%= link_to service_path(service[:slug]), class: "inline-flex items-center text-sm font-extrabold text-blue-600 hover:text-blue-700" do %>
              Explore
              <i class="fa-solid fa-arrow-right ms-2 text-xs"></i>
            <% end %>
            <%= link_to contact_path, class: "inline-flex w-full items-center justify-center rounded-xl border border-blue-100 bg-blue-50 px-4 py-3 text-xs font-extrabold text-blue-700 transition hover:-translate-y-0.5 hover:bg-blue-100" do %>
              Get a Quote
              <i class="fa-solid fa-paper-plane ms-2 text-[0.65rem]"></i>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-10 text-center">
      <%= link_to contact_path, class: "inline-flex items-center justify-center rounded-xl bg-blue-600 px-7 py-4 text-sm font-extrabold text-white shadow-xl shadow-blue-600/20 transition hover:-translate-y-0.5 hover:bg-blue-700" do %>
        Not Sure What You Need? Talk to Us
        <i class="fa-solid fa-comments ms-3 text-xs"></i>
      <% end %>
    </div>
  </div>
</section>

<section class="bg-white py-16 sm:py-20">
  <div class="mx-auto grid max-w-[104rem] gap-10 px-4 sm:px-6 lg:grid-cols-[0.75fr_1.25fr] lg:items-center lg:px-12 2xl:px-16">
    <div>
      <p class="text-sm font-extrabold uppercase tracking-[0.25em] text-blue-600">Why Choose M&W Labs?</p>
      <h2 class="mt-4 max-w-2xl text-3xl font-black leading-tight tracking-tight text-slate-950 sm:text-4xl">
        We Don’t Just Deliver Services,<br>
        We Build <span class="text-blue-600">Growth Systems.</span>
      </h2>

      <div class="mt-7 space-y-4">
        <% [
          "Result-driven strategies that bring real business growth",
          "Creative, modern & conversion-focused solutions",
          "Transparent communication & on-time delivery",
          "Dedicated team that cares about your success"
        ].each do |point| %>
          <div class="flex items-start gap-3 text-sm font-bold text-slate-600">
            <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-blue-600 text-xs text-white">
              <i class="fa-solid fa-check"></i>
            </span>
            <span><%= point %></span>
          </div>
        <% end %>
      </div>

      <div class="mt-8 flex flex-col gap-4 sm:flex-row">
        <%= link_to about_path, class: "inline-flex items-center justify-center rounded-xl bg-blue-600 px-7 py-4 text-sm font-extrabold text-white shadow-xl shadow-blue-600/20 hover:bg-blue-700" do %>
          Learn More About Us
          <i class="fa-solid fa-arrow-right ms-3 text-xs"></i>
        <% end %>
        <%= link_to contact_path, class: "inline-flex items-center justify-center rounded-xl border border-blue-200 bg-white px-7 py-4 text-sm font-extrabold text-blue-700 shadow-sm hover:bg-blue-50" do %>
          Get Growth Advice
          <i class="fa-solid fa-lightbulb ms-3 text-xs"></i>
        <% end %>
      </div>
    </div>

    <div class="space-y-6">
      <div class="grid gap-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:grid-cols-2 xl:grid-cols-4">
        <% [
          [ "fa-users", "500+", "Projects Completed", "bg-blue-50 text-blue-600" ],
          [ "fa-face-smile", "300+", "Happy Clients", "bg-indigo-50 text-indigo-600" ],
          [ "fa-trophy", "5+", "Years of Experience", "bg-emerald-50 text-emerald-600" ],
          [ "fa-globe", "20+", "Countries Served", "bg-blue-50 text-blue-600" ]
        ].each do |icon, value, label, color| %>
          <div class="flex items-center gap-4 rounded-xl bg-white p-3">
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl <%= color %>">
              <i class="fa-solid <%= icon %> text-xl"></i>
            </span>
            <div>
              <p class="text-3xl font-black tracking-tight text-slate-950"><%= value %></p>
              <p class="text-xs font-bold text-slate-500"><%= label %></p>
            </div>
          </div>
        <% end %>
      </div>

      <div class="grid overflow-hidden rounded-2xl border border-slate-200 bg-slate-50 shadow-sm md:grid-cols-[0.42fr_0.58fr]">
        <div class="flex items-end justify-center bg-gradient-to-br from-blue-50 to-white p-6">
          <div class="flex h-56 w-44 items-end justify-center rounded-t-full bg-gradient-to-b from-slate-200 to-slate-100">
            <div class="mb-6 flex h-36 w-28 flex-col items-center justify-center rounded-full bg-white shadow-xl">
              <span class="flex h-20 w-20 items-center justify-center rounded-full bg-slate-800 text-3xl text-white">
                <i class="fa-solid fa-user-tie"></i>
              </span>
              <span class="mt-3 h-4 w-20 rounded-full bg-blue-600"></span>
            </div>
          </div>
        </div>

        <div class="flex flex-col justify-center p-7 sm:p-10">
          <i class="fa-solid fa-quote-left text-3xl text-blue-200"></i>
          <blockquote class="mt-4 text-lg font-bold leading-8 text-slate-700">
            M&W Labs transformed our online presence completely. Their team is professional, creative, and delivers outstanding results!
          </blockquote>

          <div class="mt-7">
            <p class="font-black text-slate-950">David Smith</p>
            <p class="text-sm font-semibold text-slate-500">CEO, TechFlow</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="bg-white py-16 sm:py-20" data-project-section>
  <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-sm font-extrabold uppercase tracking-[0.25em] text-blue-600">Our Work</p>
        <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">
          Some Recent <span class="text-blue-600">Projects</span>
        </h2>
      </div>

      <div class="flex flex-wrap gap-2" data-project-filters>
        <% [ "All", "Web Development", "Marketing", "Branding", "Video" ].each_with_index do |filter, index| %>
          <button type="button" class="rounded-lg border px-5 py-2.5 text-xs font-extrabold transition <%= index.zero? ? "border-blue-600 bg-blue-600 text-white shadow-lg shadow-blue-600/20" : "border-slate-200 bg-white text-slate-700 hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700" %>" data-project-filter="<%= filter %>" aria-pressed="<%= index.zero? %>">
            <%= filter %>
          </button>
        <% end %>
      </div>
    </div>

    <div class="mt-9 grid gap-5 sm:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-6" data-project-grid>
      <% [
        {
          title: "Fintech Website Development",
          category: "Web Development",
          icon: "fa-chart-pie",
          accent: "from-blue-500 to-cyan-400",
          panel: "bg-blue-50"
        },
        {
          title: "Lead Generation Campaign",
          category: "Marketing",
          icon: "fa-bullseye",
          accent: "from-emerald-500 to-teal-400",
          panel: "bg-emerald-50"
        },
        {
          title: "Coffee Brand Identity",
          category: "Branding",
          icon: "fa-mug-hot",
          accent: "from-slate-900 to-amber-700",
          panel: "bg-stone-100"
        },
        {
          title: "YouTube Channel Editing",
          category: "Video",
          icon: "fa-play",
          accent: "from-violet-600 to-fuchsia-500",
          panel: "bg-violet-50"
        },
        {
          title: "SaaS Dashboard Development",
          category: "Web Development",
          icon: "fa-table-columns",
          accent: "from-blue-600 to-indigo-500",
          panel: "bg-blue-50"
        },
        {
          title: "Instagram Ad Campaign",
          category: "Marketing",
          icon: "fa-mobile-screen-button",
          accent: "from-rose-400 to-orange-300",
          panel: "bg-rose-50"
        }
      ].each do |project| %>
        <article class="group overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition duration-300 hover:-translate-y-2 hover:border-blue-100 hover:shadow-2xl hover:shadow-blue-100/70" data-project-card data-project-category="<%= project[:category] %>">
          <div class="relative h-40 overflow-hidden <%= project[:panel] %>">
            <div class="absolute inset-x-0 top-0 h-2 bg-gradient-to-r <%= project[:accent] %>"></div>
            <div class="absolute inset-4 rounded-xl bg-white/80 shadow-xl shadow-slate-200/70 ring-1 ring-white/80 transition duration-300 group-hover:scale-105">
              <div class="flex items-center gap-1 border-b border-slate-100 px-3 py-2">
                <span class="h-2 w-2 rounded-full bg-rose-400"></span>
                <span class="h-2 w-2 rounded-full bg-amber-400"></span>
                <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
              </div>
              <div class="grid h-[calc(100%-2rem)] grid-cols-[0.42fr_0.58fr] gap-3 p-3">
                <div class="space-y-2">
                  <span class="block h-3 rounded-full bg-slate-200"></span>
                  <span class="block h-3 w-3/4 rounded-full bg-slate-100"></span>
                  <span class="block h-16 rounded-lg bg-gradient-to-br <%= project[:accent] %>"></span>
                </div>
                <div class="space-y-2">
                  <div class="flex h-16 items-center justify-center rounded-lg bg-slate-50 text-blue-600">
                    <i class="fa-solid <%= project[:icon] %> text-3xl"></i>
                  </div>
                  <span class="block h-3 rounded-full bg-slate-200"></span>
                  <span class="block h-3 w-2/3 rounded-full bg-slate-100"></span>
                </div>
              </div>
            </div>
          </div>

          <div class="p-5">
            <h3 class="text-base font-black leading-snug text-slate-950"><%= project[:title] %></h3>
            <p class="mt-2 text-sm font-bold text-slate-500"><%= project[:category] %></p>
          </div>
        </article>
      <% end %>
    </div>

    <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <%= link_to work_path, class: "inline-flex items-center justify-center rounded-lg border border-blue-200 bg-white px-8 py-3 text-sm font-extrabold text-blue-700 shadow-sm transition hover:-translate-y-0.5 hover:bg-blue-50 hover:shadow-lg hover:shadow-blue-100" do %>
        View All Projects
        <i class="fa-solid fa-arrow-right ms-3 text-xs"></i>
      <% end %>
      <%= link_to contact_path, class: "inline-flex items-center justify-center rounded-lg bg-blue-600 px-8 py-3 text-sm font-extrabold text-white shadow-xl shadow-blue-600/20 transition hover:-translate-y-0.5 hover:bg-blue-700" do %>
        Build Something Similar
        <i class="fa-solid fa-rocket ms-3 text-xs"></i>
      <% end %>
    </div>
  </div>
</section>

<section class="overflow-hidden bg-white pb-16 sm:pb-20">
  <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
    <div>
      <p class="text-sm font-extrabold uppercase tracking-[0.25em] text-blue-600">Our Process</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">How We Work</h2>
    </div>

    <div class="relative mt-10 grid gap-7 md:grid-cols-2 lg:grid-cols-5 lg:gap-0">
      <% [
        [ "01", "Discover", "We understand your goals, audience and requirements.", "fa-magnifying-glass-chart" ],
        [ "02", "Plan", "We create a strategic plan tailored to your business.", "fa-clipboard-list" ],
        [ "03", "Build", "Our experts design, develop and create with precision.", "fa-code" ],
        [ "04", "Launch", "We test everything and launch for maximum impact.", "fa-rocket" ],
        [ "05", "Grow", "We analyze, optimize and scale your business growth.", "fa-chart-line" ]
      ].each_with_index do |step, index| %>
        <% number, title, body, icon = step %>
        <div class="group relative rounded-2xl bg-white p-4 transition duration-300 hover:-translate-y-1 sm:p-5 lg:overflow-visible lg:rounded-none lg:p-0 lg:pr-8">
          <% unless index == 4 %>
            <svg class="pointer-events-none absolute left-[4.8rem] top-7 z-0 hidden h-14 w-[calc(100%-1.5rem)] text-blue-100 lg:block" aria-hidden="true" viewBox="0 0 190 56" fill="none" preserveAspectRatio="none">
              <path d="M4 30 C52 2 105 2 156 30" stroke="currentColor" stroke-width="2" stroke-dasharray="5 7"/>
            </svg>
            <span class="absolute right-4 top-[2.25rem] z-20 hidden text-blue-600 lg:block">
              <i class="fa-solid fa-arrow-right text-xs"></i>
            </span>
          <% end %>

          <div class="relative z-10 flex items-start gap-4">
            <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full border border-blue-100 bg-white text-blue-600 shadow-[0_18px_45px_rgba(37,99,235,0.12)] ring-8 ring-blue-50/70 transition duration-300 group-hover:scale-110 group-hover:bg-blue-600 group-hover:text-white">
              <i class="fa-solid <%= icon %> text-2xl"></i>
            </div>

            <div class="pt-1">
              <div class="flex items-center gap-3">
                <p class="text-sm font-black text-blue-600"><%= number %></p>
                <h3 class="text-base font-black text-slate-950"><%= title %></h3>
              </div>
              <p class="mt-4 max-w-[13rem] text-sm font-semibold leading-7 text-slate-600 lg:max-w-[10.5rem]"><%= body %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-10 text-center">
      <%= link_to contact_path, class: "inline-flex items-center justify-center rounded-xl border border-blue-200 bg-white px-7 py-4 text-sm font-extrabold text-blue-700 shadow-sm transition hover:-translate-y-0.5 hover:bg-blue-50 hover:shadow-lg hover:shadow-blue-100" do %>
        Start With a Discovery Call
        <i class="fa-solid fa-calendar-check ms-3 text-xs"></i>
      <% end %>
    </div>
  </div>
</section>

<section class="bg-white pb-16 sm:pb-20" data-testimonials-section>
  <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
    <div>
      <p class="text-sm font-extrabold uppercase tracking-[0.25em] text-blue-600">What Clients Say</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">
        Real People. Real <span class="text-blue-600">Results.</span>
      </h2>
    </div>

    <div class="relative mt-9">
      <button type="button" class="absolute -left-3 top-1/2 z-20 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-blue-100 bg-white text-blue-600 shadow-xl shadow-blue-100 transition hover:bg-blue-600 hover:text-white sm:-left-5" data-testimonials-prev aria-label="Previous testimonial">
        <i class="fa-solid fa-chevron-left text-sm"></i>
      </button>

      <div class="overflow-hidden px-1">
        <div class="flex snap-x snap-mandatory gap-5 overflow-x-auto scroll-smooth pb-2 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" data-testimonials-track>
          <% [
            {
              quote: "The team at M&W Labs is exceptional. They built our website, ran amazing ads and the results exceeded our expectations.",
              name: "Jessica Brown",
              role: "Marketing Manager, Brandco",
              initials: "JB",
              color: "from-rose-400 to-pink-500"
            },
            {
              quote: "Highly professional and creative team. They understand our needs and deliver solutions that actually grow our business.",
              name: "Michael Lee",
              role: "Founder, Shopwise",
              initials: "ML",
              color: "from-blue-500 to-cyan-400"
            },
            {
              quote: "From branding to video editing, everything was top quality. Communication was smooth and timely.",
              name: "Sarah Johnson",
              role: "CEO, Skyhigh",
              initials: "SJ",
              color: "from-purple-500 to-indigo-500"
            }
          ].each do |testimonial| %>
            <article class="min-w-full snap-start rounded-2xl border border-slate-200 bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:border-blue-100 hover:shadow-xl hover:shadow-blue-100/70 sm:min-w-[calc(50%-0.625rem)] lg:min-w-[calc(33.333%-0.875rem)]">
              <i class="fa-solid fa-quote-left text-3xl text-blue-100"></i>
              <blockquote class="mt-2 min-h-24 text-sm font-semibold leading-7 text-slate-600">
                <%= testimonial[:quote] %>
              </blockquote>

              <div class="mt-6 flex items-center gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-gradient-to-br text-sm font-black text-white shadow-lg <%= testimonial[:color] %>">
                  <%= testimonial[:initials] %>
                </div>
                <div>
                  <p class="font-black text-slate-950"><%= testimonial[:name] %></p>
                  <p class="mt-1 text-xs font-bold text-slate-500"><%= testimonial[:role] %></p>
                </div>
              </div>
            </article>
          <% end %>
        </div>
      </div>

      <button type="button" class="absolute -right-3 top-1/2 z-20 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-blue-100 bg-white text-blue-600 shadow-xl shadow-blue-100 transition hover:bg-blue-600 hover:text-white sm:-right-5" data-testimonials-next aria-label="Next testimonial">
        <i class="fa-solid fa-chevron-right text-sm"></i>
      </button>
    </div>

    <div class="mt-4 flex justify-center gap-2" data-testimonials-dots>
      <% 3.times do |index| %>
        <button type="button" class="h-3 w-3 rounded-full transition <%= index.zero? ? "bg-blue-600" : "bg-blue-100" %>" data-testimonials-dot="<%= index %>" aria-label="Show testimonial <%= index + 1 %>" aria-pressed="<%= index.zero? %>"></button>
      <% end %>
    </div>

    <div class="mt-8 text-center">
      <%= link_to contact_path, class: "inline-flex items-center justify-center rounded-xl border border-blue-200 bg-white px-7 py-4 text-sm font-extrabold text-blue-700 shadow-sm transition hover:-translate-y-0.5 hover:bg-blue-50 hover:shadow-lg hover:shadow-blue-100" do %>
        Get Results Like These
        <i class="fa-solid fa-arrow-trend-up ms-3 text-xs"></i>
      <% end %>
    </div>

    <div class="relative mt-8 overflow-hidden rounded-2xl bg-gradient-to-r from-indigo-600 via-blue-600 to-cyan-500 px-6 py-9 text-white shadow-2xl shadow-blue-600/20 sm:px-10 lg:px-16">
      <div class="absolute left-0 top-0 h-full w-40 opacity-20 [background-image:radial-gradient(circle,_white_1px,_transparent_1px)] [background-size:12px_12px]"></div>
      <div class="absolute right-8 top-1/2 hidden -translate-y-1/2 text-white/90 lg:block">
        <i class="fa-solid fa-paper-plane text-8xl drop-shadow-2xl"></i>
      </div>

      <div class="relative z-10 grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center lg:pr-40">
        <div>
          <p class="text-sm font-extrabold text-blue-100">Ready to Grow Your Business?</p>
          <h3 class="mt-3 text-3xl font-black tracking-tight sm:text-4xl">Let's Build Something Amazing Together!</h3>
          <p class="mt-4 max-w-2xl text-base font-semibold leading-8 text-blue-50">Book a free strategy call and let's discuss how we can help you grow.</p>
        </div>

        <div class="flex flex-col gap-4 sm:flex-row">
          <%= link_to contact_path, class: "inline-flex items-center justify-center rounded-xl bg-white px-7 py-4 text-sm font-extrabold text-blue-700 shadow-xl shadow-blue-950/10 transition hover:-translate-y-0.5 hover:bg-blue-50" do %>
            Book a Free Call
            <i class="fa-solid fa-phone ms-3 text-xs"></i>
          <% end %>
          <%= link_to contact_path, class: "inline-flex items-center justify-center rounded-xl border border-white/30 bg-white/10 px-7 py-4 text-sm font-extrabold text-white shadow-sm backdrop-blur transition hover:-translate-y-0.5 hover:bg-white/20" do %>
            Request a Quote
            <i class="fa-solid fa-arrow-right ms-3 text-xs"></i>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

