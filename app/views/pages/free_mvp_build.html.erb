<% content_for :title, "Free MVP Build for Selected Founders | M&W Labs" %>
<% content_for :meta_description, "Apply for the M&W Labs free MVP build program. Selected founders get strategy, design, and development support to launch a working MVP and validate their idea faster." %>
<% content_for :structured_data do %>
  <%= jsonld_tag service_jsonld(
    name: "Free MVP Build Program",
    description: "A founder program where M&W Labs contributes strategy, design, and development to build a working MVP for selected ideas each quarter, free of charge.",
    url: free_mvp_build_url,
    free: true) %>
<% end %>

<section class="relative isolate overflow-hidden border-b border-slate-100 bg-[radial-gradient(circle_at_top_right,_#eff6ff,_transparent_28rem),linear-gradient(180deg,_#ffffff_0%,_#f8fbff_100%)] py-14 sm:py-16">
  <div class="aurora-blob absolute left-8 top-20 -z-10 h-72 w-72 rounded-full bg-blue-100/70 blur-3xl"></div>
  <div class="aurora-blob-slow absolute right-0 top-10 -z-10 h-80 w-80 rounded-full bg-cyan-100/60 blur-3xl"></div>

  <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
    <div class="inline-flex items-center gap-2 rounded-full border border-blue-100/80 bg-white/90 px-4 py-2 text-[0.68rem] font-extrabold uppercase tracking-[0.18em] text-blue-700 shadow-[0_18px_45px_rgba(37,99,235,0.10)] backdrop-blur sm:text-xs">
      <span class="relative flex h-5 w-5 items-center justify-center rounded-full bg-blue-600 text-[0.58rem] text-white shadow-lg shadow-blue-500/25">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-blue-400 opacity-40"></span>
        +
      </span>
      Founder Program &middot; Limited Spots
    </div>

    <h1 class="mt-6 max-w-4xl text-3xl font-black tracking-tight text-slate-950 sm:text-5xl">
      Free MVP Build for <span class="bg-gradient-to-r from-blue-600 to-cyan-500 bg-clip-text text-transparent">Selected Founders</span>
    </h1>
    <p class="mt-5 max-w-3xl text-base font-semibold leading-8 text-slate-600 sm:text-lg">
      Have a strong idea but no product yet? Each quarter, M&W Labs selects a limited number of founders and contributes strategy, design, and development to build a working MVP — so you can validate demand and pitch with something real.
    </p>

    <div class="mt-8 flex flex-col gap-4 sm:flex-row">
      <a href="#apply" class="btn-shine inline-flex items-center justify-center rounded-xl bg-blue-600 px-7 py-4 text-sm font-extrabold text-white shadow-xl shadow-blue-600/20 transition hover:-translate-y-0.5 hover:bg-blue-700">
        Apply for the Program
        <i class="fa-solid fa-rocket ms-3 text-xs"></i>
      </a>
      <a href="#how-it-works" class="inline-flex items-center justify-center rounded-xl border border-blue-200 bg-white px-7 py-4 text-sm font-extrabold text-blue-700 shadow-sm transition hover:-translate-y-0.5 hover:bg-blue-50">
        How It Works
        <i class="fa-solid fa-arrow-down ms-3 text-xs"></i>
      </a>
    </div>
  </div>
</section>

<section class="bg-white py-14 sm:py-16">
  <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <p class="text-sm font-extrabold uppercase tracking-[0.25em] text-blue-600">What You Get</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">
        Everything you need to <span class="bg-gradient-to-r from-blue-600 to-cyan-500 bg-clip-text text-transparent">launch and validate</span>
      </h2>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      <% [
        [ "fa-compass", "bg-blue-50 text-blue-600", "Product Strategy", "A focused strategy session to sharpen your idea, define the core problem, and scope the smallest product worth launching." ],
        [ "fa-pen-ruler", "bg-indigo-50 text-indigo-600", "MVP Design", "Clean, conversion-focused UI and UX for the screens and flows your first users will actually touch." ],
        [ "fa-code", "bg-cyan-50 text-cyan-600", "Working Build", "A functional MVP developed by our engineering team — real software your early users can sign up for and use." ],
        [ "fa-chart-line", "bg-emerald-50 text-emerald-600", "Launch Guidance", "Positioning, launch checklist, and early growth recommendations so the MVP reaches real users, not just a demo link." ]
      ].each_with_index do |(icon, color, title, body), index| %>
        <div class="h-full" data-reveal data-reveal-delay="<%= index * 80 %>">
          <div class="tilt-3d relative flex h-full flex-col rounded-xl border border-slate-200 bg-white p-6 shadow-sm hover:border-blue-200 hover:shadow-2xl hover:shadow-blue-100/70" data-tilt>
            <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl <%= color %>">
              <i class="fa-solid <%= icon %> text-xl"></i>
            </div>
            <h3 class="text-lg font-black leading-snug text-slate-950"><%= title %></h3>
            <p class="mt-3 flex-1 text-sm font-medium leading-7 text-slate-600"><%= body %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<section class="bg-slate-50 py-14 sm:py-16">
  <div class="mx-auto grid max-w-[104rem] gap-10 px-4 sm:px-6 lg:grid-cols-2 lg:items-start lg:px-12 2xl:px-16">
    <div data-reveal="left">
      <p class="text-sm font-extrabold uppercase tracking-[0.25em] text-blue-600">Who It's For</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">Built for founders ready to move</h2>
      <div class="mt-7 space-y-4">
        <% [
          "Founders with a clear problem and a specific audience in mind",
          "Ideas that can prove value with a focused first version",
          "Teams committed to launching and talking to real users",
          "Founders open to a long-term build-and-grow partnership"
        ].each_with_index do |point, index| %>
          <div class="flex items-start gap-3 text-sm font-bold text-slate-600" data-reveal data-reveal-delay="<%= index * 90 %>">
            <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-blue-600 text-xs text-white shadow-lg shadow-blue-600/25">
              <i class="fa-solid fa-check"></i>
            </span>
            <span><%= point %></span>
          </div>
        <% end %>
      </div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-7 shadow-sm sm:p-8" data-reveal="right">
      <h3 class="text-xl font-black text-slate-950">Why we do this</h3>
      <p class="mt-4 text-sm font-semibold leading-8 text-slate-600">
        The best long-term clients start as founders with a great idea and no product. By contributing the first build for selected ideas, we help you validate faster — and when your MVP finds traction, we're already the team that knows your product best.
      </p>
      <p class="mt-4 text-sm font-semibold leading-8 text-slate-600">
        Selection is limited each quarter so every accepted founder gets senior attention. If your idea isn't selected, we'll still reply with honest feedback and a clear path forward.
      </p>
    </div>
  </div>
</section>

<section id="how-it-works" class="bg-white py-14 sm:py-16">
  <div class="mx-auto max-w-[104rem] px-4 sm:px-6 lg:px-12 2xl:px-16">
    <div data-reveal>
      <p class="text-sm font-extrabold uppercase tracking-[0.25em] text-blue-600">How It Works</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">From application to launch</h2>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <% [
        [ "01", "Apply", "Tell us about your idea, audience, and goals using the application form below.", "fa-file-pen" ],
        [ "02", "Review Call", "If shortlisted, we book a call to dig into the problem, market, and scope together.", "fa-phone" ],
        [ "03", "Build", "Our team designs and develops your MVP with weekly check-ins and full transparency.", "fa-code" ],
        [ "04", "Launch & Validate", "We hand over a working product plus launch guidance so you can reach real users fast.", "fa-rocket" ]
      ].each_with_index do |(number, title, body, icon), index| %>
        <div class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-blue-100 hover:shadow-xl hover:shadow-blue-100/60" data-reveal data-reveal-delay="<%= index * 100 %>">
          <div class="flex items-center gap-4">
            <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full border border-blue-100 bg-white text-blue-600 shadow-[0_18px_45px_rgba(37,99,235,0.12)] ring-8 ring-blue-50/70 transition duration-300 group-hover:bg-blue-600 group-hover:text-white">
              <i class="fa-solid <%= icon %> text-xl"></i>
            </div>
            <p class="text-sm font-black text-blue-600"><%= number %></p>
          </div>
          <h3 class="mt-5 text-base font-black text-slate-950"><%= title %></h3>
          <p class="mt-3 text-sm font-semibold leading-7 text-slate-600"><%= body %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<section id="apply" class="relative isolate overflow-hidden bg-white py-14 sm:py-20">
  <div class="aurora-blob absolute left-0 top-24 -z-10 h-72 w-72 rounded-full bg-blue-100/60 blur-3xl"></div>
  <div class="aurora-blob-slow absolute bottom-10 right-0 -z-10 h-80 w-80 rounded-full bg-cyan-100/50 blur-3xl"></div>

  <div class="mx-auto grid max-w-[104rem] gap-10 px-4 sm:px-6 lg:grid-cols-[0.82fr_1.18fr] lg:items-center lg:px-12 2xl:px-16">
    <div data-reveal="left">
      <p class="text-sm font-extrabold uppercase tracking-[0.25em] text-blue-600">Apply Now</p>
      <h2 class="mt-4 max-w-2xl text-3xl font-black leading-tight tracking-tight text-slate-950 sm:text-5xl">
        Tell us about the product you want to launch.
      </h2>
      <p class="mt-5 max-w-2xl text-sm font-semibold leading-8 text-slate-600 sm:text-base">
        Share your idea, the problem it solves, and who it's for. Applications are reviewed by our senior team, and every founder gets a reply — selected or not.
      </p>
    </div>

    <div data-reveal="right">
      <%= render "pages/shared/lead_form",
        lead: Lead.new(source: "Landing Page", service_interest: "Free MVP Build"),
        source: "Landing Page",
        compact: true,
        title: "Apply for a free MVP build",
        description: "Describe your idea, target users, timeline, and what a successful first version looks like. The more context you share, the faster we can review.",
        button_label: "Submit Application" %>
    </div>
  </div>
</section>

<%= render "pages/shared/cta" %>
