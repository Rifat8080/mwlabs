<% content_for :title, "Case Studies | Mwlabs" %>
<% content_for :meta_description, "See M&W Labs case studies showing how clients improved conversions, generated qualified leads, launched ecommerce platforms, and scaled operations." %>

<%= render "pages/shared/hero",
  eyebrow: "Case Studies",
  title: "Success Stories from Real Clients",
  description: "See how we've helped businesses improve conversions, generate leads and scale operations." %>

<section class="bg-white py-14 sm:py-16">
  <div class="mx-auto grid max-w-[104rem] gap-6 px-4 sm:px-6 lg:grid-cols-3 lg:px-12 2xl:px-16">
    <% [
      [ "Brandco", "312% increase in qualified leads after a full funnel rebuild.", "Digital Marketing" ],
      [ "Shopwise", "New ecommerce platform launched in 8 weeks with 2.4x conversion rate.", "Web Development" ],
      [ "Skyhigh", "Brand refresh and content system that doubled social engagement.", "Branding & Design" ]
    ].each do |client, result, category| %>
      <article class="rounded-2xl border border-slate-200 bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:border-blue-100 hover:shadow-xl hover:shadow-blue-100/70">
        <p class="text-xs font-extrabold uppercase tracking-[0.2em] text-blue-600"><%= category %></p>
        <h2 class="mt-3 text-xl font-black text-slate-950"><%= client %></h2>
        <p class="mt-4 text-sm font-semibold leading-7 text-slate-600"><%= result %></p>
      </article>
    <% end %>
  </div>
</section>

<%= render "pages/shared/cta" %>
