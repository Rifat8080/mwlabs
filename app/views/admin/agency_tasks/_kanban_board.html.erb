<div class="flex gap-4 overflow-x-auto pb-4" data-controller="kanban-board">
  <% AgencyTask::STATUSES.each do |status| %>
    <div class="flex w-72 shrink-0 flex-col rounded-2xl border border-slate-200 bg-slate-50/70">
      <div class="flex items-center justify-between rounded-t-2xl border-b border-slate-200 bg-white px-4 py-3">
        <h3 class="text-sm font-black text-slate-950"><%= status.titleize %></h3>
        <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-black text-slate-600"><%= tasks_by_status[status].size %></span>
      </div>

      <div class="flex-1 space-y-3 p-3" data-kanban-board-target="column" data-status="<%= status %>" data-action="dragover->kanban-board#allowDrop dragleave->kanban-board#dragLeave drop->kanban-board#drop" data-table-filter-target="row" data-search-text="" style="min-height: 6rem;">
        <% tasks_by_status[status].each do |task| %>
          <div class="tilt-3d group cursor-grab rounded-xl border border-slate-200 bg-white p-3 shadow-sm transition hover:border-blue-200 hover:shadow-lg active:cursor-grabbing"
            draggable="true"
            data-agency-task-id="<%= task.id %>"
            data-action="dragstart->kanban-board#dragStart dragend->kanban-board#dragEnd"
            data-table-filter-target="row"
            data-search-text="<%= [ task.title, task.description, task.tags ].compact.join(' ').downcase %>">
            <div class="flex items-start justify-between gap-2" data-filter-column="status" data-filter-value="<%= task.status.downcase %>">
              <p class="text-sm font-black leading-snug text-slate-950"><%= link_to task.title, admin_agency_task_path(task), class: "hover:text-blue-700" %></p>
              <input type="checkbox" value="<%= task.id %>" class="mt-0.5 h-4 w-4 shrink-0 rounded border-slate-300 text-blue-600 focus:ring-blue-500" data-bulk-actions-target="checkbox" data-action="change->bulk-actions#refresh">
            </div>
            <div class="mt-2 flex flex-wrap items-center gap-1.5" data-filter-column="category" data-filter-value="<%= task.agency_task_category&.name.to_s.downcase %>">
              <% if task.agency_task_category.present? %>
                <span class="rounded-full px-2 py-0.5 text-[0.65rem] font-black <%= agency_task_category_badge_class(task.agency_task_category) %>"><%= task.agency_task_category.name %></span>
              <% end %>
              <span class="rounded-full px-2 py-0.5 text-[0.65rem] font-black <%= admin_priority_class(task.priority) %>" data-filter-column="priority" data-filter-value="<%= task.priority.downcase %>"><%= task.priority %></span>
              <% if task.recurring? %>
                <span class="rounded-full bg-cyan-50 px-2 py-0.5 text-[0.65rem] font-black text-cyan-700"><i class="fa-solid fa-repeat"></i></span>
              <% end %>
            </div>
            <% if task.due_date.present? %>
              <p class="mt-2 text-xs font-bold <%= task.due_date < Date.current && !AgencyTask::CLOSED_STATUSES.include?(task.status) ? 'text-rose-600' : 'text-slate-500' %>">
                <i class="fa-regular fa-calendar"></i> <%= task.due_date.strftime("%b %-d") %>
              </p>
            <% end %>
            <% if task.checklist_items.any? %>
              <p class="mt-2 text-xs font-bold text-slate-400"><i class="fa-solid fa-list-check"></i> <%= task.checklist_items.count(&:done) %>/<%= task.checklist_items.size %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
