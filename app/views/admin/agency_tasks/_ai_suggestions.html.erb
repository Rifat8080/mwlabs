<div class="rounded-2xl border border-blue-200 bg-blue-50 p-5" id="agency-task-ai-suggestions" data-controller="dismissible">
  <p class="flex items-center gap-2 text-xs font-black uppercase tracking-[0.16em] text-blue-700">
    <i class="fa-solid fa-wand-magic-sparkles"></i> AI Suggestions
  </p>

  <div class="mt-3 space-y-3 text-sm text-slate-700">
    <% if suggestion[:description].present? %>
      <div>
        <p class="text-xs font-black uppercase tracking-wide text-slate-500">Description</p>
        <p class="mt-1"><%= suggestion[:description] %></p>
      </div>
    <% end %>
    <% if suggestion[:priority].present? %>
      <div><span class="text-xs font-black uppercase tracking-wide text-slate-500">Priority:</span> <%= suggestion[:priority] %></div>
    <% end %>
    <% if suggestion[:due_date].present? %>
      <div><span class="text-xs font-black uppercase tracking-wide text-slate-500">Suggested due date:</span> <%= suggestion[:due_date] %></div>
    <% end %>
    <% if Array(suggestion[:checklist]).any? %>
      <div>
        <p class="text-xs font-black uppercase tracking-wide text-slate-500">Suggested checklist</p>
        <ul class="mt-1 list-disc space-y-1 pl-5">
          <% Array(suggestion[:checklist]).each do |item| %><li><%= item %></li><% end %>
        </ul>
      </div>
    <% end %>
  </div>

  <div class="mt-4 flex flex-wrap items-center gap-3">
    <%= form_with model: [ :admin, agency_task ], method: :patch do %>
      <% if suggestion[:description].present? %><%= hidden_field_tag "agency_task[description]", suggestion[:description] %><% end %>
      <% if AgencyTask::PRIORITIES.include?(suggestion[:priority]) %><%= hidden_field_tag "agency_task[priority]", suggestion[:priority] %><% end %>
      <% if suggestion[:due_date].present? %><%= hidden_field_tag "agency_task[due_date]", suggestion[:due_date] %><% end %>
      <% Array(suggestion[:checklist]).each_with_index do |item, index| %>
        <%= hidden_field_tag "agency_task[checklist_items_attributes][#{index}][title]", item %>
      <% end %>
      <button type="submit" class="rounded-xl bg-blue-600 px-4 py-2.5 text-sm font-black text-white shadow-lg shadow-blue-600/20 hover:bg-blue-700">Accept &amp; Save</button>
    <% end %>
    <button type="button" data-action="click->dismissible#dismiss" class="text-xs font-bold text-slate-500 hover:text-slate-700">Discard</button>
  </div>
</div>
