<% today = Date.current %>
<% groups = {
  "Overdue" => tasks.select { |t| t.due_date.present? && t.due_date < today && !AgencyTask::CLOSED_STATUSES.include?(t.status) },
  "Today" => tasks.select { |t| t.due_date == today },
  "This Week" => tasks.select { |t| t.due_date.present? && t.due_date > today && t.due_date <= today.end_of_week },
  "Later" => tasks.select { |t| t.due_date.present? && t.due_date > today.end_of_week },
  "No Due Date" => tasks.select { |t| t.due_date.blank? }
} %>

<div class="space-y-5">
  <% groups.each do |label, group_tasks| %>
    <% next if group_tasks.empty? %>
    <section class="overflow-hidden rounded-[1.75rem] border border-white bg-white/90 shadow-xl shadow-slate-200/70 backdrop-blur">
      <div class="border-b border-slate-100 bg-slate-50/70 px-5 py-4 lg:px-6">
        <h2 class="text-sm font-black uppercase tracking-[0.16em] <%= label == "Overdue" ? "text-rose-600" : "text-blue-600" %>">
          <%= label %> <span class="text-slate-400">(<%= group_tasks.size %>)</span>
        </h2>
      </div>
      <ul class="divide-y divide-slate-100">
        <% group_tasks.each do |task| %>
          <li class="flex flex-wrap items-center justify-between gap-3 px-5 py-4 transition hover:bg-blue-50/40 lg:px-6" data-table-filter-target="row" data-search-text="<%= [ task.title, task.description, task.tags ].compact.join(' ').downcase %>">
            <div class="flex min-w-0 items-center gap-3">
              <input type="checkbox" value="<%= task.id %>" class="h-4 w-4 shrink-0 rounded border-slate-300 text-blue-600 focus:ring-blue-500" data-bulk-actions-target="checkbox" data-action="change->bulk-actions#refresh">
              <div class="min-w-0">
                <%= link_to task.title, admin_agency_task_path(task), class: "block truncate text-sm font-black text-slate-950 transition hover:text-blue-700" %>
                <p class="mt-1 text-xs font-semibold text-slate-500">
                  <%= task.agency_task_category&.name || "Uncategorized" %>
                  <% if task.due_date.present? %> · <%= task.due_date.strftime("%b %-d, %Y") %><% end %>
                </p>
              </div>
            </div>
            <div class="flex shrink-0 items-center gap-2" data-filter-column="status" data-filter-value="<%= task.status.downcase %>">
              <span data-filter-column="priority" data-filter-value="<%= task.priority.downcase %>" class="rounded-full px-2.5 py-1 text-xs font-black <%= admin_priority_class(task.priority) %>"><%= task.priority %></span>
              <span class="inline-flex rounded-full px-2.5 py-1 text-xs font-black ring-1 <%= admin_status_class(task.status) %>"><%= task.status.titleize %></span>
            </div>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <% if tasks.empty? %>
    <div class="rounded-[1.75rem] border border-dashed border-slate-200 bg-white px-6 py-16 text-center shadow-sm">
      <span class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-50 text-blue-600">
        <i class="fa-solid fa-inbox text-xl"></i>
      </span>
      <p class="mt-4 text-sm font-black text-slate-900">No tasks yet</p>
    </div>
  <% end %>
</div>
