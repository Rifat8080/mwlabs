<% param_prefix = "agency_task[checklist_items_attributes]" %>
<div class="overflow-hidden rounded-[1.75rem] border border-slate-200 bg-slate-50/70" data-controller="dynamic-fields" data-dynamic-fields-param-prefix-value="<%= param_prefix %>">
  <div class="border-b border-slate-200 bg-white/60 px-5 py-4 lg:px-6">
    <p class="text-xs font-black uppercase tracking-[0.18em] text-blue-600">Checklist</p>
    <h2 class="mt-2 text-xl font-black text-slate-950">Add Checklist Items</h2>
    <p class="mt-1 text-sm font-medium text-slate-600">
      <% if @resource.persisted? && @resource.checklist_items.any? %>
        This task already has <%= pluralize(@resource.checklist_items.count, "checklist item") %> — manage them from the task detail page. Add more below.
      <% else %>
        Break this task into smaller steps. You can add or remove rows instantly.
      <% end %>
    </p>
  </div>

  <div class="space-y-3 p-4 lg:p-6" data-dynamic-fields-target="container">
    <div class="flex items-center gap-3" data-dynamic-fields-row>
      <input type="text" name="<%= param_prefix %>[0][title]" placeholder="Checklist item" data-field-name="title" class="block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-900 shadow-sm focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50">
      <button type="button" data-action="dynamic-fields#remove" class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-rose-100 bg-rose-50 text-rose-700 transition hover:bg-rose-100">
        <i class="fa-solid fa-trash-can text-xs"></i>
      </button>
    </div>
  </div>

  <div class="border-t border-slate-200 bg-white/60 px-5 py-4 lg:px-6">
    <button type="button" data-action="dynamic-fields#add" class="inline-flex items-center gap-2 rounded-2xl border border-blue-200 bg-white px-4 py-3 text-sm font-black text-blue-700 shadow-sm transition hover:bg-blue-50">
      <i class="fa-solid fa-plus text-xs"></i>
      Add checklist item
    </button>
  </div>

  <template data-dynamic-fields-target="template">
    <div class="flex items-center gap-3" data-dynamic-fields-row>
      <input type="text" value="" placeholder="Checklist item" data-field-name="title" class="block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-900 shadow-sm focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50">
      <button type="button" data-action="dynamic-fields#remove" class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-rose-100 bg-rose-50 text-rose-700 transition hover:bg-rose-100">
        <i class="fa-solid fa-trash-can text-xs"></i>
      </button>
    </div>
  </template>
</div>
