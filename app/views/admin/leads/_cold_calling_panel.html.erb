<details data-controller="cold-calling" data-cold-calling-panel class="group rounded-[1.75rem] border border-emerald-100 bg-emerald-50/80 p-5 shadow-lg shadow-emerald-100/40 lg:p-6">
  <summary class="list-none flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between cursor-pointer">
    <div class="flex items-start gap-3">
      <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-white text-emerald-600 shadow-sm">
        <i class="fa-solid fa-phone-volume"></i>
      </span>
      <div class="min-w-0">
        <p class="text-xs font-black uppercase tracking-[0.16em] text-emerald-700">Cold calling guide</p>
        <h2 class="mt-2 text-lg font-black text-slate-950">Beginner-friendly script for callers</h2>
        <p class="mt-2 text-sm font-semibold leading-6 text-slate-700">
          This framework keeps the conversation natural, helps the caller listen more than talk, and gives them a simple structure for taking notes.
        </p>
      </div>
    </div>

    <span class="inline-flex items-center gap-2 self-start rounded-full border border-emerald-200 bg-white px-4 py-2 text-sm font-black text-emerald-700 shadow-sm transition hover:border-emerald-300 hover:bg-emerald-50">
      Open cold call guide
      <i class="fa-solid fa-chevron-down text-xs transition duration-200 group-open:-rotate-180"></i>
    </span>
  </summary>

  <div class="mt-6">
    <div class="rounded-2xl border border-slate-200 bg-white/90 px-4 py-3 text-sm font-semibold text-slate-700 shadow-sm">
      <span data-cold-calling-target="status">Ready to save answers without reloading.</span>
    </div>

    <%= form_with model: [:admin, lead], url: admin_lead_path(lead), method: :patch, local: true, data: { action: "submit->cold-calling#submit", cold_calling_target: "form" }, class: "mt-6 space-y-6" do |form| %>
    <% saved_answers = lead.cold_call_answer_values %>
    <div class="grid gap-4 lg:grid-cols-[1fr_1.1fr]">
      <div class="rounded-[1.5rem] border border-emerald-200 bg-white/95 p-5 shadow-sm">
        <p class="text-sm font-black text-slate-950">Question answers</p>
        <p class="mt-1 text-sm text-slate-600">Capture the prospect’s response to each call prompt.</p>

        <div class="mt-4 space-y-4">
          <% lead.cold_call_questions.each do |question| %>
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
              <p class="text-xs font-black uppercase tracking-[0.14em] text-slate-500"><%= question[:label] %></p>
              <%= text_area_tag "lead[question_answers][#{question[:key]}]", saved_answers[:question_answers][question[:key]], rows: 2, data: { action: "input->cold-calling#saveForm change->cold-calling#saveForm" }, class: "mt-3 block w-full rounded-2xl border border-slate-200 bg-white px-3 py-3 text-sm font-semibold text-slate-900 shadow-sm focus:border-emerald-300 focus:outline-none focus:ring-4 focus:ring-emerald-50" %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="space-y-4">
        <div class="rounded-[1.5rem] border border-emerald-200 bg-white/95 p-5 shadow-sm">
          <p class="text-sm font-black text-slate-950">Overview notes</p>
          <p class="mt-1 text-sm text-slate-600">Use these fields for summary insights, objections, and next steps.</p>

          <div class="mt-4 space-y-4">
            <div>
              <%= label_tag "lead[client_answers]", "Client answers", class: "block text-[0.68rem] font-black uppercase tracking-[0.16em] text-slate-500" %>
              <%= text_area_tag "lead[client_answers]", saved_answers[:client_answers], rows: 4, data: { action: "input->cold-calling#saveForm change->cold-calling#saveForm" }, class: "mt-2 block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm focus:border-emerald-300 focus:outline-none focus:ring-4 focus:ring-emerald-50" %>
            </div>

            <div>
              <%= label_tag "lead[caller_notes]", "Caller notes", class: "block text-[0.68rem] font-black uppercase tracking-[0.16em] text-slate-500" %>
              <%= text_area_tag "lead[caller_notes]", saved_answers[:caller_notes], rows: 4, data: { action: "input->cold-calling#saveForm change->cold-calling#saveForm" }, class: "mt-2 block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm focus:border-emerald-300 focus:outline-none focus:ring-4 focus:ring-emerald-50" %>
            </div>
          </div>
        </div>

        <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50/90 p-4 text-sm text-slate-600 shadow-sm">
          <p class="font-black text-slate-950">Why this matters</p>
          <p class="mt-2 leading-6">Recording answers per question makes follow-ups faster, prevents detail loss, and helps the team quickly action the right next step.</p>
        </div>

        <div class="flex justify-end">
          <%= form.submit "Save call notes", class: "inline-flex items-center justify-center rounded-full bg-emerald-600 px-5 py-3 text-sm font-black text-white shadow-lg shadow-emerald-600/20 transition hover:bg-emerald-700" %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="mt-6 space-y-4">
    <% lead.cold_call_script_steps.each_with_index do |step, index| %>
      <div class="rounded-2xl border border-emerald-100 bg-white/90 p-4 shadow-sm">
        <p class="text-sm font-black text-slate-950"><%= step[:title] %></p>
        <ul class="mt-3 space-y-2">
          <% step[:lines].each do |line| %>
            <li class="rounded-xl border border-slate-100 bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-700"><%= line %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>

  <div class="mt-6 rounded-2xl border border-emerald-200 bg-white/80 p-4">
    <p class="text-sm font-black text-slate-950">Call note prompts</p>
    <ul class="mt-3 space-y-2">
      <% lead.cold_call_note_prompts.each do |prompt| %>
        <li class="rounded-xl border border-slate-100 bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-700"><%= prompt %></li>
      <% end %>
    </ul>
  </div>
</details>
