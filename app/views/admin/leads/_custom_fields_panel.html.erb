<section id="lead-custom-fields" class="overflow-hidden rounded-[1.75rem] border border-violet-100 bg-white/90 shadow-xl shadow-violet-100/40 backdrop-blur">
  <% if Lead.custom_fields_supported? %>
  <div class="border-b border-violet-100 bg-[radial-gradient(circle_at_top_right,_#f5f3ff,_transparent_24rem),#ffffff] p-5 lg:p-6">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <div class="inline-flex items-center gap-2 rounded-full border border-violet-100 bg-violet-50 px-3 py-1.5 text-xs font-black uppercase tracking-[0.16em] text-violet-700">
          <i class="fa-solid fa-tags"></i>
          Custom Fields
        </div>
        <h2 class="mt-3 text-2xl font-black tracking-tight text-slate-950">Extra lead details</h2>
        <p class="mt-2 max-w-3xl text-sm font-semibold leading-7 text-slate-600">Add or remove custom fields instantly. Changes save without reloading the page.</p>
      </div>
      <span class="inline-flex rounded-full bg-violet-50 px-3 py-1.5 text-xs font-black text-violet-700 ring-1 ring-violet-100"><%= lead.custom_fields.size %> fields</span>
    </div>
  </div>

  <div class="space-y-3 p-4 sm:p-5 lg:p-6">
    <% if lead.custom_fields.any? %>
      <div class="grid gap-3 sm:grid-cols-2">
        <% lead.custom_fields.each_with_index do |field, index| %>
          <article class="rounded-2xl border border-slate-100 bg-slate-50/80 p-4 transition hover:border-violet-100 hover:bg-white">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-[0.68rem] font-black uppercase tracking-[0.16em] text-slate-400"><%= field["label"].presence || "Custom field" %></p>
                <p class="mt-2 break-words text-sm font-semibold text-slate-900"><%= field["value"].presence || "—" %></p>
              </div>
              <% if can_manage_resource?(Lead) %>
                <%= button_to admin_lead_custom_field_path(lead, index: index), method: :delete, form: { data: { turbo_confirm: "Remove this custom field?" } }, class: "shrink-0 rounded-xl border border-rose-100 bg-rose-50 px-3 py-2 text-xs font-black text-rose-700 hover:bg-rose-100" do %>
                  <i class="fa-solid fa-trash-can"></i>
                <% end %>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-2xl border border-dashed border-slate-200 bg-slate-50 px-6 py-10 text-center">
        <i class="fa-solid fa-tags text-2xl text-slate-300"></i>
        <p class="mt-3 text-sm font-black text-slate-700">No custom fields yet</p>
        <p class="mt-1 text-sm font-medium text-slate-500">Use the form below to capture extra qualification details for this lead.</p>
      </div>
    <% end %>
  </div>

  <% if can_manage_resource?(Lead) %>
    <div class="border-t border-violet-100 bg-slate-50/80 p-4 sm:p-5 lg:p-6">
      <%= form_with url: admin_lead_custom_fields_path(lead), method: :post, class: "grid gap-3 rounded-[1.25rem] border border-slate-200 bg-white p-4 shadow-sm lg:grid-cols-12" do |form| %>
        <div class="lg:col-span-4">
          <%= form.label :label, "Field label", class: "block text-xs font-black uppercase tracking-[0.14em] text-slate-500" %>
          <%= form.text_field :label, required: true, placeholder: "Example: Budget range", class: "mt-2 block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm focus:border-violet-300 focus:outline-none focus:ring-4 focus:ring-violet-50" %>
        </div>
        <div class="lg:col-span-6">
          <%= form.label :value, "Value", class: "block text-xs font-black uppercase tracking-[0.14em] text-slate-500" %>
          <%= form.text_field :value, placeholder: "Example: $5k-$10k", class: "mt-2 block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm focus:border-violet-300 focus:outline-none focus:ring-4 focus:ring-violet-50" %>
        </div>
        <div class="flex items-end lg:col-span-2">
          <%= form.submit "Add field", class: "w-full rounded-xl bg-violet-600 px-4 py-3 text-sm font-extrabold text-white shadow-lg shadow-violet-600/20 hover:bg-violet-700" %>
        </div>
      <% end %>
    </div>
  <% end %>
  <% else %>
    <div class="p-4 sm:p-5 lg:p-6">
      <%= render "admin/leads/custom_fields_migration_notice" %>
    </div>
  <% end %>
</section>
