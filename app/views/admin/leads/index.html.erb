<% content_for :title, "#{resource_title} | M&W Labs Control Center" %>
<% content_for :meta_description, resource_description %>

<% assigned_field = resource_fields.find { |field| field[:name] == :assigned_to_id } %>
<% can_bulk_manage = can_manage_resource?(Lead) %>
<% column_labels = { display_name: "Lead", follow_up_date: "Follow-up", assigned_to: "Assigned to", service_interest: "Interest" } %>

<div class="space-y-6" data-controller="table-filter bulk-actions">
  <section class="relative overflow-hidden rounded-[2.25rem] border border-white/80 bg-slate-950 p-6 text-white shadow-2xl shadow-slate-900/20 lg:p-8">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(56,189,248,0.35),_transparent_28rem),radial-gradient(circle_at_bottom_left,_rgba(37,99,235,0.3),_transparent_22rem)]"></div>
    <div class="relative flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between">
      <div class="min-w-0">
        <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-[0.68rem] font-black uppercase tracking-[0.2em] text-cyan-100 backdrop-blur">
          <i class="fa-solid fa-user-plus"></i>
          Lead Workspace
        </div>
        <h1 class="mt-5 text-4xl font-black tracking-tight md:text-5xl"><%= resource_title %></h1>
        <p class="mt-3 max-w-3xl text-sm font-semibold leading-7 text-slate-300 md:text-base"><%= resource_description %></p>
      </div>

      <% if can_bulk_manage %>
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
          <%= link_to import_admin_leads_path, class: "inline-flex items-center justify-center gap-2 rounded-2xl border border-white/15 bg-white/10 px-5 py-3.5 text-sm font-black text-white backdrop-blur transition hover:bg-white/15" do %>
            Import CSV / Excel
            <i class="fa-solid fa-file-arrow-up text-xs"></i>
          <% end %>
          <%= link_to new_admin_lead_path, class: "inline-flex items-center justify-center gap-2 rounded-2xl bg-white px-5 py-3.5 text-sm font-black text-slate-950 shadow-xl shadow-black/10 transition hover:-translate-y-0.5 hover:bg-blue-50" do %>
            New Lead
            <i class="fa-solid fa-plus text-xs"></i>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="relative mt-8 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
      <% [
        [ "Total leads", @lead_stats[:total], "fa-layer-group" ],
        [ "New this month", @lead_stats[:new_this_month], "fa-arrow-trend-up" ],
        [ "Follow-ups due", @lead_stats[:follow_ups_due], "fa-bell" ],
        [ "Won", @lead_stats[:won], "fa-trophy" ]
      ].each do |label, value, icon| %>
        <div class="rounded-2xl border border-white/10 bg-white/10 px-5 py-4 backdrop-blur">
          <div class="flex items-center gap-2 text-[0.68rem] font-black uppercase tracking-[0.16em] text-slate-300">
            <i class="fa-solid <%= icon %> text-cyan-300"></i>
            <%= label %>
          </div>
          <p class="mt-2 text-3xl font-black"><%= value %></p>
        </div>
      <% end %>
    </div>
  </section>

  <%= render "admin/resources/filters",
    resources: @resources,
    columns: visible_resource_columns,
    record_name: "lead",
    column_labels: column_labels,
    select_change_action: "change->table-filter#filter change->bulk-actions#refresh" %>

  <% if can_bulk_manage %>
    <div class="sticky top-4 z-20 hidden overflow-hidden rounded-2xl border border-slate-800 bg-slate-950/95 shadow-2xl shadow-slate-900/40 backdrop-blur" data-bulk-actions-target="bar">
      <div class="flex flex-col gap-3 px-4 py-3 lg:flex-row lg:items-center lg:justify-between lg:px-5">
        <div class="flex items-center gap-3">
          <span class="inline-flex min-w-8 items-center justify-center rounded-lg bg-blue-500 px-2 py-1 text-sm font-black text-white shadow-lg shadow-blue-500/30" data-bulk-actions-target="count">0 leads selected</span>
          <button type="button" class="text-xs font-bold text-slate-400 transition hover:text-white" data-action="click->bulk-actions#clear">
            Clear
            <i class="fa-solid fa-xmark ml-1 text-[0.65rem]"></i>
          </button>
        </div>

        <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
          <%= form_with url: bulk_update_admin_leads_path, method: :patch, class: "flex items-center", data: { bulk_actions_target: "assignForm", action: "submit->bulk-actions#injectIds" } do %>
            <input type="hidden" name="bulk_action" value="assign">
            <div class="flex items-center overflow-hidden rounded-xl border border-slate-700 bg-slate-900">
              <span class="flex items-center gap-2 border-r border-slate-700 px-3 py-2 text-[0.65rem] font-black uppercase tracking-[0.12em] text-slate-400">
                <i class="fa-solid fa-user-check text-[0.65rem]"></i>
                Assign
              </span>
              <select name="assigned_to_id" class="h-9 border-0 bg-transparent pl-3 pr-8 text-xs font-bold text-white outline-none [&>option]:text-slate-900">
                <option value="">Unassigned</option>
                <% field_options(assigned_field).each do |label, id| %>
                  <option value="<%= id %>"><%= label %></option>
                <% end %>
              </select>
              <button type="submit" disabled class="h-9 border-l border-slate-700 bg-slate-800 px-3.5 text-xs font-black text-white transition hover:bg-blue-600 disabled:cursor-not-allowed disabled:opacity-40 disabled:hover:bg-slate-800" data-bulk-actions-target="assignSubmit">Apply</button>
            </div>
          <% end %>

          <%= form_with url: bulk_update_admin_leads_path, method: :patch, class: "flex items-center", data: { bulk_actions_target: "statusForm", action: "submit->bulk-actions#injectIds" } do %>
            <input type="hidden" name="bulk_action" value="status">
            <div class="flex items-center overflow-hidden rounded-xl border border-slate-700 bg-slate-900">
              <span class="flex items-center gap-2 border-r border-slate-700 px-3 py-2 text-[0.65rem] font-black uppercase tracking-[0.12em] text-slate-400">
                <i class="fa-solid fa-tag text-[0.65rem]"></i>
                Status
              </span>
              <select name="status" class="h-9 border-0 bg-transparent pl-3 pr-8 text-xs font-bold text-white outline-none [&>option]:text-slate-900">
                <option value="">Choose&hellip;</option>
                <% Lead::STATUSES.each do |status| %>
                  <option value="<%= status %>"><%= status %></option>
                <% end %>
              </select>
              <button type="submit" disabled class="h-9 border-l border-slate-700 bg-slate-800 px-3.5 text-xs font-black text-white transition hover:bg-blue-600 disabled:cursor-not-allowed disabled:opacity-40 disabled:hover:bg-slate-800" data-bulk-actions-target="statusSubmit">Apply</button>
            </div>
          <% end %>

          <%= form_with url: bulk_destroy_admin_leads_path, method: :delete, data: { bulk_actions_target: "deleteForm", action: "submit->bulk-actions#confirmDelete submit->bulk-actions#injectIds" } do %>
            <button type="submit" class="inline-flex h-9 items-center gap-2 rounded-xl border border-rose-500/40 bg-rose-500/10 px-3.5 text-xs font-black text-rose-300 transition hover:bg-rose-500 hover:text-white">
              <i class="fa-solid fa-trash text-[0.7rem]"></i>
              Delete
            </button>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="space-y-3 lg:hidden">
    <% @resources.each do |resource| %>
      <% status_value = field_value(resource, name: :status) %>
      <article class="rounded-[1.5rem] border border-slate-100 bg-white p-4 shadow-lg shadow-slate-200/60 transition hover:border-blue-100 hover:shadow-blue-100/50" data-table-filter-target="row" data-search-text="<%= visible_resource_columns.map { |column| admin_value(field_value(resource, name: column)).to_s.downcase }.join(' ') %>">
        <div class="flex items-start justify-between gap-3">
          <div class="flex min-w-0 items-start gap-3">
            <% if can_bulk_manage %>
              <input type="checkbox" value="<%= resource.id %>" class="mt-1 h-4 w-4 shrink-0 rounded border-slate-300 text-blue-600 focus:ring-blue-500" data-bulk-actions-target="checkbox" data-action="change->bulk-actions#refresh">
            <% end %>
            <div class="min-w-0">
              <p class="truncate text-base font-black text-slate-950">
                <%= link_to resource.display_name, admin_lead_path(resource), class: "block truncate text-base font-black text-slate-950 transition hover:text-blue-700" %>
              </p>
              <span class="mt-2 inline-flex rounded-full px-2.5 py-1 text-xs font-black ring-1 <%= admin_status_class(status_value) %>"><%= admin_value(status_value) %></span>
            </div>
          </div>
          <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-blue-50 text-blue-600">
            <i class="fa-solid fa-user-plus text-sm"></i>
          </span>
        </div>

        <dl class="mt-4 grid gap-2 sm:grid-cols-2">
          <% visible_resource_columns.each do |column| %>
            <% next if column == :status || column == :display_name %>
            <% value = field_value(resource, name: column) %>
            <% overdue = column == :follow_up_date && value.present? && value <= Date.current && !resource.status.in?(%w[ Won Lost ]) %>
            <div class="rounded-xl bg-slate-50 px-3 py-2" data-filter-column="<%= column %>" data-filter-value="<%= admin_value(value).to_s.downcase %>">
              <dt class="text-[0.65rem] font-black uppercase tracking-[0.14em] text-slate-400"><%= column_labels[column] || column.to_s.humanize %></dt>
              <dd class="mt-1 flex items-center gap-2 truncate text-sm font-semibold <%= overdue ? "text-rose-600" : "text-slate-700" %>">
                <% if column == :assigned_to && resource.assigned_to.present? %>
                  <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-blue-100 text-[0.6rem] font-black text-blue-700"><%= admin_initials(resource.assigned_to.display_name) %></span>
                <% end %>
                <% if admin_value_link?(value) %>
                  <%= link_to admin_value(value), admin_value_link_url(value), target: "_blank", rel: "noopener", class: "truncate text-blue-700 underline decoration-blue-200 underline-offset-2 hover:text-blue-900" %>
                <% else %>
                  <span class="truncate"><%= admin_value(value) %></span>
                  <% if overdue %><i class="fa-solid fa-triangle-exclamation text-[0.65rem]"></i><% end %>
                <% end %>
              </dd>
            </div>
          <% end %>
        </dl>

        <div class="mt-4 flex gap-2">
          <%= link_to "View", admin_lead_path(resource), class: "flex-1 rounded-xl bg-slate-950 px-3 py-2.5 text-center text-xs font-black text-white shadow-lg shadow-slate-900/10" %>
          <% if can_bulk_manage %>
            <%= link_to "Edit", edit_admin_lead_path(resource), class: "flex-1 rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-center text-xs font-black text-slate-700" %>
            <%= button_to "Delete", admin_lead_path(resource), method: :delete, form: { data: { turbo_confirm: "Delete this lead?" }, class: "flex-1" }, class: "w-full rounded-xl border border-rose-100 bg-rose-50 px-3 py-2.5 text-center text-xs font-black text-rose-700 hover:bg-rose-100" %>
          <% end %>
        </div>
      </article>
    <% end %>

    <% if @resources.empty? %>
      <div class="rounded-[1.75rem] border border-dashed border-slate-200 bg-white px-6 py-16 text-center shadow-sm">
        <span class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-50 text-blue-600">
          <i class="fa-solid fa-inbox text-xl"></i>
        </span>
        <p class="mt-4 text-sm font-black text-slate-900">No leads yet</p>
        <p class="mt-1 text-sm font-medium text-slate-500">Create the first lead to start tracking this workflow.</p>
      </div>
    <% end %>

    <div class="hidden rounded-[1.5rem] border border-dashed border-slate-200 bg-white px-6 py-12 text-center text-sm font-semibold text-slate-500" data-table-filter-target="empty">
      No matching leads found.
    </div>
  </div>

  <section class="hidden overflow-hidden rounded-[1.75rem] border border-white bg-white/90 shadow-xl shadow-slate-200/70 backdrop-blur lg:block">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50/80">
          <tr>
            <% if can_bulk_manage %>
              <th class="w-12 px-5 py-4 text-left">
                <input type="checkbox" class="h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500" data-bulk-actions-target="selectAll" data-action="change->bulk-actions#toggleAll">
              </th>
            <% end %>
            <% visible_resource_columns.each do |column| %>
              <th class="px-5 py-4 text-left text-xs font-black uppercase tracking-[0.16em] text-slate-500"><%= column_labels[column] || column.to_s.humanize %></th>
            <% end %>
            <th class="px-5 py-4 text-right text-xs font-black uppercase tracking-[0.16em] text-slate-500">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @resources.each do |resource| %>
            <tr class="transition hover:bg-blue-50/50" data-table-filter-target="row" data-search-text="<%= visible_resource_columns.map { |column| admin_value(field_value(resource, name: column)).to_s.downcase }.join(' ') %>">
              <% if can_bulk_manage %>
                <td class="whitespace-nowrap px-5 py-4">
                  <input type="checkbox" value="<%= resource.id %>" class="h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500" data-bulk-actions-target="checkbox" data-action="change->bulk-actions#refresh">
                </td>
              <% end %>
              <% visible_resource_columns.each do |column| %>
                <% value = field_value(resource, name: column) %>
                <% overdue = column == :follow_up_date && value.present? && value <= Date.current && !resource.status.in?(%w[ Won Lost ]) %>
                <td class="whitespace-nowrap px-5 py-4 font-semibold text-slate-700" data-filter-column="<%= column %>" data-filter-value="<%= admin_value(value).to_s.downcase %>">
                  <% if column == :status %>
                    <span class="inline-flex rounded-full px-2.5 py-1 text-xs font-black ring-1 <%= admin_status_class(value) %>"><%= admin_value(value) %></span>
                  <% elsif column == :display_name %>
                    <%= link_to admin_value(value), admin_lead_path(resource), class: "inline-flex max-w-xs items-center gap-2 truncate text-slate-950 transition hover:text-blue-700" %>
                  <% elsif column == :assigned_to %>
                    <% if resource.assigned_to.present? %>
                      <span class="inline-flex items-center gap-2">
                        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-blue-100 text-[0.6rem] font-black text-blue-700"><%= admin_initials(resource.assigned_to.display_name) %></span>
                        <span class="max-w-[10rem] truncate"><%= resource.assigned_to.display_name %></span>
                      </span>
                    <% else %>
                      <span class="text-slate-400">Unassigned</span>
                    <% end %>
                  <% elsif column == :follow_up_date %>
                    <span class="inline-flex items-center gap-1.5 <%= overdue ? "text-rose-600" : "" %>">
                      <%= admin_value(value) %>
                      <% if overdue %><i class="fa-solid fa-triangle-exclamation text-[0.65rem]"></i><% end %>
                    </span>
                  <% elsif admin_value_link?(value) %>
                    <%= link_to admin_value(value), admin_value_link_url(value), target: "_blank", rel: "noopener", class: "inline-flex max-w-xs items-center gap-2 truncate text-blue-700 underline decoration-blue-200 underline-offset-2 hover:text-blue-900" %>
                  <% else %>
                    <div class="flex items-center gap-2">
                      <span class="max-w-xs truncate"><%= admin_value(value) %></span>
                      <% if admin_value_copyable?(value) %>
                        <button type="button" class="rounded-full border border-slate-200 bg-white p-1.5 text-slate-500 transition hover:border-blue-200 hover:text-blue-600" data-action="click->table-filter#copyValue" data-copy-value="<%= admin_value(value) %>" aria-label="Copy <%= column.to_s.humanize.downcase %>">
                          <i class="fa-regular fa-copy text-[0.7rem]"></i>
                        </button>
                      <% end %>
                    </div>
                  <% end %>
                </td>
              <% end %>
              <td class="whitespace-nowrap px-5 py-4 text-right">
                <div class="inline-flex items-center gap-2">
                  <%= link_to "View", admin_lead_path(resource), class: "rounded-xl bg-slate-950 px-3 py-2 text-xs font-black text-white shadow-lg shadow-slate-900/10 hover:bg-blue-700" %>
                  <% if can_bulk_manage %>
                    <%= link_to "Edit", edit_admin_lead_path(resource), class: "rounded-xl border border-slate-200 bg-white px-3 py-2 text-xs font-black text-slate-700 hover:bg-slate-50" %>
                    <%= button_to "Delete", admin_lead_path(resource), method: :delete, form: { data: { turbo_confirm: "Delete this lead?" } }, class: "rounded-xl border border-rose-100 bg-rose-50 px-3 py-2 text-xs font-black text-rose-700 hover:bg-rose-100" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>

          <% if @resources.empty? %>
            <tr>
              <td colspan="<%= visible_resource_columns.size + (can_bulk_manage ? 2 : 1) %>" class="px-4 py-16 text-center">
                <div class="mx-auto max-w-sm">
                  <span class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-50 text-blue-600">
                    <i class="fa-solid fa-inbox text-xl"></i>
                  </span>
                  <p class="mt-4 text-sm font-black text-slate-900">No leads yet</p>
                  <p class="mt-1 text-sm font-medium text-slate-500">Create the first lead to start tracking this workflow.</p>
                </div>
              </td>
            </tr>
          <% end %>

          <tr class="hidden" data-table-filter-target="empty">
            <td colspan="<%= visible_resource_columns.size + (can_bulk_manage ? 2 : 1) %>" class="px-4 py-12 text-center font-semibold text-slate-500">No matching leads found.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
</div>
