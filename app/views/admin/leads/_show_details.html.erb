<%= turbo_frame_tag "lead-show-details" do %>
  <%= form_with model: [:admin, lead], url: admin_lead_path(lead), method: :patch, data: { turbo_frame: "lead-show-details" }, class: "mt-5 space-y-5" do |form| %>
    <% if lead.errors.any? %>
      <div class="rounded-2xl border border-rose-200 bg-rose-50 p-4 text-sm font-semibold text-rose-700 shadow-sm">
        <p class="font-black">Please fix the following:</p>
        <ul class="mt-2 list-disc space-y-1 pl-5">
          <% lead.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="rounded-[1.5rem] border border-slate-100 bg-slate-50/70 p-4 shadow-sm sm:p-5">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-xs font-black uppercase tracking-[0.16em] text-slate-500">Editable lead details</p>
          <p class="mt-1 text-sm font-semibold text-slate-600">Update the core lead information here without leaving the page.</p>
        </div>
        <span class="inline-flex rounded-full bg-white px-3 py-1.5 text-xs font-black uppercase tracking-[0.14em] text-slate-600 shadow-sm">Live form</span>
      </div>

      <div class="mt-5 grid gap-4 sm:grid-cols-2">
        <% resource_fields.each do |field| %>
          <% next if field[:type] == :quote_items %>
          <% next if field[:type] == :file %>
          <% next if field[:type] == :rich_text %>
          <% type = field[:type] || :text %>
          <% wrapper_class = type == :textarea ? "sm:col-span-2" : "" %>

          <div class="<%= wrapper_class %> rounded-[1.25rem] border border-slate-200 bg-white p-4 shadow-sm">
            <%= form.label field[:name], admin_field_label(field), class: "block text-[0.68rem] font-black uppercase tracking-[0.16em] text-slate-500" %>

            <% case type %>
            <% when :textarea %>
              <%= form.text_area field[:name], rows: 4, class: "mt-2 block w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-900 shadow-sm transition focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50" %>
            <% when :select %>
              <%= form.select field[:name], options_for_select(field_options(field), lead.public_send(field[:name])), { include_blank: "Select" }, class: "mt-2 block w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-900 shadow-sm transition focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50" %>
            <% when :date %>
              <%= form.date_field field[:name], class: "mt-2 block w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-900 shadow-sm transition focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50" %>
            <% when :decimal %>
              <%= form.number_field field[:name], step: 0.01, class: "mt-2 block w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-900 shadow-sm transition focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50" %>
            <% when :email %>
              <%= form.email_field field[:name], class: "mt-2 block w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-900 shadow-sm transition focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50" %>
            <% else %>
              <%= form.text_field field[:name], class: "mt-2 block w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-900 shadow-sm transition focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm font-semibold text-slate-500">Changes save inline and update the page instantly.</p>
      <%= form.submit "Save changes", class: "inline-flex items-center justify-center rounded-2xl bg-blue-600 px-5 py-3 text-sm font-black text-white shadow-lg shadow-blue-600/20 transition hover:bg-blue-700" %>
    </div>
  <% end %>
<% end %>
