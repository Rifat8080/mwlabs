<% content_for :title, "Agency OS Dashboard | M&W Labs Control Center" %>
<% content_for :meta_description, "Your personal agency operating dashboard: tasks, marketing planner, daily planner, and progress in one place." %>

<div class="space-y-6">
  <section class="relative overflow-hidden rounded-[2.25rem] border border-white/80 bg-slate-950 p-6 text-white shadow-2xl shadow-slate-900/20 lg:p-8">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(56,189,248,0.35),_transparent_28rem),radial-gradient(circle_at_bottom_left,_rgba(37,99,235,0.3),_transparent_22rem)]"></div>
    <div class="relative">
      <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-[0.68rem] font-black uppercase tracking-[0.2em] text-cyan-100 backdrop-blur">
        <i class="fa-solid fa-chart-line"></i>
        Agency OS
      </div>
      <h1 class="mt-5 text-4xl font-black tracking-tight md:text-5xl">Agency Operations Dashboard</h1>
      <p class="mt-3 max-w-3xl text-sm font-semibold leading-7 text-slate-300 md:text-base">Your personal task manager, marketing planner, and daily planner — replacing the spreadsheets and sticky notes.</p>

      <div class="mt-6 flex flex-wrap gap-3">
        <%= link_to admin_agency_tasks_path, class: "inline-flex items-center gap-2 rounded-2xl bg-white px-5 py-3 text-sm font-black text-slate-950 shadow-xl shadow-black/10 transition hover:-translate-y-0.5 hover:bg-blue-50" do %>
          Open Tasks <i class="fa-solid fa-arrow-right text-xs"></i>
        <% end %>
        <%= link_to calendar_admin_marketing_items_path, class: "inline-flex items-center gap-2 rounded-2xl border border-white/15 bg-white/10 px-5 py-3 text-sm font-black text-white backdrop-blur transition hover:-translate-y-0.5 hover:bg-white/15" do %>
          Marketing Calendar <i class="fa-solid fa-calendar-days text-xs"></i>
        <% end %>
        <%= link_to admin_daily_plan_path, class: "inline-flex items-center gap-2 rounded-2xl border border-white/15 bg-white/10 px-5 py-3 text-sm font-black text-white backdrop-blur transition hover:-translate-y-0.5 hover:bg-white/15" do %>
          Daily Planner <i class="fa-solid fa-calendar-day text-xs"></i>
        <% end %>
      </div>
    </div>
  </section>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <% @cards.each do |label, value| %>
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <p class="text-xs font-black uppercase tracking-[0.14em] text-slate-400"><%= label %></p>
        <p class="mt-2 text-3xl font-black text-slate-950"><%= value %></p>
      </div>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1.4fr_0.8fr]">
    <div class="space-y-6">
      <section class="rounded-[1.75rem] border border-white bg-white/90 p-5 shadow-xl shadow-slate-200/70 backdrop-blur lg:p-6">
        <p class="text-xs font-black uppercase tracking-[0.18em] text-blue-600">Quick Add</p>
        <%= form_with model: @new_task, url: admin_agency_tasks_path, class: "mt-3 flex flex-col gap-3 sm:flex-row" do |form| %>
          <%= form.text_field :title, placeholder: "Add a task...", required: true, class: "block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-900 shadow-sm focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50" %>
          <%= form.select :agency_task_category_id, options_from_collection_for_select(@agency_task_categories, :id, :name), { include_blank: "No category" }, class: "block w-full shrink-0 rounded-xl border border-slate-200 bg-white px-3 py-3 text-sm font-semibold text-slate-700 shadow-sm focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50 sm:w-48" %>
          <%= form.submit "Add Task", class: "shrink-0 rounded-xl bg-blue-600 px-6 py-3 text-sm font-black text-white shadow-lg shadow-blue-600/20 hover:bg-blue-700" %>
        <% end %>
      </section>

      <div class="grid gap-6 lg:grid-cols-3">
        <% [ [ "Today", @today_tasks, "fa-calendar-day" ], [ "Overdue", @overdue_tasks, "fa-triangle-exclamation" ], [ "Upcoming", @upcoming_tasks, "fa-forward" ] ].each do |label, tasks, icon| %>
          <section class="rounded-[1.75rem] border border-white bg-white/90 p-5 shadow-xl shadow-slate-200/70 backdrop-blur">
            <p class="flex items-center gap-2 text-xs font-black uppercase tracking-[0.16em] <%= label == "Overdue" ? "text-rose-600" : "text-blue-600" %>">
              <i class="fa-solid <%= icon %>"></i> <%= label %>
            </p>
            <ul class="mt-3 space-y-2">
              <% tasks.each do |task| %>
                <li class="truncate text-sm font-semibold text-slate-700">
                  <%= link_to task.title, admin_agency_task_path(task), class: "hover:text-blue-700" %>
                </li>
              <% end %>
              <% if tasks.empty? %>
                <li class="text-sm font-medium text-slate-400">Nothing here.</li>
              <% end %>
            </ul>
          </section>
        <% end %>
      </div>

      <section class="rounded-[1.75rem] border border-white bg-white/90 p-5 shadow-xl shadow-slate-200/70 backdrop-blur lg:p-6">
        <p class="text-xs font-black uppercase tracking-[0.18em] text-blue-600">Calendar Overview — <%= Date.current.strftime("%B %Y") %></p>
        <div class="mt-4 grid grid-cols-7 gap-1.5 text-center">
          <% %w[S M T W T F S].each do |d| %><div class="text-[0.6rem] font-black text-slate-400"><%= d %></div><% end %>
          <% Date.current.beginning_of_month.wday.times do %><div></div><% end %>
          <% @mini_calendar.each do |date, counts| %>
            <% total = counts[:tasks] + counts[:marketing] %>
            <div class="flex h-9 flex-col items-center justify-center rounded-lg text-[0.65rem] font-bold <%= date == Date.current ? "bg-blue-600 text-white" : total.positive? ? "bg-blue-50 text-blue-700" : "text-slate-400" %>">
              <%= date.day %>
              <% if total.positive? %><span class="h-1 w-1 rounded-full <%= date == Date.current ? "bg-white" : "bg-blue-500" %>"></span><% end %>
            </div>
          <% end %>
        </div>
      </section>
    </div>

    <div class="space-y-6">
      <section class="rounded-[1.75rem] border border-white bg-white/90 p-5 shadow-xl shadow-slate-200/70 backdrop-blur">
        <p class="text-xs font-black uppercase tracking-[0.18em] text-blue-600">Progress</p>
        <% [ [ "This week", @weekly_progress ], [ "This month", @monthly_progress ] ].each do |label, progress| %>
          <% percent = progress[:total].positive? ? (progress[:completed].to_f / progress[:total] * 100).round : 0 %>
          <div class="mt-4">
            <div class="flex items-center justify-between text-xs font-bold text-slate-600">
              <span><%= label %></span>
              <span><%= progress[:completed] %>/<%= progress[:total] %> (<%= percent %>%)</span>
            </div>
            <div class="mt-2 h-2.5 w-full overflow-hidden rounded-full bg-slate-100">
              <div class="h-full rounded-full bg-blue-600" style="width: <%= percent %>%"></div>
            </div>
          </div>
        <% end %>
      </section>

      <section class="rounded-[1.75rem] border border-white bg-white/90 p-5 shadow-xl shadow-slate-200/70 backdrop-blur">
        <p class="text-xs font-black uppercase tracking-[0.18em] text-blue-600">Recent Activity</p>
        <ul class="mt-4 space-y-3">
          <% @recent_activity.each do |log| %>
            <li class="border-l-2 border-blue-100 pl-3">
              <p class="text-sm font-semibold text-slate-700"><%= log.action %><% if log.details.present? %>: <%= log.details %><% end %></p>
              <p class="text-xs font-medium text-slate-400"><%= time_ago_in_words(log.created_at) %> ago</p>
            </li>
          <% end %>
          <% if @recent_activity.empty? %>
            <li class="text-sm font-medium text-slate-400">No activity yet.</li>
          <% end %>
        </ul>
      </section>
    </div>
  </div>
</div>
