<% quote_form = resource_fields.any? { |field| field[:type] == :quote_items } %>
<% file_form = resource_fields.any? { |field| field[:type] == :file } %>
<%= form_with model: [ :admin, @resource ], class: "space-y-6", multipart: file_form, html: (file_form ? { data: { turbo: false } } : {}), data: (quote_form ? { controller: "quote-calculator" } : {}) do |form| %>
  <% if @resource.errors.any? %>
    <div class="rounded-2xl border-2 border-rose-200 bg-rose-50 p-5 text-sm text-rose-700 shadow-lg shadow-rose-100">
      <div class="flex gap-3">
        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-rose-500 text-white">
          <i class="fa-solid fa-circle-exclamation"></i>
        </span>
        <div>
          <p class="font-black">Please fix the following:</p>
          <ul class="mt-2 list-disc space-y-1 pl-5 font-semibold">
            <% @resource.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <p class="text-xs font-black uppercase tracking-[0.18em] text-blue-600">Form Fields</p>
    <h2 class="mt-2 text-xl font-black text-slate-950">Record information</h2>
    <p class="mt-1 text-sm font-semibold text-slate-500">Complete the fields below. Required fields are marked on validation.</p>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <% resource_fields.each do |field| %>
      <% next if field[:type] == :quote_items %>
      <% type = field[:type] || :text %>
      <% wrapper_class = type.in?(%i[textarea rich_text]) ? "sm:col-span-2" : "" %>

      <div class="<%= wrapper_class %> rounded-2xl border border-slate-100 bg-slate-50/70 p-4 transition focus-within:border-blue-200 focus-within:bg-white focus-within:shadow-lg focus-within:shadow-blue-100/40">
        <%= form.label field[:name], admin_field_label(field), class: "block text-[0.68rem] font-black uppercase tracking-[0.16em] text-slate-500" %>

        <% case type %>
        <% when :textarea %>
          <%= form.text_area field[:name], rows: 5, class: "mt-2 block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-900 shadow-sm transition placeholder:text-slate-400 focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50" %>
        <% when :rich_text %>
          <div class="mt-2 overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm focus-within:border-blue-300 focus-within:ring-4 focus-within:ring-blue-50 admin-rich-text">
            <%= form.rich_text_area field[:name], class: "trix-content min-h-[28rem] px-4 py-3 text-sm font-medium text-slate-900" %>
          </div>
        <% when :select %>
          <%= form.select field[:name], options_for_select(field_options(field), @resource.public_send(field[:name])), { include_blank: "Select" }, class: "mt-2 block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-900 shadow-sm transition focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50" %>
        <% when :checkbox %>
          <div class="mt-3 flex items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3">
            <%= form.check_box field[:name], class: "h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500" %>
            <span class="text-sm font-semibold text-slate-700">Yes</span>
          </div>
        <% when :file %>
          <% if @resource.is_a?(BlogPost) && field[:name] == :cover_image %>
            <div class="mt-2 space-y-3" data-controller="cover-image-upload" data-cover-image-upload-max-size-value="<%= BlogPost::COVER_IMAGE_MAX_SIZE %>">
              <% if @resource.cover_image.attached? %>
                <div class="overflow-hidden rounded-xl border border-blue-100 bg-blue-50">
                  <%= admin_cover_image_preview @resource.cover_image, class: "h-40 w-full object-cover", alt: "Current cover image" %>
                  <p class="px-4 py-3 text-sm font-semibold text-blue-900">
                    Current cover: <%= @resource.cover_image.filename %> (<%= number_to_human_size(@resource.cover_image.byte_size) %>)
                  </p>
                </div>
              <% end %>

              <%= hidden_field_tag "blog_post[cover_image_upload_requested]", "0", data: { cover_image_upload_target: "requested" } %>
              <%= form.file_field field[:name],
                accept: "image/png,image/jpeg,image/gif,image/webp",
                class: "block w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm font-semibold text-slate-700 shadow-sm file:mr-4 file:rounded-lg file:border-0 file:bg-blue-50 file:px-4 file:py-2 file:text-sm file:font-black file:text-blue-700 hover:file:bg-blue-100",
                data: { cover_image_upload_target: "input", action: "change->cover-image-upload#select" } %>

              <div class="hidden rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-semibold text-rose-700" data-cover-image-upload-target="error" role="alert"></div>

              <div class="hidden overflow-hidden rounded-xl border border-emerald-200 bg-emerald-50" data-cover-image-upload-target="preview">
                <%= tag.img src: "", class: "h-40 w-full object-cover", alt: "Selected cover preview", data: { cover_image_upload_target: "previewImage" } %>
                <div class="px-4 py-3 text-sm font-semibold text-emerald-900">
                  <p>New cover selected: <span data-cover-image-upload-target="previewName"></span></p>
                  <p class="mt-1 text-xs text-emerald-700"><span data-cover-image-upload-target="previewSize"></span></p>
                </div>
              </div>
            </div>
          <% elsif @resource.is_a?(FileUpload) && @resource.file.attached? %>
            <div class="mt-2 rounded-xl border border-blue-100 bg-blue-50 px-4 py-3 text-sm font-semibold text-blue-900">
              <p class="font-black">Current file</p>
              <p class="mt-1 break-all"><%= @resource.file.filename %> (<%= admin_file_size(@resource) %>)</p>
              <p class="mt-1 text-xs text-blue-700">Upload a new file below to replace it.</p>
            </div>
          <% end %>
          <% unless @resource.is_a?(BlogPost) && field[:name] == :cover_image %>
          <%= form.file_field field[:name], class: "mt-2 block w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm font-semibold text-slate-700 shadow-sm file:mr-4 file:rounded-lg file:border-0 file:bg-blue-50 file:px-4 file:py-2 file:text-sm file:font-black file:text-blue-700 hover:file:bg-blue-100" %>
          <% end %>
        <% when :decimal %>
          <% calculator_target = field[:name] == :discount ? "discount" : field[:name] == :tax ? "tax" : nil %>
          <%= form.number_field field[:name], step: 0.01, class: "mt-2 block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-900 shadow-sm transition focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50", data: { quote_calculator_target: calculator_target, action: calculator_target ? "input->quote-calculator#calculate" : nil }.compact %>
        <% else %>
          <%= form.public_send("#{type}_field", field[:name], class: "mt-2 block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-900 shadow-sm transition placeholder:text-slate-400 focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50") %>
        <% end %>

        <% if field[:hint].present? %>
          <p class="mt-2 text-xs font-semibold text-slate-500"><%= field[:hint] %></p>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if quote_form %>
    <div class="overflow-hidden rounded-[1.75rem] border border-blue-100 bg-[radial-gradient(circle_at_top_right,_#eff6ff,_transparent_26rem),#f8fbff] shadow-xl shadow-blue-100/50">
      <div class="border-b border-blue-100/80 bg-white/60 px-5 py-4 lg:px-6">
        <p class="text-xs font-black uppercase tracking-[0.18em] text-blue-600">Quote Builder</p>
        <h2 class="mt-2 text-xl font-black text-slate-950">Line Items</h2>
        <p class="mt-1 text-sm font-medium text-slate-600">Add services or custom charges. Totals are calculated when the quote is saved.</p>
      </div>

      <div class="space-y-4 p-4 lg:p-6">
        <%= form.fields_for :quote_items do |item_form| %>
          <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:border-blue-100 hover:shadow-xl hover:shadow-blue-100/50">
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-6">
              <div>
                <%= item_form.label :item_type, "Type", class: "block text-[0.68rem] font-black uppercase tracking-[0.14em] text-slate-500" %>
                <%= item_form.select :item_type, QuoteItem::ITEM_TYPES, {}, class: "mt-2 block w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2.5 text-sm font-semibold focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50" %>
              </div>
              <div class="sm:col-span-2">
                <%= item_form.label :name, "Name", class: "block text-[0.68rem] font-black uppercase tracking-[0.14em] text-slate-500" %>
                <%= item_form.text_field :name, list: "service-names", class: "mt-2 block w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2.5 text-sm font-semibold focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50" %>
              </div>
              <div>
                <%= item_form.label :quantity, "Qty", class: "block text-[0.68rem] font-black uppercase tracking-[0.14em] text-slate-500" %>
                <%= item_form.number_field :quantity, step: 0.01, class: "mt-2 block w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2.5 text-sm font-semibold focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50", data: { quote_calculator_target: "quantity", action: "input->quote-calculator#calculate" } %>
              </div>
              <div>
                <%= item_form.label :unit_price, "Unit price", class: "block text-[0.68rem] font-black uppercase tracking-[0.14em] text-slate-500" %>
                <%= item_form.number_field :unit_price, step: 0.01, class: "mt-2 block w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2.5 text-sm font-semibold focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50", data: { quote_calculator_target: "unitPrice", action: "input->quote-calculator#calculate" } %>
              </div>
              <div class="flex items-end">
                <label class="flex w-full items-center justify-center gap-2 rounded-xl border border-rose-100 bg-rose-50 px-3 py-2.5 text-sm font-black text-rose-700">
                  <%= item_form.check_box :_destroy, class: "h-4 w-4 rounded border-rose-300 text-rose-600" %>
                  Remove
                </label>
              </div>
            </div>
            <div class="mt-4">
              <%= item_form.label :description, "Description", class: "block text-[0.68rem] font-black uppercase tracking-[0.14em] text-slate-500" %>
              <%= item_form.text_area :description, rows: 2, class: "mt-2 block w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2.5 text-sm font-semibold focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50" %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="grid gap-3 border-t border-blue-100/80 bg-white/60 p-4 sm:grid-cols-2 lg:p-6">
        <div class="rounded-2xl border border-blue-100 bg-white p-4 shadow-sm">
          <p class="text-xs font-black uppercase tracking-[0.22em] text-slate-500">Live subtotal</p>
          <p class="mt-2 text-2xl font-black text-slate-950" data-quote-calculator-target="subtotal">$0.00</p>
        </div>
        <div class="rounded-2xl border border-blue-400/20 bg-slate-950 p-4 text-white shadow-2xl shadow-slate-900/20">
          <p class="text-xs font-black uppercase tracking-[0.22em] text-cyan-100">Live total</p>
          <p class="mt-2 text-2xl font-black" data-quote-calculator-target="total">$0.00</p>
        </div>
      </div>

      <datalist id="service-names">
        <% Service.order(:name).each do |service| %>
          <option value="<%= service.name %>"></option>
        <% end %>
      </datalist>
    </div>
  <% end %>

  <div class="flex flex-col-reverse gap-3 border-t border-slate-100 pt-6 sm:flex-row sm:items-center sm:justify-between">
    <%= link_to polymorphic_path([ :admin, resource_model ]), class: "inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-white px-5 py-3 text-sm font-black text-slate-700 shadow-sm transition hover:bg-slate-50" do %>
      <i class="fa-solid fa-xmark text-xs"></i>
      Cancel
    <% end %>
    <%= form.submit class: "rounded-2xl bg-blue-600 px-6 py-3 text-sm font-black text-white shadow-xl shadow-blue-600/20 transition hover:bg-blue-700" %>
  </div>
<% end %>
