<% content_for :title, "#{resource_title} | M&W Labs Control Center" %>

<div class="space-y-6" data-controller="table-filter">
  <div class="relative overflow-hidden rounded-[2rem] border border-blue-100 bg-[radial-gradient(circle_at_top_right,_#eff6ff,_transparent_28rem),linear-gradient(180deg,_#ffffff_0%,_#f8fbff_100%)] p-6 shadow-sm lg:p-8">
    <div class="absolute left-8 top-8 z-0 h-40 w-40 rounded-full bg-blue-100/70 blur-3xl"></div>
    <div class="relative flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <div class="inline-flex items-center gap-2 rounded-full border border-blue-100 bg-white px-4 py-2 text-[0.68rem] font-extrabold uppercase tracking-[0.18em] text-blue-700 shadow-sm">
          M&W Labs Control Center
          <span class="flex h-5 w-5 items-center justify-center rounded-full bg-blue-50 text-blue-600">+</span>
        </div>
        <h1 class="mt-4 text-4xl font-black tracking-tight text-slate-950 lg:text-5xl"><%= resource_title %></h1>
        <p class="mt-3 max-w-2xl text-sm font-medium leading-7 text-slate-600"><%= resource_description %></p>
      </div>

      <%= link_to new_polymorphic_path([ :admin, resource_model ]), class: "inline-flex items-center justify-center rounded-xl bg-blue-600 px-5 py-3 text-sm font-extrabold text-white shadow-xl shadow-blue-600/20 hover:bg-blue-700" do %>
        New <%= resource_model.model_name.human %>
        <i class="fa-solid fa-arrow-right ms-3 text-xs"></i>
      <% end %>
    </div>
  </div>

  <div class="flex flex-col gap-3 rounded-[1.5rem] border border-slate-200 bg-white p-4 shadow-sm sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-sm font-black text-slate-950"><%= pluralize(@resources.size, resource_model.model_name.human.downcase) %></p>
      <p class="mt-1 text-xs font-semibold text-slate-500">Search filters the table instantly without leaving the page.</p>
    </div>

    <label class="relative block sm:w-80">
      <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-slate-400">
        <i class="fa-solid fa-magnifying-glass text-xs"></i>
      </span>
      <input type="search" placeholder="Search <%= resource_title.downcase %>..." class="block w-full rounded-xl border border-slate-200 bg-slate-50 py-3 pl-9 pr-3 text-sm font-semibold text-slate-800 outline-none transition focus:border-blue-200 focus:bg-white focus:ring-4 focus:ring-blue-50" data-table-filter-target="input" data-action="input->table-filter#filter">
    </label>
  </div>

  <div class="overflow-hidden rounded-[1.5rem] border border-slate-200 bg-white shadow-sm">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50">
          <tr>
            <% resource_columns.each do |column| %>
              <th class="px-5 py-4 text-left text-xs font-black uppercase tracking-[0.16em] text-slate-500"><%= column.to_s.humanize %></th>
            <% end %>
            <th class="px-5 py-4 text-right text-xs font-black uppercase tracking-[0.16em] text-slate-500">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @resources.each do |resource| %>
            <tr class="transition hover:bg-blue-50/60" data-table-filter-target="row">
              <% resource_columns.each do |column| %>
                <% value = field_value(resource, name: column) %>
                <td class="whitespace-nowrap px-5 py-4 font-semibold text-slate-700">
                  <% if column.to_s == "status" %>
                    <span class="inline-flex rounded-full px-2.5 py-1 text-xs font-semibold ring-1 <%= admin_status_class(value) %>"><%= admin_value(value) %></span>
                  <% else %>
                    <%= admin_value(value) %>
                  <% end %>
                </td>
              <% end %>
              <td class="whitespace-nowrap px-5 py-4 text-right">
                <%= link_to "View", polymorphic_path([ :admin, resource ]), class: "rounded-lg bg-blue-50 px-3 py-2 text-xs font-extrabold text-blue-700 hover:bg-blue-100" %>
                <%= link_to "Edit", edit_polymorphic_path([ :admin, resource ]), class: "ml-2 rounded-lg bg-slate-100 px-3 py-2 text-xs font-extrabold text-slate-700 hover:bg-slate-200" %>
              </td>
            </tr>
          <% end %>

          <% if @resources.empty? %>
            <tr>
              <td colspan="<%= resource_columns.size + 1 %>" class="px-4 py-16 text-center">
                <div class="mx-auto max-w-sm">
                  <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-50 text-blue-600">
                    <i class="fa-solid fa-inbox text-xl"></i>
                  </div>
                  <p class="mt-4 text-sm font-black text-slate-900">No records yet</p>
                  <p class="mt-1 text-sm font-medium text-slate-500">Create the first <%= resource_model.model_name.human.downcase %> to start tracking this workflow.</p>
                </div>
              </td>
            </tr>
          <% end %>

          <tr class="hidden" data-table-filter-target="empty">
            <td colspan="<%= resource_columns.size + 1 %>" class="px-4 py-12 text-center font-semibold text-slate-500">No matching records found.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
