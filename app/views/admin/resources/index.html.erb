<% content_for :title, "#{resource_title} | M&W Labs Control Center" %>
<% content_for :meta_description, resource_description %>

<div class="space-y-6" data-controller="table-filter">
  <section class="relative overflow-hidden rounded-[2.25rem] border border-white/80 bg-slate-950 p-6 text-white shadow-2xl shadow-slate-900/20 lg:p-8">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(56,189,248,0.35),_transparent_28rem),radial-gradient(circle_at_bottom_left,_rgba(37,99,235,0.3),_transparent_22rem)]"></div>
    <div class="relative flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between">
      <div class="min-w-0">
        <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-[0.68rem] font-black uppercase tracking-[0.2em] text-cyan-100 backdrop-blur">
          <i class="fa-solid <%= admin_resource_icon(resource_model) %>"></i>
          <%= resource_model.model_name.human %> Workspace
        </div>
        <h1 class="mt-5 text-4xl font-black tracking-tight md:text-5xl"><%= resource_title %></h1>
        <p class="mt-3 max-w-3xl text-sm font-semibold leading-7 text-slate-300 md:text-base"><%= resource_description %></p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
        <div class="rounded-2xl border border-white/10 bg-white/10 px-5 py-4 backdrop-blur">
          <p class="text-[0.68rem] font-black uppercase tracking-[0.16em] text-slate-300">Records</p>
          <p class="mt-1 text-3xl font-black"><%= @resources.size %></p>
        </div>
        <% if can_manage_resource?(resource_model) %>
          <% if resource_model == Lead %>
            <%= link_to import_admin_leads_path, class: "inline-flex items-center justify-center gap-2 rounded-2xl border border-white/15 bg-white/10 px-5 py-3.5 text-sm font-black text-white backdrop-blur transition hover:bg-white/15" do %>
              Import CSV / Excel
              <i class="fa-solid fa-file-arrow-up text-xs"></i>
            <% end %>
          <% end %>
          <%= link_to new_polymorphic_path([ :admin, resource_model ]), class: "inline-flex items-center justify-center gap-2 rounded-2xl bg-white px-5 py-3.5 text-sm font-black text-slate-950 shadow-xl shadow-black/10 transition hover:-translate-y-0.5 hover:bg-blue-50" do %>
            New <%= resource_model.model_name.human %>
            <i class="fa-solid fa-plus text-xs"></i>
          <% end %>
        <% end %>
      </div>
    </div>
  </section>

  <section class="flex flex-col gap-4 rounded-[1.75rem] border border-white bg-white/90 p-4 shadow-xl shadow-slate-200/70 backdrop-blur sm:flex-row sm:items-center sm:justify-between lg:p-5">
    <div>
      <p class="text-sm font-black text-slate-950"><%= pluralize(@resources.size, resource_model.model_name.human.downcase) %></p>
      <p class="mt-1 text-xs font-semibold text-slate-500">Search filters the list instantly without leaving the page.</p>
    </div>

    <label class="relative block w-full sm:max-w-md">
      <span class="pointer-events-none absolute inset-y-0 left-4 flex items-center text-slate-400">
        <i class="fa-solid fa-magnifying-glass text-sm"></i>
      </span>
      <input type="search" placeholder="Search <%= resource_title.downcase %>..." class="block w-full rounded-2xl border border-slate-200 bg-slate-50 py-3.5 pl-11 pr-4 text-sm font-semibold text-slate-800 outline-none transition focus:border-blue-200 focus:bg-white focus:ring-4 focus:ring-blue-50" data-table-filter-target="input" data-action="input->table-filter#filter">
    </label>
  </section>

  <div class="space-y-3 lg:hidden">
    <% @resources.each do |resource| %>
      <% primary_column = visible_resource_columns.first %>
      <% status_column = visible_resource_columns.find { |column| column.to_s == "status" } %>
      <article class="rounded-[1.5rem] border border-slate-100 bg-white p-4 shadow-lg shadow-slate-200/60 transition hover:border-blue-100 hover:shadow-blue-100/50" data-table-filter-target="row">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <p class="truncate text-base font-black text-slate-950"><%= admin_value(field_value(resource, name: primary_column)) %></p>
            <% if status_column %>
              <% status_value = field_value(resource, name: status_column) %>
              <span class="mt-2 inline-flex rounded-full px-2.5 py-1 text-xs font-black ring-1 <%= admin_status_class(status_value) %>"><%= admin_value(status_value) %></span>
            <% end %>
          </div>
          <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-blue-50 text-blue-600">
            <i class="fa-solid <%= admin_resource_icon(resource_model) %> text-sm"></i>
          </span>
        </div>

        <dl class="mt-4 grid gap-2 sm:grid-cols-2">
          <% visible_resource_columns.drop(1).each do |column| %>
            <% next if column == status_column %>
            <% value = field_value(resource, name: column) %>
            <div class="rounded-xl bg-slate-50 px-3 py-2">
              <dt class="text-[0.65rem] font-black uppercase tracking-[0.14em] text-slate-400"><%= column.to_s.humanize %></dt>
              <dd class="mt-1 truncate text-sm font-semibold text-slate-700"><%= admin_value(value) %></dd>
            </div>
          <% end %>
        </dl>

        <div class="mt-4 flex gap-2">
          <%= link_to "View", polymorphic_path([ :admin, resource ]), class: "flex-1 rounded-xl bg-slate-950 px-3 py-2.5 text-center text-xs font-black text-white shadow-lg shadow-slate-900/10" %>
          <% if resource.is_a?(FileUpload) && admin_file_download_allowed?(resource) %>
            <%= link_to "Download", download_admin_file_upload_path(resource), class: "flex-1 rounded-xl border border-blue-100 bg-blue-50 px-3 py-2.5 text-center text-xs font-black text-blue-700" %>
          <% end %>
          <% if can_manage_resource?(resource_model) %>
            <%= link_to "Edit", edit_polymorphic_path([ :admin, resource ]), class: "flex-1 rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-center text-xs font-black text-slate-700" %>
            <% if resource_model == Lead %>
              <%= button_to "Delete", polymorphic_path([ :admin, resource ]), method: :delete, form: { data: { turbo_confirm: "Delete this lead?" }, class: "flex-1" }, class: "w-full rounded-xl border border-rose-100 bg-rose-50 px-3 py-2.5 text-center text-xs font-black text-rose-700 hover:bg-rose-100" %>
            <% end %>
          <% end %>
        </div>
      </article>
    <% end %>

    <% if @resources.empty? %>
      <div class="rounded-[1.75rem] border border-dashed border-slate-200 bg-white px-6 py-16 text-center shadow-sm">
        <span class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-50 text-blue-600">
          <i class="fa-solid fa-inbox text-xl"></i>
        </span>
        <p class="mt-4 text-sm font-black text-slate-900">No records yet</p>
        <p class="mt-1 text-sm font-medium text-slate-500">Create the first <%= resource_model.model_name.human.downcase %> to start tracking this workflow.</p>
      </div>
    <% end %>

    <div class="hidden rounded-[1.5rem] border border-dashed border-slate-200 bg-white px-6 py-12 text-center text-sm font-semibold text-slate-500" data-table-filter-target="empty">
      No matching records found.
    </div>
  </div>

  <section class="hidden overflow-hidden rounded-[1.75rem] border border-white bg-white/90 shadow-xl shadow-slate-200/70 backdrop-blur lg:block">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50/80">
          <tr>
            <% visible_resource_columns.each do |column| %>
              <th class="px-5 py-4 text-left text-xs font-black uppercase tracking-[0.16em] text-slate-500"><%= column.to_s.humanize %></th>
            <% end %>
            <th class="px-5 py-4 text-right text-xs font-black uppercase tracking-[0.16em] text-slate-500">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @resources.each do |resource| %>
            <tr class="transition hover:bg-blue-50/50" data-table-filter-target="row">
              <% visible_resource_columns.each do |column| %>
                <% value = field_value(resource, name: column) %>
                <td class="whitespace-nowrap px-5 py-4 font-semibold text-slate-700">
                  <% if column.to_s == "status" %>
                    <span class="inline-flex rounded-full px-2.5 py-1 text-xs font-black ring-1 <%= admin_status_class(value) %>"><%= admin_value(value) %></span>
                  <% else %>
                    <%= admin_value(value) %>
                  <% end %>
                </td>
              <% end %>
              <td class="whitespace-nowrap px-5 py-4 text-right">
                <div class="inline-flex items-center gap-2">
                  <%= link_to "View", polymorphic_path([ :admin, resource ]), class: "rounded-xl bg-slate-950 px-3 py-2 text-xs font-black text-white shadow-lg shadow-slate-900/10 hover:bg-blue-700" %>
                  <% if resource.is_a?(FileUpload) && admin_file_download_allowed?(resource) %>
                    <%= link_to "Download", download_admin_file_upload_path(resource), class: "rounded-xl border border-blue-100 bg-blue-50 px-3 py-2 text-xs font-black text-blue-700 hover:bg-blue-100" %>
                  <% end %>
                  <% if can_manage_resource?(resource_model) %>
                    <%= link_to "Edit", edit_polymorphic_path([ :admin, resource ]), class: "rounded-xl border border-slate-200 bg-white px-3 py-2 text-xs font-black text-slate-700 hover:bg-slate-50" %>
                    <% if resource_model == Lead %>
                      <%= button_to "Delete", polymorphic_path([ :admin, resource ]), method: :delete, form: { data: { turbo_confirm: "Delete this lead?" } }, class: "rounded-xl border border-rose-100 bg-rose-50 px-3 py-2 text-xs font-black text-rose-700 hover:bg-rose-100" %>
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>

          <% if @resources.empty? %>
            <tr>
              <td colspan="<%= visible_resource_columns.size + 1 %>" class="px-4 py-16 text-center">
                <div class="mx-auto max-w-sm">
                  <span class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-50 text-blue-600">
                    <i class="fa-solid fa-inbox text-xl"></i>
                  </span>
                  <p class="mt-4 text-sm font-black text-slate-900">No records yet</p>
                  <p class="mt-1 text-sm font-medium text-slate-500">Create the first <%= resource_model.model_name.human.downcase %> to start tracking this workflow.</p>
                </div>
              </td>
            </tr>
          <% end %>

          <tr class="hidden" data-table-filter-target="empty">
            <td colspan="<%= visible_resource_columns.size + 1 %>" class="px-4 py-12 text-center font-semibold text-slate-500">No matching records found.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
</div>
