<%# Collapsible filter panel shared by all admin resource lists.
    Locals:
      resources          — the records being listed (used for counts and filter options)
      columns            — columns to build select filters for
      record_name        — singular human name, e.g. "lead"
      column_labels      — optional { column => "Label" } overrides
      select_change_action — optional extra Stimulus actions on the selects %>
<% column_labels = local_assigns.fetch(:column_labels, {}) %>
<% select_change_action = local_assigns.fetch(:select_change_action, "change->table-filter#filter") %>

<details class="group rounded-[1.75rem] border border-slate-200 bg-white/95 shadow-xl shadow-slate-200/70 backdrop-blur">
  <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-5 py-4 lg:px-6">
    <div class="flex min-w-0 items-center gap-3">
      <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-slate-100 text-slate-600 transition group-open:bg-blue-600 group-open:text-white">
        <i class="fa-solid fa-sliders text-sm"></i>
      </span>
      <div class="min-w-0">
        <h2 class="truncate text-sm font-black tracking-tight text-slate-950">Search &amp; filters</h2>
        <p class="truncate text-xs font-semibold text-slate-500"><%= pluralize(resources.size, record_name) %> · results update instantly</p>
      </div>
    </div>

    <span class="inline-flex shrink-0 items-center gap-2 rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs font-black text-slate-600 transition group-open:border-blue-200 group-open:bg-blue-50 group-open:text-blue-700 sm:px-3.5">
      <span class="hidden sm:inline"><span class="group-open:hidden">Show filters</span><span class="hidden group-open:inline">Hide filters</span></span>
      <i class="fa-solid fa-chevron-down text-[0.65rem] transition duration-200 group-open:-rotate-180"></i>
    </span>
  </summary>

  <div class="space-y-4 border-t border-slate-100 p-5 lg:p-6">
    <div>
      <label for="resource-search" class="mb-1.5 block text-[0.65rem] font-black uppercase tracking-[0.14em] text-slate-400">Search</label>
      <div class="relative">
        <span class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center text-slate-400">
          <i class="fa-solid fa-magnifying-glass text-sm"></i>
        </span>
        <input id="resource-search" type="search" placeholder="Search all fields..." class="block h-11 w-full rounded-xl border border-slate-200 bg-slate-50 pl-10 pr-4 text-sm font-semibold text-slate-900 outline-none transition focus:border-blue-400 focus:bg-white focus:ring-4 focus:ring-blue-100/60" data-table-filter-target="input" data-action="input->table-filter#filter">
      </div>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      <% columns.each do |column| %>
        <% filter_options = resources.map { |resource| field_value(resource, name: column) }.compact.reject(&:blank?).map { |value| admin_value(value) }.uniq %>
        <div>
          <label for="filter-<%= column %>" class="mb-1.5 block truncate text-[0.65rem] font-black uppercase tracking-[0.14em] text-slate-400"><%= column_labels[column] || column.to_s.humanize %></label>
          <div class="relative">
            <select id="filter-<%= column %>" class="block h-11 w-full appearance-none rounded-xl border border-slate-200 bg-slate-50 px-3.5 pr-9 text-sm font-semibold text-slate-700 outline-none transition focus:border-blue-400 focus:bg-white focus:ring-4 focus:ring-blue-100/60" data-table-filter-target="filterInput" data-column="<%= column %>" data-action="<%= select_change_action %>">
              <option value="">All</option>
              <% filter_options.each do |option| %>
                <option value="<%= option.to_s.downcase %>"><%= option %></option>
              <% end %>
            </select>
            <span class="pointer-events-none absolute inset-y-0 right-3 flex items-center text-slate-400">
              <i class="fa-solid fa-chevron-down text-xs"></i>
            </span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</details>
