<% content_for :title, "New #{resource_model.model_name.human} | M&W Labs Control Center" %>
<% content_for :meta_description, "Create a new #{resource_model.model_name.human.downcase} in the M&W Labs Control Center. #{resource_description}" %>

<div class="mx-auto w-full max-w-5xl space-y-6">
  <section class="relative overflow-hidden rounded-[2.25rem] border border-white/80 bg-slate-950 p-6 text-white shadow-2xl shadow-slate-900/20 lg:p-8">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(56,189,248,0.35),_transparent_28rem),radial-gradient(circle_at_bottom_left,_rgba(37,99,235,0.3),_transparent_22rem)]"></div>
    <div class="relative">
      <%= link_to polymorphic_path([ :admin, resource_model ]), class: "inline-flex items-center gap-2 text-sm font-black text-cyan-100 transition hover:text-white" do %>
        <i class="fa-solid fa-arrow-left text-xs"></i>
        Back to <%= resource_title %>
      <% end %>
      <div class="mt-5 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-[0.68rem] font-black uppercase tracking-[0.2em] text-cyan-100 backdrop-blur">
        <i class="fa-solid <%= admin_resource_icon(resource_model) %>"></i>
        Create <%= resource_model.model_name.human.downcase %>
      </div>
      <h1 class="mt-5 text-4xl font-black tracking-tight md:text-5xl">New <%= resource_model.model_name.human %></h1>
      <p class="mt-3 max-w-3xl text-sm font-semibold leading-7 text-slate-300"><%= resource_description %></p>
    </div>
  </section>

  <section class="overflow-hidden rounded-[1.75rem] border border-white bg-white/90 p-5 shadow-xl shadow-slate-200/70 backdrop-blur lg:p-6">
    <%= render "admin/resources/form" %>
  </section>
</div>
