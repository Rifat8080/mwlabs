<% if activity_logs.present? %>
  <details class="group rounded-[1.75rem] border border-slate-200 bg-white/90 p-5 shadow-xl shadow-slate-200/70 backdrop-blur lg:p-6">
    <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
      <div>
        <p class="text-xs font-black uppercase tracking-[0.18em] text-blue-600">Timeline</p>
        <h2 class="mt-2 text-lg font-black text-slate-950">Activity</h2>
      </div>
      <span class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-3 py-1.5 text-sm font-black text-slate-600 transition group-open:border-blue-200 group-open:bg-blue-50 group-open:text-blue-700">
        Show history
        <i class="fa-solid fa-chevron-down text-xs transition duration-200 group-open:-rotate-180"></i>
      </span>
    </summary>

    <div class="mt-5 space-y-4">
      <% activity_logs.each do |log| %>
        <div class="relative rounded-2xl border border-slate-100 bg-slate-50/80 p-4 pl-5">
          <span class="absolute left-0 top-0 h-full w-1 rounded-l-2xl bg-blue-500"></span>
          <p class="text-sm font-black text-slate-900"><%= log.action %></p>
          <p class="mt-1 text-xs font-semibold text-slate-500"><%= log.created_at.to_fs(:long) %> by <%= log.user&.display_name || "System" %></p>
          <% if log.details.present? %>
            <p class="mt-2 text-sm font-medium leading-6 text-slate-600"><%= sanitize(log.details) %></p>
          <% end %>
        </div>
      <% end %>
    </div>
  </details>
<% end %>
