<% content_for :title, "#{resource_model.model_name.human} | M&W Labs Control Center" %>

<div class="space-y-6">
  <% if @resource.is_a?(Quote) && @resource.negotiation_open? %>
    <div class="rounded-[1.5rem] border-2 border-amber-300 bg-amber-50 p-5 shadow-xl shadow-amber-100">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div class="flex gap-4">
          <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-amber-500 text-white shadow-lg shadow-amber-200">
            <i class="fa-solid fa-triangle-exclamation"></i>
          </span>
          <div>
            <p class="text-xs font-black uppercase tracking-[0.2em] text-amber-700">Action required before acceptance</p>
            <h2 class="mt-1 text-xl font-black text-slate-950">Open quote negotiation</h2>
            <p class="mt-1 text-sm font-semibold leading-6 text-amber-900">
              Acceptance is locked until M&W Labs responds and marks this negotiation as ready for acceptance.
              Current response owner: <strong><%= @resource.awaiting_response_from %></strong>.
            </p>
          </div>
        </div>
        <a href="#quote-negotiation" class="inline-flex items-center justify-center rounded-xl bg-amber-600 px-5 py-3 text-sm font-extrabold text-white shadow-lg shadow-amber-200 hover:bg-amber-700">
          Review negotiation
        </a>
      </div>
    </div>
  <% end %>

  <div class="flex flex-col gap-4 rounded-[2rem] border border-blue-100 bg-[radial-gradient(circle_at_top_right,_#eff6ff,_transparent_24rem),#ffffff] p-6 shadow-sm sm:flex-row sm:items-end sm:justify-between lg:p-8">
    <div>
      <%= link_to "← Back to #{resource_title}", polymorphic_path([ :admin, resource_model ]), class: "text-sm font-extrabold text-blue-600 hover:text-blue-700" %>
      <h1 class="mt-3 text-4xl font-black tracking-tight text-slate-950 lg:text-5xl"><%= @resource.try(:display_name) || resource_model.model_name.human %></h1>
      <p class="mt-2 text-sm font-medium leading-7 text-slate-600"><%= resource_description %></p>
    </div>

    <div class="flex flex-wrap gap-3">
      <% if @resource.is_a?(Quote) %>
        <%= link_to "Download PDF", pdf_admin_quote_path(@resource), class: "rounded-xl border border-blue-200 bg-blue-50 px-4 py-2 text-sm font-extrabold text-blue-700 shadow-sm hover:bg-blue-100" %>
        <%= link_to "Negotiation", "#quote-negotiation", class: "rounded-xl border border-amber-200 bg-amber-50 px-4 py-2 text-sm font-extrabold text-amber-800 shadow-sm hover:bg-amber-100" %>

        <% if @resource.decision_closed? %>
          <span class="rounded-xl border <%= @resource.accepted? ? 'border-emerald-200 bg-emerald-50 text-emerald-700' : 'border-slate-200 bg-slate-50 text-slate-700' %> px-4 py-2 text-sm font-extrabold shadow-sm">
            <%= @resource.status %> quote
          </span>
        <% else %>
          <% if can_send_quote?(@resource) %>
            <%= button_to "Send quote", send_quote_admin_quote_path(@resource), method: :patch, class: "rounded-xl bg-blue-600 px-4 py-2 text-sm font-extrabold text-white shadow-lg shadow-blue-600/20 hover:bg-blue-700" %>
          <% end %>

          <% if can_decide_quote?(@resource) %>
            <% if @resource.acceptance_blocked_by_negotiation? %>
              <span class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-2 text-sm font-extrabold text-amber-800 shadow-sm" title="Resolve the open negotiation before accepting this quote.">Accept locked</span>
            <% else %>
              <%= button_to "Accept quote", accept_admin_quote_path(@resource), method: :patch, class: "rounded-xl bg-emerald-600 px-4 py-2 text-sm font-extrabold text-white shadow-lg shadow-emerald-600/20 hover:bg-emerald-700" %>
            <% end %>
            <%= button_to "Reject quote", reject_admin_quote_path(@resource), method: :patch, form: { data: { turbo_confirm: "Reject this quote?" } }, class: "rounded-xl border border-rose-200 bg-white px-4 py-2 text-sm font-extrabold text-rose-700 shadow-sm hover:bg-rose-50" %>
          <% end %>
        <% end %>
      <% end %>

      <% if can_manage_resource?(resource_model) && !(@resource.is_a?(Quote) && @resource.decision_closed?) %>
        <%= link_to "Edit", edit_polymorphic_path([ :admin, @resource ]), class: "rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-extrabold text-slate-700 shadow-sm hover:bg-slate-50" %>
        <%= button_to "Delete", polymorphic_path([ :admin, @resource ]), method: :delete, form: { data: { turbo_confirm: "Delete this record?" } }, class: "rounded-xl border border-rose-200 bg-white px-4 py-2 text-sm font-extrabold text-rose-700 shadow-sm hover:bg-rose-50" %>
      <% end %>
    </div>
  </div>

  <div class="grid gap-6 lg:grid-cols-3">
    <div class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm lg:col-span-2">
      <div class="flex items-center justify-between gap-4">
        <h2 class="text-lg font-black text-slate-950">Details</h2>
        <span class="rounded-full bg-slate-50 px-3 py-1 text-xs font-black uppercase tracking-[0.14em] text-slate-500"><%= resource_model.model_name.human %></span>
      </div>
      <dl class="mt-5 grid gap-4 md:grid-cols-2">
        <% visible_resource_fields.each do |field| %>
          <% next if field[:type] == :quote_items %>
          <% value = field_value(@resource, field) %>
          <div class="rounded-2xl bg-slate-50 p-4">
            <dt class="text-xs font-black uppercase tracking-[0.16em] text-slate-400"><%= admin_field_label(field) %></dt>
            <dd class="mt-2 text-sm font-semibold text-slate-900"><%= admin_value(value) %></dd>
          </div>
        <% end %>
      </dl>
    </div>

    <div class="space-y-6">
      <% if @resource.respond_to?(:next_action) %>
        <div class="rounded-[1.5rem] border border-amber-100 bg-amber-50 p-6 shadow-sm">
          <div class="flex items-start gap-3">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-white text-amber-600 shadow-sm">
              <i class="fa-solid fa-route"></i>
            </span>
            <div>
              <h2 class="text-lg font-black text-slate-950">Recommended Next Action</h2>
              <p class="mt-2 text-sm font-semibold leading-6 text-slate-700"><%= @resource.next_action %></p>
            </div>
          </div>
        </div>
      <% end %>

      <% if @resource.is_a?(Quote) %>
        <div class="rounded-[1.5rem] border border-blue-100 bg-blue-600 p-6 text-white shadow-xl shadow-blue-600/20">
          <h2 class="text-lg font-black">Quote Totals</h2>
          <div class="mt-4 space-y-2 text-sm text-blue-100">
            <div class="flex justify-between"><span>Subtotal</span><strong><%= number_to_currency(@resource.subtotal) %></strong></div>
            <div class="flex justify-between"><span>Discount</span><strong><%= number_to_currency(@resource.discount) %></strong></div>
            <div class="flex justify-between"><span>Tax</span><strong><%= number_to_currency(@resource.tax) %></strong></div>
            <div class="flex justify-between border-t border-blue-400/50 pt-3 text-base text-white"><span>Total</span><strong><%= number_to_currency(@resource.total_amount) %></strong></div>
          </div>
        </div>
      <% end %>

      <% if @activity_logs.present? %>
        <div class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-lg font-black text-slate-950">Activity Timeline</h2>
          <div class="mt-4 space-y-4">
            <% @activity_logs.each do |log| %>
              <div class="relative border-l-2 border-blue-200 pl-4">
                <span class="absolute -left-[5px] top-1 h-2 w-2 rounded-full bg-blue-600"></span>
                <p class="text-sm font-bold text-slate-900"><%= log.action %></p>
                <p class="mt-1 text-xs font-semibold text-slate-500"><%= log.created_at.to_fs(:long) %> by <%= log.user&.display_name || "System" %></p>
                <% if log.details.present? %>
                  <p class="mt-1 text-sm font-medium text-slate-600"><%= log.details %></p>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <% if @resource.is_a?(Quote) %>
    <%= render "admin/quotes/negotiation", quote: @resource %>
  <% end %>

  <% if @resource.is_a?(Quote) && @resource.quote_items.any? %>
    <div class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-black text-slate-950">Line Items</h2>
      <div class="mt-4 overflow-hidden rounded-2xl border border-slate-100">
        <table class="min-w-full divide-y divide-slate-100 text-sm">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-black uppercase tracking-[0.16em] text-slate-500">Item</th>
              <th class="px-4 py-3 text-left text-xs font-black uppercase tracking-[0.16em] text-slate-500">Qty</th>
              <th class="px-4 py-3 text-left text-xs font-black uppercase tracking-[0.16em] text-slate-500">Price</th>
              <th class="px-4 py-3 text-left text-xs font-black uppercase tracking-[0.16em] text-slate-500">Total</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @resource.quote_items.each do |item| %>
              <tr class="hover:bg-blue-50/50">
                <td class="px-4 py-4 font-black text-slate-950"><%= item.name %></td>
                <td class="px-4 py-4 font-semibold text-slate-700"><%= item.quantity %></td>
                <td class="px-4 py-4 font-semibold text-slate-700"><%= number_to_currency(item.unit_price) %></td>
                <td class="px-4 py-4 font-black text-slate-950"><%= number_to_currency(item.total) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>
