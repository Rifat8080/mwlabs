<% content_for :title, "#{resource_model.model_name.human} | M&W Labs Control Center" %>

<div class="space-y-6">
  <% if @resource.is_a?(Quote) && @resource.negotiation_open? %>
    <div class="rounded-[1.75rem] border-2 border-amber-300 bg-amber-50 p-5 shadow-xl shadow-amber-100 lg:p-6">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div class="flex gap-4">
          <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-amber-500 text-white shadow-lg shadow-amber-200">
            <i class="fa-solid fa-triangle-exclamation"></i>
          </span>
          <div>
            <p class="text-xs font-black uppercase tracking-[0.2em] text-amber-700">Action required before acceptance</p>
            <h2 class="mt-1 text-xl font-black text-slate-950">Open quote negotiation</h2>
            <p class="mt-1 text-sm font-semibold leading-6 text-amber-900">
              Acceptance is locked until M&W Labs responds and marks this negotiation as ready for acceptance.
              Current response owner: <strong><%= @resource.awaiting_response_from %></strong>.
            </p>
          </div>
        </div>
        <a href="#quote-negotiation" class="inline-flex items-center justify-center rounded-2xl bg-amber-600 px-5 py-3 text-sm font-black text-white shadow-lg shadow-amber-200 hover:bg-amber-700">
          Review negotiation
        </a>
      </div>
    </div>
  <% end %>

  <section class="relative overflow-hidden rounded-[2.25rem] border border-white/80 bg-slate-950 p-6 text-white shadow-2xl shadow-slate-900/20 lg:p-8">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(56,189,248,0.35),_transparent_28rem),radial-gradient(circle_at_bottom_left,_rgba(37,99,235,0.3),_transparent_22rem)]"></div>
    <div class="relative space-y-6">
      <%= link_to polymorphic_path([ :admin, resource_model ]), class: "inline-flex items-center gap-2 text-sm font-black text-cyan-100 transition hover:text-white" do %>
        <i class="fa-solid fa-arrow-left text-xs"></i>
        Back to <%= resource_title %>
      <% end %>

      <div class="flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between">
        <div class="min-w-0">
          <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-[0.68rem] font-black uppercase tracking-[0.2em] text-cyan-100 backdrop-blur">
            <i class="fa-solid <%= admin_resource_icon(resource_model) %>"></i>
            <%= resource_model.model_name.human %> record
          </div>
          <h1 class="mt-5 break-words text-4xl font-black tracking-tight md:text-5xl"><%= admin_resource_record_title(@resource) %></h1>
          <p class="mt-3 max-w-3xl text-sm font-semibold leading-7 text-slate-300"><%= resource_description %></p>
        </div>

        <div class="flex flex-wrap gap-2">
          <% if @resource.respond_to?(:status) && @resource.status.present? %>
            <span class="inline-flex rounded-full bg-white/10 px-3 py-1.5 text-xs font-black uppercase tracking-[0.14em] text-white ring-1 ring-white/15"><%= @resource.status %></span>
          <% end %>
          <% if @resource.is_a?(Project) %>
            <span class="inline-flex rounded-full bg-white/10 px-3 py-1.5 text-xs font-black text-white ring-1 ring-white/15"><%= @resource.progress %>% complete</span>
          <% end %>
        </div>
      </div>

      <div class="flex flex-wrap gap-2">
        <% if @resource.is_a?(Quote) %>
          <%= link_to "Download PDF", pdf_admin_quote_path(@resource), class: "inline-flex items-center gap-2 rounded-2xl border border-white/15 bg-white/10 px-4 py-2.5 text-sm font-black text-white backdrop-blur transition hover:bg-white/15" %>
          <%= link_to "Negotiation", "#quote-negotiation", class: "inline-flex items-center gap-2 rounded-2xl border border-amber-300/40 bg-amber-400/20 px-4 py-2.5 text-sm font-black text-amber-50 transition hover:bg-amber-400/30" %>

          <% if @resource.decision_closed? %>
            <span class="inline-flex items-center rounded-2xl border <%= @resource.accepted? ? 'border-emerald-300/40 bg-emerald-400/20 text-emerald-50' : 'border-white/15 bg-white/10 text-white' %> px-4 py-2.5 text-sm font-black">
              <%= @resource.status %> quote
            </span>
          <% else %>
            <% if can_send_quote?(@resource) %>
              <%= button_to "Send quote", send_quote_admin_quote_path(@resource), method: :patch, class: "rounded-2xl bg-white px-4 py-2.5 text-sm font-black text-slate-950 shadow-xl shadow-black/10 hover:bg-blue-50" %>
            <% end %>

            <% if can_decide_quote?(@resource) %>
              <% if @resource.acceptance_blocked_by_negotiation? %>
                <span class="inline-flex items-center rounded-2xl border border-amber-300/40 bg-amber-400/20 px-4 py-2.5 text-sm font-black text-amber-50" title="Resolve the open negotiation before accepting this quote.">Accept locked</span>
              <% else %>
                <%= button_to "Accept quote", accept_admin_quote_path(@resource), method: :patch, class: "rounded-2xl bg-emerald-500 px-4 py-2.5 text-sm font-black text-white shadow-lg shadow-emerald-500/20 hover:bg-emerald-600" %>
              <% end %>
              <%= button_to "Reject quote", reject_admin_quote_path(@resource), method: :patch, form: { data: { turbo_confirm: "Reject this quote?" } }, class: "rounded-2xl border border-rose-300/40 bg-rose-400/15 px-4 py-2.5 text-sm font-black text-rose-50 hover:bg-rose-400/25" %>
            <% end %>
          <% end %>
        <% end %>

        <% if @resource.is_a?(Project) %>
          <%= link_to "Project Tasks", "#project-tasks", class: "inline-flex items-center gap-2 rounded-2xl border border-white/15 bg-white/10 px-4 py-2.5 text-sm font-black text-white backdrop-blur transition hover:bg-white/15" %>
          <%= link_to "Project Files", "#project-files", class: "inline-flex items-center gap-2 rounded-2xl border border-white/15 bg-white/10 px-4 py-2.5 text-sm font-black text-white backdrop-blur transition hover:bg-white/15" %>
        <% end %>

        <% if @resource.is_a?(BlogPost) && @resource.published? %>
          <%= link_to blog_post_path(@resource.slug), target: "_blank", rel: "noopener", class: "inline-flex items-center gap-2 rounded-2xl bg-white px-4 py-2.5 text-sm font-black text-slate-950 shadow-xl shadow-black/10 transition hover:bg-blue-50" do %>
            <i class="fa-solid fa-arrow-up-right-from-square text-xs"></i>
            View live post
          <% end %>
        <% end %>

        <% if @resource.is_a?(FileUpload) %>
          <% if admin_file_download_allowed?(@resource) %>
            <%= link_to download_admin_file_upload_path(@resource), class: "inline-flex items-center gap-2 rounded-2xl bg-white px-4 py-2.5 text-sm font-black text-slate-950 shadow-xl shadow-black/10 transition hover:bg-blue-50" do %>
              <i class="fa-solid fa-download text-xs"></i>
              Download file
            <% end %>
          <% else %>
            <span class="inline-flex items-center gap-2 rounded-2xl border border-white/15 bg-white/10 px-4 py-2.5 text-sm font-black text-slate-200">
              <i class="fa-solid fa-lock text-xs"></i>
              Download locked
            </span>
          <% end %>
        <% end %>

        <% if @resource.present? && can_manage_resource?(resource_model) && !(@resource.is_a?(Quote) && @resource.decision_closed?) %>
          <%= link_to "Edit", edit_polymorphic_path([ :admin, @resource ]), class: "inline-flex items-center gap-2 rounded-2xl border border-white/15 bg-white/10 px-4 py-2.5 text-sm font-black text-white backdrop-blur transition hover:bg-white/15" %>
          <%= button_to "Delete", polymorphic_path([ :admin, @resource ]), method: :delete, form: { data: { turbo_confirm: "Delete this record?" } }, class: "rounded-2xl border border-rose-300/40 bg-rose-400/15 px-4 py-2.5 text-sm font-black text-rose-50 hover:bg-rose-400/25" %>
        <% end %>
      </div>
    </div>
  </section>

  <div class="grid gap-6 xl:grid-cols-3">
    <section class="rounded-[1.75rem] border border-white bg-white/90 p-5 shadow-xl shadow-slate-200/70 backdrop-blur lg:p-6 xl:col-span-2">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-xs font-black uppercase tracking-[0.18em] text-blue-600">Record Details</p>
          <h2 class="mt-2 text-xl font-black text-slate-950">Overview</h2>
        </div>
        <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-black uppercase tracking-[0.14em] text-slate-600"><%= resource_model.model_name.human %></span>
      </div>

      <dl class="mt-5 grid gap-4 sm:grid-cols-2">
        <% visible_resource_fields.each do |field| %>
          <% next if field[:type] == :quote_items %>
          <% next if @resource.is_a?(BlogPost) && field[:name] == :body %>
          <% value = field_value(@resource, field) %>
          <div class="rounded-2xl border border-slate-100 bg-slate-50/80 p-4 transition hover:border-blue-100 hover:bg-white">
            <dt class="text-[0.68rem] font-black uppercase tracking-[0.16em] text-slate-400"><%= admin_field_label(field) %></dt>
            <dd class="mt-2 break-words text-sm font-semibold text-slate-900"><%= admin_value(value) %></dd>
          </div>
        <% end %>
      </dl>
    </section>

    <div class="space-y-6">
      <% if @resource.respond_to?(:next_action) %>
        <section class="rounded-[1.75rem] border border-amber-100 bg-amber-50/80 p-5 shadow-lg shadow-amber-100/40 lg:p-6">
          <div class="flex items-start gap-3">
            <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-white text-amber-600 shadow-sm">
              <i class="fa-solid fa-route"></i>
            </span>
            <div>
              <p class="text-xs font-black uppercase tracking-[0.16em] text-amber-700">Recommended Next Action</p>
              <p class="mt-2 text-sm font-semibold leading-6 text-slate-700"><%= @resource.next_action %></p>
            </div>
          </div>
        </section>
      <% end %>

      <% if @resource.is_a?(FileUpload) %>
        <section class="rounded-[1.75rem] border border-white bg-white/90 p-5 shadow-xl shadow-slate-200/70 backdrop-blur lg:p-6">
          <div class="flex items-start gap-3">
            <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-blue-50 text-blue-600 shadow-sm">
              <i class="fa-solid fa-file-arrow-down"></i>
            </span>
            <div class="min-w-0">
              <p class="text-xs font-black uppercase tracking-[0.16em] text-blue-600">Attached File</p>
              <h2 class="mt-2 break-words text-lg font-black text-slate-950"><%= @resource.display_name %></h2>
              <div class="mt-3 space-y-2 text-sm font-semibold text-slate-600">
                <p><span class="text-slate-400">Size:</span> <%= admin_file_size(@resource) %></p>
                <p><span class="text-slate-400">Type:</span> <%= @resource.content_type.presence || "Unknown" %></p>
                <p><span class="text-slate-400">Project:</span> <%= admin_value(@resource.project) %></p>
                <p><span class="text-slate-400">Task:</span> <%= admin_value(@resource.task) %></p>
              </div>
              <% if admin_file_download_allowed?(@resource) %>
                <%= link_to download_admin_file_upload_path(@resource), class: "mt-4 inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-blue-600 px-4 py-3 text-sm font-black text-white shadow-xl shadow-blue-600/20 transition hover:bg-blue-700" do %>
                  <i class="fa-solid fa-download text-xs"></i>
                  Download to your computer
                <% end %>
              <% else %>
                <p class="mt-4 rounded-2xl border border-amber-100 bg-amber-50 px-4 py-3 text-sm font-bold text-amber-800">This file is visible, but downloading is disabled.</p>
              <% end %>
            </div>
          </div>
        </section>
      <% end %>

      <% if @resource.is_a?(Quote) %>
        <section class="relative overflow-hidden rounded-[1.75rem] border border-blue-400/20 bg-slate-950 p-5 text-white shadow-2xl shadow-slate-900/20 lg:p-6">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(59,130,246,0.45),_transparent_18rem)]"></div>
          <div class="relative">
            <p class="text-xs font-black uppercase tracking-[0.18em] text-cyan-100">Quote Totals</p>
            <div class="mt-4 space-y-2 text-sm">
              <div class="flex justify-between gap-4"><span class="text-slate-300">Subtotal</span><strong><%= number_to_currency(@resource.subtotal) %></strong></div>
              <div class="flex justify-between gap-4"><span class="text-slate-300">Discount</span><strong><%= number_to_currency(@resource.discount) %></strong></div>
              <div class="flex justify-between gap-4"><span class="text-slate-300">Tax</span><strong><%= number_to_currency(@resource.tax) %></strong></div>
              <div class="flex justify-between gap-4 border-t border-white/10 pt-3 text-base"><span class="text-slate-300">Total</span><strong><%= number_to_currency(@resource.total_amount) %></strong></div>
            </div>
          </div>
        </section>
      <% end %>

      <% if @resource.is_a?(BlogPost) && @resource.cover_image.attached? %>
        <section class="rounded-[1.75rem] border border-white bg-white/90 p-5 shadow-xl shadow-slate-200/70 backdrop-blur lg:p-6">
          <p class="text-xs font-black uppercase tracking-[0.18em] text-blue-600">Cover Image</p>
          <div class="mt-4 overflow-hidden rounded-2xl border border-slate-100">
            <%= image_tag @resource.cover_image.variant(resize_to_limit: [ 960, 540 ]), class: "w-full object-cover", alt: @resource.title %>
          </div>
        </section>
      <% end %>

      <% if @activity_logs.present? %>
        <section class="rounded-[1.75rem] border border-white bg-white/90 p-5 shadow-xl shadow-slate-200/70 backdrop-blur lg:p-6">
          <p class="text-xs font-black uppercase tracking-[0.18em] text-blue-600">Timeline</p>
          <h2 class="mt-2 text-lg font-black text-slate-950">Activity</h2>
          <div class="mt-4 space-y-4">
            <% @activity_logs.each do |log| %>
              <div class="relative rounded-2xl border border-slate-100 bg-slate-50/80 p-4 pl-5">
                <span class="absolute left-0 top-0 h-full w-1 rounded-l-2xl bg-blue-500"></span>
                <p class="text-sm font-black text-slate-900"><%= log.action %></p>
                <p class="mt-1 text-xs font-semibold text-slate-500"><%= log.created_at.to_fs(:long) %> by <%= log.user&.display_name || "System" %></p>
                <% if log.details.present? %>
                  <p class="mt-2 text-sm font-medium leading-6 text-slate-600"><%= sanitize(log.details) %></p>
                <% end %>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>
    </div>
  </div>

  <% if @resource.is_a?(Quote) %>
    <%= render "admin/quotes/negotiation", quote: @resource %>
  <% end %>

  <% if @resource.is_a?(Project) %>
    <%= render "admin/projects/tasks", project: @resource %>
    <%= render "admin/projects/files", project: @resource %>
  <% end %>

  <% if @resource.is_a?(Quote) && @resource.quote_items.any? %>
    <section class="overflow-hidden rounded-[1.75rem] border border-white bg-white/90 shadow-xl shadow-slate-200/70 backdrop-blur">
      <div class="border-b border-slate-100 bg-slate-50/70 px-5 py-4 lg:px-6">
        <p class="text-xs font-black uppercase tracking-[0.18em] text-blue-600">Pricing Breakdown</p>
        <h2 class="mt-2 text-xl font-black text-slate-950">Line Items</h2>
      </div>

      <div class="hidden overflow-x-auto lg:block">
        <table class="min-w-full divide-y divide-slate-100 text-sm">
          <thead class="bg-slate-50/80">
            <tr>
              <th class="px-5 py-4 text-left text-xs font-black uppercase tracking-[0.16em] text-slate-500">Item</th>
              <th class="px-5 py-4 text-left text-xs font-black uppercase tracking-[0.16em] text-slate-500">Qty</th>
              <th class="px-5 py-4 text-left text-xs font-black uppercase tracking-[0.16em] text-slate-500">Price</th>
              <th class="px-5 py-4 text-left text-xs font-black uppercase tracking-[0.16em] text-slate-500">Total</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @resource.quote_items.each do |item| %>
              <tr class="hover:bg-blue-50/40">
                <td class="px-5 py-4 font-black text-slate-950"><%= item.name %></td>
                <td class="px-5 py-4 font-semibold text-slate-700"><%= item.quantity %></td>
                <td class="px-5 py-4 font-semibold text-slate-700"><%= number_to_currency(item.unit_price) %></td>
                <td class="px-5 py-4 font-black text-slate-950"><%= number_to_currency(item.total) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="space-y-3 p-4 lg:hidden">
        <% @resource.quote_items.each do |item| %>
          <article class="rounded-2xl border border-slate-100 bg-slate-50 p-4">
            <p class="font-black text-slate-950"><%= item.name %></p>
            <div class="mt-3 grid grid-cols-3 gap-2 text-xs font-bold text-slate-500">
              <div class="rounded-xl bg-white p-3">
                <p class="text-slate-400">Qty</p>
                <p class="mt-1 text-slate-800"><%= item.quantity %></p>
              </div>
              <div class="rounded-xl bg-white p-3">
                <p class="text-slate-400">Price</p>
                <p class="mt-1 text-slate-800"><%= number_to_currency(item.unit_price) %></p>
              </div>
              <div class="rounded-xl bg-white p-3">
                <p class="text-slate-400">Total</p>
                <p class="mt-1 text-slate-800"><%= number_to_currency(item.total) %></p>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    </section>
  <% end %>

  <% if @resource.is_a?(BlogPost) %>
    <section class="overflow-hidden rounded-[1.75rem] border border-white bg-white/90 shadow-xl shadow-slate-200/70 backdrop-blur">
      <div class="border-b border-slate-100 bg-slate-50/70 px-5 py-4 lg:px-6">
        <p class="text-xs font-black uppercase tracking-[0.18em] text-blue-600">Article Content</p>
        <h2 class="mt-2 text-xl font-black text-slate-950">Body Preview</h2>
      </div>
      <div class="prose prose-slate max-w-none p-5 text-sm font-medium leading-7 text-slate-700 lg:p-6">
        <%= simple_format(sanitize(@resource.body)) %>
      </div>
    </section>
  <% end %>
</div>
