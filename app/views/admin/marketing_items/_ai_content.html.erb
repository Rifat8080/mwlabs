<div class="rounded-2xl border border-blue-200 bg-blue-50 p-5" id="marketing-item-ai-content">
  <p class="flex items-center gap-2 text-xs font-black uppercase tracking-[0.16em] text-blue-700">
    <i class="fa-solid fa-wand-magic-sparkles"></i> AI Draft
  </p>
  <div class="mt-3 whitespace-pre-line rounded-xl border border-blue-100 bg-white p-4 text-sm leading-7 text-slate-700"><%= content %></div>

  <div class="mt-4 flex flex-wrap gap-2">
    <% [ [ "regenerate", "Regenerate" ], [ "improve", "Improve" ], [ "shorten", "Shorten" ], [ "professional", "Make Professional" ], [ "engaging", "Make Engaging" ] ].each do |instruction, label| %>
      <%= button_to label, ai_rewrite_admin_marketing_item_path(marketing_item, instruction: instruction), method: :post, class: "rounded-lg border border-blue-200 bg-white px-3 py-2 text-xs font-black text-blue-700 hover:bg-blue-100" %>
    <% end %>
  </div>

  <%= form_with model: [ :admin, marketing_item ], method: :patch, class: "mt-4" do %>
    <%= hidden_field_tag "marketing_item[description]", content %>
    <button type="submit" class="rounded-xl bg-blue-600 px-4 py-2.5 text-sm font-black text-white shadow-lg shadow-blue-600/20 hover:bg-blue-700">Use This Content</button>
  <% end %>
</div>
