<% content_for :title, "Marketing Calendar | M&W Labs Control Center" %>
<% content_for :meta_description, resource_description %>

<div class="space-y-6">
  <section class="relative overflow-hidden rounded-[2.25rem] border border-white/80 bg-slate-950 p-6 text-white shadow-2xl shadow-slate-900/20 lg:p-8">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(56,189,248,0.35),_transparent_28rem),radial-gradient(circle_at_bottom_left,_rgba(37,99,235,0.3),_transparent_22rem)]"></div>
    <div class="relative flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between">
      <div class="min-w-0">
        <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-[0.68rem] font-black uppercase tracking-[0.2em] text-cyan-100 backdrop-blur">
          <i class="fa-solid fa-calendar-days"></i>
          Content Calendar
        </div>
        <h1 class="mt-5 text-4xl font-black tracking-tight md:text-5xl"><%= @month.strftime("%B %Y") %></h1>
        <p class="mt-3 max-w-3xl text-sm font-semibold leading-7 text-slate-300 md:text-base">Drag a card to a new day to reschedule it. Click a card to edit.</p>
      </div>

      <div class="flex flex-wrap gap-3">
        <%= link_to calendar_admin_marketing_items_path(month: (@month - 1.month).strftime("%Y-%m")), class: "inline-flex items-center gap-2 rounded-2xl border border-white/15 bg-white/10 px-4 py-3 text-sm font-black text-white backdrop-blur transition hover:bg-white/15" do %>
          <i class="fa-solid fa-chevron-left text-xs"></i> Prev
        <% end %>
        <%= link_to calendar_admin_marketing_items_path(month: Date.current.strftime("%Y-%m")), class: "inline-flex items-center gap-2 rounded-2xl border border-white/15 bg-white/10 px-4 py-3 text-sm font-black text-white backdrop-blur transition hover:bg-white/15" do %>
          Today
        <% end %>
        <%= link_to calendar_admin_marketing_items_path(month: (@month + 1.month).strftime("%Y-%m")), class: "inline-flex items-center gap-2 rounded-2xl border border-white/15 bg-white/10 px-4 py-3 text-sm font-black text-white backdrop-blur transition hover:bg-white/15" do %>
          Next <i class="fa-solid fa-chevron-right text-xs"></i>
        <% end %>
        <%= link_to admin_marketing_items_path, class: "inline-flex items-center gap-2 rounded-2xl border border-white/15 bg-white/10 px-4 py-3 text-sm font-black text-white backdrop-blur transition hover:bg-white/15" do %>
          <i class="fa-solid fa-table-list text-xs"></i> Table view
        <% end %>
        <%= link_to new_admin_marketing_item_path, class: "inline-flex items-center gap-2 rounded-2xl bg-white px-4 py-3 text-sm font-black text-slate-950 shadow-xl shadow-black/10 transition hover:-translate-y-0.5 hover:bg-blue-50" do %>
          New Item <i class="fa-solid fa-plus text-xs"></i>
        <% end %>
      </div>
    </div>
  </section>

  <div id="marketing-calendar">
    <%= render "admin/marketing_items/calendar_grid", month: @month, items_by_date: @items_by_date %>
  </div>
</div>
