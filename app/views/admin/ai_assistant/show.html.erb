<% content_for :title, "AI Assistant | M&W Labs Control Center" %>
<% content_for :meta_description, "Chat with the MW Labs AI operations assistant: plan your day, generate marketing ideas, and analyze your week." %>

<div class="space-y-6" data-controller="ai-assistant" data-ai-assistant-messages-url-value="<%= admin_ai_assistant_messages_path %>" data-ai-assistant-quick-action-url-value="<%= admin_ai_assistant_quick_action_path %>">
  <section class="relative overflow-hidden rounded-[2.25rem] border border-white/80 bg-slate-950 p-6 text-white shadow-2xl shadow-slate-900/20 lg:p-8">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(56,189,248,0.35),_transparent_28rem),radial-gradient(circle_at_bottom_left,_rgba(37,99,235,0.3),_transparent_22rem)]"></div>
    <div class="relative">
      <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-[0.68rem] font-black uppercase tracking-[0.2em] text-cyan-100 backdrop-blur">
        <i class="fa-solid fa-robot"></i>
        AI Assistant
      </div>
      <h1 class="mt-5 text-4xl font-black tracking-tight md:text-5xl">Your Agency Operations Assistant</h1>
      <p class="mt-3 max-w-3xl text-sm font-semibold leading-7 text-slate-300 md:text-base">Ask anything, or use a quick action to plan, generate, or analyze.</p>
    </div>
  </section>

  <div class="flex flex-wrap gap-2">
    <% [
      [ "plan_my_day", "Plan My Day", "fa-calendar-day" ],
      [ "marketing_ideas", "Generate Marketing Ideas", "fa-bullhorn" ],
      [ "analyze_my_week", "Analyze My Week", "fa-chart-line" ],
      [ "productivity_analysis", "Productivity Analysis", "fa-gauge-high" ]
    ].each do |action_name, label, icon| %>
      <button type="button" data-action-name="<%= action_name %>" data-action="click->ai-assistant#quickAction" class="inline-flex items-center gap-2 rounded-xl border border-blue-200 bg-blue-50 px-4 py-2.5 text-sm font-black text-blue-700 shadow-sm transition hover:bg-blue-100">
        <i class="fa-solid <%= icon %> text-xs"></i> <%= label %>
      </button>
    <% end %>
  </div>

  <section class="flex flex-col overflow-hidden rounded-[1.75rem] border border-white bg-white/90 shadow-xl shadow-slate-200/70 backdrop-blur">
    <div class="flex items-center justify-between border-b border-slate-100 px-5 py-4">
      <p class="text-xs font-black uppercase tracking-[0.16em] text-blue-600">Chat</p>
      <p class="text-xs font-bold text-slate-400" data-ai-assistant-target="status"></p>
    </div>

    <div class="max-h-[32rem] min-h-[16rem] space-y-4 overflow-y-auto p-5" data-ai-assistant-target="messages">
      <% @messages.each do |message| %>
        <div class="space-y-1" data-message-group>
          <div class="flex <%= message.role == "user" ? "justify-end" : "justify-start" %>">
            <div class="max-w-lg whitespace-pre-line rounded-2xl px-4 py-3 text-sm leading-6 shadow-sm <%= message.role == "user" ? "bg-blue-600 font-semibold text-white" : "border border-slate-200 bg-white font-medium text-slate-700" %>" data-message-content="<%= message.content %>">
              <%= message.content %>
            </div>
          </div>
          <% if message.role == "assistant" %>
            <div class="flex justify-start gap-3 pl-1">
              <button type="button" data-action="click->ai-assistant#copy" class="text-xs font-bold text-slate-400 transition hover:text-slate-600"><i class="fa-regular fa-copy"></i> Copy</button>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if @messages.empty? %>
        <p class="text-sm font-medium text-slate-400">Say hello, or try a quick action above.</p>
      <% end %>
    </div>

    <%= form_with url: "#", method: :post, data: { action: "submit->ai-assistant#submit" }, class: "flex items-center gap-3 border-t border-slate-100 p-4" do %>
      <textarea data-ai-assistant-target="input" rows="1" placeholder="Ask the AI assistant anything about your agency..." class="block w-full resize-none rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-medium text-slate-900 shadow-sm focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50"></textarea>
      <button type="submit" class="shrink-0 rounded-xl bg-blue-600 px-5 py-3 text-sm font-black text-white shadow-lg shadow-blue-600/20 hover:bg-blue-700"><i class="fa-solid fa-paper-plane"></i></button>
    <% end %>
  </section>
</div>
