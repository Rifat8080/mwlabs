<% content_for :title, "AI Employees | M&W Labs Control Center" %>
<% content_for :meta_description, "Run specialized AI agents to help manage MW Labs' daily operations, on the Gemini free tier." %>

<% agent_themes = [
  "from-blue-50 to-white text-blue-700 ring-blue-100",
  "from-cyan-50 to-white text-cyan-700 ring-cyan-100",
  "from-emerald-50 to-white text-emerald-700 ring-emerald-100",
  "from-indigo-50 to-white text-indigo-700 ring-indigo-100",
  "from-amber-50 to-white text-amber-700 ring-amber-100",
  "from-rose-50 to-white text-rose-700 ring-rose-100",
  "from-fuchsia-50 to-white text-fuchsia-700 ring-fuchsia-100"
] %>

<div class="space-y-6">
  <section class="relative overflow-hidden rounded-[2.25rem] border border-white/80 bg-slate-950 p-6 text-white shadow-2xl shadow-slate-900/20 lg:p-8">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(56,189,248,0.35),_transparent_28rem),radial-gradient(circle_at_bottom_left,_rgba(37,99,235,0.3),_transparent_22rem)]"></div>
    <div class="relative">
      <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-[0.68rem] font-black uppercase tracking-[0.2em] text-cyan-100 backdrop-blur">
        <i class="fa-solid fa-users-gear"></i>
        AI Employees
      </div>
      <h1 class="mt-5 text-4xl font-black tracking-tight md:text-5xl">Your AI Workforce</h1>
      <p class="mt-3 max-w-3xl text-sm font-semibold leading-7 text-slate-300 md:text-base">Specialized agents that plan, write, and report for MW Labs &mdash; running on the Gemini free tier.</p>

      <% if @usage_summary[:near_daily_limit] %>
        <div class="mt-5 inline-flex items-center gap-2 rounded-2xl border border-amber-300/30 bg-amber-400/10 px-4 py-3 text-xs font-black text-amber-200">
          <i class="fa-solid fa-triangle-exclamation"></i>
          Approaching today's free-tier request limit (<%= @usage_summary[:requests_today] %> used, <%= @usage_summary[:requests_today_pct] %>%).
        </div>
      <% end %>
    </div>

    <div class="relative mt-6 grid grid-cols-2 gap-3 lg:grid-cols-5">
      <% [
        [ "Requests today", @usage_summary[:requests_today] ],
        [ "Requests this month", @usage_summary[:requests_this_month] ],
        [ "Failed today", @usage_summary[:failed_requests_today] ],
        [ "Avg response", @usage_summary[:avg_duration_ms].present? ? "#{(@usage_summary[:avg_duration_ms] / 1000.0).round(1)}s" : "&mdash;".html_safe ],
        [ "Most used", @usage_summary[:most_used_feature].presence || "&mdash;".html_safe ]
      ].each do |label, value| %>
        <div class="rounded-2xl border border-white/10 bg-white/10 p-4">
          <p class="truncate text-[0.62rem] font-black uppercase tracking-[0.14em] text-slate-300"><%= label %></p>
          <p class="mt-2 truncate text-xl font-black text-white"><%= value %></p>
        </div>
      <% end %>
    </div>
  </section>

  <section class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
    <% @agents.each_with_index do |agent, index| %>
      <% theme = agent_themes[index % agent_themes.size] %>
      <% last_run = @latest_runs[agent[:key]] %>
      <%= link_to admin_ai_employee_path(agent[:key]), class: "group overflow-hidden rounded-[1.75rem] border border-white bg-gradient-to-br #{theme} p-5 shadow-xl shadow-slate-200/60 ring-1 transition hover:-translate-y-1 hover:shadow-2xl hover:shadow-blue-100/70" do %>
        <div class="flex items-start justify-between gap-4">
          <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-white text-current shadow-sm">
            <i class="fa-solid <%= agent[:icon] %>"></i>
          </span>
          <span class="rounded-full bg-white px-2.5 py-1 text-[0.65rem] font-black uppercase tracking-[0.14em] <%= last_run&.status == "error" ? "text-rose-500" : "text-emerald-500" %>">
            <%= last_run.present? ? last_run.status : "Not run yet" %>
          </span>
        </div>

        <p class="mt-4 text-base font-black text-slate-950"><%= agent[:name] %></p>
        <p class="mt-1 text-xs font-semibold leading-5 text-slate-500"><%= agent[:description] %></p>

        <div class="mt-5 grid grid-cols-3 gap-2 text-center text-[0.65rem] font-bold text-slate-500">
          <div class="rounded-xl bg-white p-2">
            <p class="text-slate-400">Runs</p>
            <p class="mt-1 text-sm font-black text-slate-800"><%= @run_counts[agent[:key]] || 0 %></p>
          </div>
          <div class="rounded-xl bg-white p-2">
            <p class="text-slate-400">Last run</p>
            <p class="mt-1 text-sm font-black text-slate-800"><%= last_run.present? ? time_ago_in_words(last_run.created_at) + " ago" : "never" %></p>
          </div>
          <div class="rounded-xl bg-white p-2">
            <p class="text-slate-400">Cost</p>
            <p class="mt-1 text-sm font-black text-emerald-600">$0.00</p>
          </div>
        </div>

        <div class="mt-5 flex items-center justify-between text-xs font-black text-current">
          Run Agent
          <i class="fa-solid fa-arrow-right transition group-hover:translate-x-1"></i>
        </div>
      <% end %>
    <% end %>
  </section>
</div>
