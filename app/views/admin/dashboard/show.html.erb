<% content_for :title, "Dashboard | M&W Labs Control Center" %>

<div class="space-y-8">
  <div class="relative overflow-hidden rounded-[2rem] border border-blue-100 bg-[radial-gradient(circle_at_top_right,_#eff6ff,_transparent_28rem),linear-gradient(180deg,_#ffffff_0%,_#f8fbff_100%)] p-6 shadow-sm">
    <div class="absolute right-0 top-0 h-64 w-64 rounded-full bg-cyan-100/60 blur-3xl"></div>
    <div class="relative">
      <div class="inline-flex items-center gap-2 rounded-full border border-blue-100 bg-white px-4 py-2 text-[0.68rem] font-extrabold uppercase tracking-[0.18em] text-blue-700 shadow-sm">
        M&W Labs Control Center
        <span class="flex h-5 w-5 items-center justify-center rounded-full bg-blue-50 text-blue-600">+</span>
      </div>
      <h1 class="mt-4 text-4xl font-black tracking-tight text-slate-950">Agency Operations Dashboard</h1>
      <p class="mt-3 max-w-3xl text-sm font-medium leading-7 text-slate-600">Manage clients, leads, quotes, projects, tasks, invoices, payments, expenses, and follow-ups from one internal control center.</p>
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <% @cards.each do |label, value| %>
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-blue-100 hover:shadow-xl hover:shadow-blue-100/60">
        <p class="text-xs font-black uppercase tracking-[0.18em] text-slate-400"><%= label %></p>
        <p class="mt-3 text-2xl font-black text-slate-950"><%= value %></p>
      </div>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-3">
    <section class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm xl:col-span-2">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-lg font-black text-slate-950">Lead Pipeline</h2>
          <p class="mt-1 text-sm font-medium text-slate-600">Current lead counts by sales stage.</p>
        </div>
        <%= link_to "Manage leads", admin_leads_path, class: "text-sm font-semibold text-blue-600 hover:text-blue-700" %>
      </div>

      <div class="mt-5 grid gap-3 md:grid-cols-3">
        <% @pipeline.each do |status, count| %>
          <div class="rounded-2xl bg-slate-50 p-4">
            <p class="text-sm font-bold text-slate-700"><%= status %></p>
            <p class="mt-2 text-2xl font-black text-slate-950"><%= count %></p>
          </div>
        <% end %>
      </div>
    </section>

    <section class="rounded-[1.5rem] border border-blue-100 bg-blue-600 p-6 text-white shadow-xl shadow-blue-600/20">
      <h2 class="text-lg font-black">Money Overview</h2>
      <div class="mt-5 space-y-3 text-sm">
        <div class="flex justify-between"><span class="text-blue-100">Income this month</span><strong><%= number_to_currency(@money[:income]) %></strong></div>
        <div class="flex justify-between"><span class="text-blue-100">Expenses this month</span><strong><%= number_to_currency(@money[:expenses]) %></strong></div>
        <div class="flex justify-between"><span class="text-blue-100">Profit this month</span><strong><%= number_to_currency(@money[:income] - @money[:expenses]) %></strong></div>
        <div class="flex justify-between border-t border-blue-400/50 pt-3"><span class="text-blue-100">Pending payment</span><strong><%= number_to_currency(@money[:pending]) %></strong></div>
      </div>
    </section>
  </div>

  <div class="grid gap-6 xl:grid-cols-3">
    <section class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-gray-950">Today’s Priorities</h2>
      <div class="mt-4 space-y-3">
        <% (@today_tasks + @today_leads + @reminders).first(10).each do |item| %>
          <div class="rounded-xl bg-gray-50 p-4">
            <% if item.is_a?(Task) %>
              <p class="text-sm font-semibold text-gray-950">Task: <%= item.title %></p>
              <p class="mt-1 text-xs text-gray-500"><%= item.project.display_name %> · due <%= admin_value(item.due_date) %></p>
            <% elsif item.is_a?(Lead) %>
              <p class="text-sm font-semibold text-gray-950">Follow up: <%= item.display_name %></p>
              <p class="mt-1 text-xs text-gray-500"><%= item.service_interest.presence || item.notes.presence || "Lead follow-up" %></p>
            <% else %>
              <p class="text-sm font-semibold text-gray-950">Reminder: <%= item.title %></p>
              <p class="mt-1 text-xs text-gray-500"><%= item.next_action.presence || item.note.presence || "Next action due" %></p>
            <% end %>
          </div>
        <% end %>

        <% if @today_tasks.empty? && @today_leads.empty? && @reminders.empty? %>
          <p class="rounded-xl bg-gray-50 p-4 text-sm text-gray-500">No urgent priorities due today.</p>
        <% end %>
      </div>
    </section>

    <section class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm xl:col-span-2">
      <div class="flex items-center justify-between">
        <h2 class="text-lg font-semibold text-gray-950">Active Projects</h2>
        <%= link_to "Manage projects", admin_projects_path, class: "text-sm font-semibold text-blue-600 hover:text-blue-700" %>
      </div>

      <div class="mt-4 overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Project</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Client</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Status</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Due Date</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Progress</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @active_projects.each do |project| %>
              <tr>
                <td class="px-4 py-3 font-medium text-gray-950"><%= link_to project.name, admin_project_path(project), class: "hover:text-blue-700" %></td>
                <td class="px-4 py-3 text-gray-700"><%= project.client.display_name %></td>
                <td class="px-4 py-3"><span class="rounded-full px-2.5 py-1 text-xs font-semibold ring-1 <%= admin_status_class(project.status) %>"><%= project.status %></span></td>
                <td class="px-4 py-3 text-gray-700"><%= admin_value(project.deadline) %></td>
                <td class="px-4 py-3 text-gray-700"><%= project.progress %>%</td>
              </tr>
            <% end %>

            <% if @active_projects.empty? %>
              <tr>
                <td colspan="5" class="px-4 py-8 text-center text-gray-500">No active projects yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <%= link_to "Add Lead", new_admin_lead_path, class: "rounded-2xl border border-blue-200 bg-blue-50 p-5 text-sm font-semibold text-blue-700 hover:bg-blue-100" %>
    <%= link_to "Create Quote", new_admin_quote_path, class: "rounded-2xl border border-emerald-200 bg-emerald-50 p-5 text-sm font-semibold text-emerald-700 hover:bg-emerald-100" %>
    <%= link_to "Record Payment", new_admin_payment_path, class: "rounded-2xl border border-indigo-200 bg-indigo-50 p-5 text-sm font-semibold text-indigo-700 hover:bg-indigo-100" %>
    <%= link_to "Add Expense", new_admin_expense_path, class: "rounded-2xl border border-amber-200 bg-amber-50 p-5 text-sm font-semibold text-amber-700 hover:bg-amber-100" %>
  </div>
</div>
