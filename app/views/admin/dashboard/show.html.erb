<div class="space-y-8">
  <div>
    <p class="text-sm font-medium text-blue-600">Dashboard</p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight text-gray-950">Dashboard</h1>
    <p class="mt-3 text-gray-600">Manage application operations from this authenticated area.</p>
  </div>

  <div class="grid gap-6 md:grid-cols-3">
    <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-medium text-gray-500">Signed in as</p>
      <p class="mt-3 text-lg font-semibold text-gray-950"><%= current_user.email %></p>
    </div>

    <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-medium text-gray-500">Users</p>
      <p class="mt-3 text-3xl font-bold text-gray-950"><%= User.count %></p>
    </div>

    <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-medium text-gray-500">Authentication</p>
      <p class="mt-3 text-lg font-semibold text-green-700">Devise enabled</p>
    </div>
  </div>
</div>
