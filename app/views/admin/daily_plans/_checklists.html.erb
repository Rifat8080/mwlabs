<div class="space-y-6" id="daily-plan-checklists">
  <% [ [ "morning", "Morning Checklist", "fa-sun" ], [ "evening", "Evening Checklist", "fa-moon" ] ].each do |list_type, label, icon| %>
    <% items = daily_plan.persisted? ? daily_plan.checklist_items.where(list_type: list_type).ordered : [] %>
    <section class="rounded-[1.75rem] border border-white bg-white/90 p-5 shadow-xl shadow-slate-200/70 backdrop-blur lg:p-6">
      <p class="text-xs font-black uppercase tracking-[0.18em] text-blue-600">
        <i class="fa-solid <%= icon %>"></i> <%= label %> (<%= items.count(&:done) %>/<%= items.size %>)
      </p>

      <% if items.any? %>
        <ul class="mt-4 space-y-2">
          <% items.each do |item| %>
            <li class="flex items-center gap-3 rounded-xl border border-slate-100 bg-slate-50/80 px-4 py-3">
              <%= button_to admin_checklist_item_path(item),
                method: :patch,
                params: { checklist_item: { done: !item.done } },
                class: "flex h-6 w-6 shrink-0 items-center justify-center rounded-lg border text-xs transition #{item.done ? 'border-emerald-300 bg-emerald-500 text-white' : 'border-slate-300 bg-white text-transparent hover:border-blue-300'}" do %>
                <i class="fa-solid fa-check"></i>
              <% end %>
              <span class="flex-1 text-sm font-semibold <%= item.done ? 'text-slate-400 line-through' : 'text-slate-900' %>"><%= item.title %></span>
              <%= button_to admin_checklist_item_path(item),
                method: :delete,
                form: { data: { turbo_confirm: "Remove this item?" } },
                class: "flex h-8 w-8 items-center justify-center rounded-lg text-slate-400 transition hover:bg-rose-50 hover:text-rose-600" do %>
                <i class="fa-solid fa-xmark text-xs"></i>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% end %>

      <% if daily_plan.persisted? %>
        <%= form_with url: admin_checklist_items_path, method: :post, class: "mt-4 flex gap-2" do %>
          <input type="hidden" name="checklist_item[checklistable_type]" value="DailyPlan">
          <input type="hidden" name="checklist_item[checklistable_id]" value="<%= daily_plan.id %>">
          <input type="hidden" name="checklist_item[list_type]" value="<%= list_type %>">
          <input type="text" name="checklist_item[title]" placeholder="Add an item..." required class="block w-full rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-900 shadow-sm focus:border-blue-300 focus:outline-none focus:ring-4 focus:ring-blue-50">
          <button type="submit" class="shrink-0 rounded-xl bg-blue-600 px-4 py-2.5 text-sm font-black text-white shadow-lg shadow-blue-600/20 hover:bg-blue-700"><i class="fa-solid fa-plus"></i></button>
        <% end %>
      <% else %>
        <p class="mt-4 text-xs font-semibold text-slate-500">Save the daily plan first to start adding checklist items.</p>
      <% end %>
    </section>
  <% end %>
</div>
