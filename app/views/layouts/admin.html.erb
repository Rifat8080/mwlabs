<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "M&W Labs Control Center" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.7.2/css/all.min.css" integrity="" crossorigin="anonymous">

    <%= yield :head %>

    <%= render "shared/favicons" %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/trix@2.1.13/dist/trix.css">
    <%= javascript_importmap_tags %>
    <%= javascript_import_module_tag "admin_editor" %>
    <%= javascript_import_module_tag "admin_cable" %>
  </head>

  <body class="min-h-screen bg-[radial-gradient(circle_at_top_left,_rgba(219,234,254,0.9),_transparent_34rem),radial-gradient(circle_at_bottom_right,_rgba(224,242,254,0.7),_transparent_30rem),linear-gradient(180deg,_#ffffff_0%,_#f8fbff_46%,_#eef6ff_100%)] text-slate-950 antialiased" data-controller="live-notifications admin-sidebar">
    <%= render "shared/site_loader" %>

    <% nav_sections = allowed_nav_sections %>

    <div class="pointer-events-none fixed inset-0 z-0 opacity-70">
      <div class="absolute left-[18rem] top-24 h-40 w-40 rounded-full bg-blue-200/40 blur-3xl"></div>
      <div class="absolute bottom-10 right-10 h-56 w-56 rounded-full bg-cyan-200/30 blur-3xl"></div>
    </div>

    <div class="fixed inset-0 z-40 hidden bg-slate-950/35 backdrop-blur-sm lg:hidden" data-admin-sidebar-target="overlay" data-action="click->admin-sidebar#close"></div>

    <nav class="fixed left-0 right-0 top-0 z-50 border-b border-white/70 bg-white/85 shadow-sm shadow-slate-200/50 backdrop-blur-xl">
      <div class="hidden h-20 w-80 items-center border-r border-slate-100/80 px-5 lg:absolute lg:left-0 lg:top-0 lg:flex">
        <%= link_to dashboard_root_path, class: "group flex w-full items-center gap-3 rounded-3xl border border-blue-100 bg-[radial-gradient(circle_at_top_right,_#dbeafe,_transparent_13rem),#ffffff] px-4 py-3 shadow-xl shadow-blue-100/40 transition hover:-translate-y-0.5 hover:border-blue-200 hover:shadow-blue-200/50" do %>
          <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-white shadow-sm ring-1 ring-slate-100">
            <%= tag.img src: "/images/logo.svg", alt: "M&W Labs", class: "h-8 w-auto object-contain" %>
          </span>
          <span class="min-w-0">
            <span class="block truncate text-sm font-black tracking-tight text-slate-950">M&W Labs</span>
            <span class="block truncate text-[0.66rem] font-black uppercase tracking-[0.18em] text-blue-600"><%= client_user? ? "Client Portal" : "Control Center" %></span>
          </span>
          <i class="fa-solid fa-chevron-right ml-auto text-[0.65rem] text-slate-300 transition group-hover:translate-x-0.5 group-hover:text-blue-500"></i>
        <% end %>
      </div>

      <div class="flex h-20 items-center justify-between gap-3 px-4 sm:px-6 lg:ml-80 lg:px-8">
        <div class="flex items-center gap-3">
          <button aria-controls="admin-sidebar" type="button" class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-slate-200 bg-white text-slate-500 shadow-sm transition hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700 focus:outline-none focus:ring-4 focus:ring-blue-100 lg:hidden" data-action="click->admin-sidebar#open">
            <span class="sr-only">Open sidebar</span>
            <svg class="h-5 w-5" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
              <path clip-rule="evenodd" fill-rule="evenodd" d="M2 4.75A.75.75 0 0 1 2.75 4h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 4.75ZM2 10a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 10Zm0 5.25a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75a.75.75 0 0 1-.75-.75Z"></path>
            </svg>
          </button>

          <%= link_to dashboard_root_path, class: "flex min-w-0 items-center gap-2 rounded-2xl border border-blue-100 bg-white/90 px-2.5 py-2 shadow-sm transition hover:bg-blue-50 sm:gap-3 sm:px-3 lg:hidden" do %>
            <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-white ring-1 ring-slate-100">
              <%= tag.img src: "/images/logo.svg", alt: "M&W Labs", class: "h-6 w-auto object-contain" %>
            </span>
            <span class="hidden min-w-0 sm:block">
              <span class="block truncate text-xs font-black text-slate-950">M&W Labs</span>
              <span class="block truncate text-[0.6rem] font-black uppercase tracking-[0.14em] text-blue-600"><%= client_user? ? "Portal" : "Control" %></span>
            </span>
          <% end %>

          <div class="hidden min-w-0 lg:block">
            <p class="text-xs font-black uppercase tracking-[0.22em] text-blue-600"><%= client_user? ? "Client Portal" : "M&W Labs OS" %></p>
            <p class="mt-1 truncate text-sm font-bold text-slate-500">Welcome back, <span class="text-slate-900"><%= current_user.display_name %></span></p>
          </div>
        </div>

        <div class="flex shrink-0 items-center gap-2 sm:gap-3">
          <%= link_to root_path, class: "hidden rounded-2xl border border-slate-200 bg-white/90 px-4 py-2.5 text-sm font-black text-slate-700 shadow-sm transition hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700 sm:inline-flex sm:items-center sm:gap-2" do %>
            View site
            <i class="fa-solid fa-arrow-up-right-from-square text-xs"></i>
          <% end %>

          <%= render "shared/notifications_dropdown" %>

          <div class="relative" data-controller="notification-menu">
            <button type="button" class="flex items-center gap-2 rounded-2xl border border-slate-200 bg-white/90 p-1.5 text-sm shadow-sm transition hover:border-blue-200 hover:bg-blue-50 focus:outline-none focus:ring-4 focus:ring-blue-100 sm:gap-3 sm:pr-3" aria-expanded="false" aria-controls="admin-user-dropdown" data-notification-menu-target="button" data-action="click->notification-menu#toggle">
              <span class="sr-only">Open user menu</span>
              <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-blue-600 to-cyan-500 text-sm font-black text-white shadow-lg shadow-blue-600/20">
                <%= current_user.display_name.first.upcase %>
              </span>
              <span class="hidden text-left sm:block">
                <span class="block max-w-32 truncate text-xs font-black text-slate-900"><%= current_user.display_name %></span>
                <span class="block text-[0.68rem] font-bold uppercase tracking-[0.12em] text-slate-400"><%= current_user.role.humanize %></span>
              </span>
              <i class="fa-solid fa-chevron-down hidden text-[0.65rem] text-slate-400 sm:block"></i>
            </button>

            <div id="admin-user-dropdown" class="absolute right-0 z-50 mt-3 hidden w-[calc(100vw-2rem)] max-w-72 overflow-hidden rounded-3xl border border-slate-100 bg-white shadow-2xl shadow-slate-300/50" data-notification-menu-target="panel">
              <div class="bg-[radial-gradient(circle_at_top_right,_#dbeafe,_transparent_14rem),#ffffff] px-5 py-4">
                <p class="text-sm font-black text-slate-950"><%= current_user.display_name %></p>
                <p class="mt-1 truncate text-xs font-semibold text-slate-500"><%= current_user.email %></p>
                <span class="mt-3 inline-flex rounded-full bg-blue-50 px-3 py-1 text-[0.65rem] font-black uppercase tracking-[0.16em] text-blue-700"><%= current_user.role.humanize %></span>
              </div>
              <div class="border-t border-slate-100 p-2">
                <%= button_to destroy_user_session_path, method: :delete, class: "flex w-full items-center gap-3 rounded-2xl px-4 py-3 text-left text-sm font-black text-rose-700 transition hover:bg-rose-50" do %>
                  <i class="fa-solid fa-arrow-right-from-bracket"></i>
                  Sign out
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <aside id="admin-sidebar" class="fixed left-0 top-0 z-50 h-screen w-[min(20rem,calc(100vw-1.5rem))] -translate-x-full border-r border-white/70 bg-white/90 shadow-2xl shadow-slate-300/50 backdrop-blur-xl transition-transform duration-300 lg:z-40 lg:w-80 lg:translate-x-0 lg:pt-20" aria-label="Sidebar" data-admin-sidebar-target="panel">
      <div class="flex h-full flex-col overflow-hidden">
        <div class="border-b border-slate-100 px-5 py-5 lg:hidden">
          <div class="flex items-center justify-between gap-3">
            <%= link_to dashboard_root_path, class: "flex min-w-0 items-center gap-3 rounded-3xl border border-blue-100 bg-white px-3 py-2 shadow-sm" do %>
              <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-blue-50 ring-1 ring-blue-100">
                <%= tag.img src: "/images/logo.svg", alt: "M&W Labs", class: "h-7 w-auto object-contain" %>
              </span>
              <span class="min-w-0">
                <span class="block truncate text-sm font-black text-slate-950">M&W Labs</span>
                <span class="block truncate text-[0.65rem] font-black uppercase tracking-[0.16em] text-blue-600"><%= client_user? ? "Client Portal" : "Control Center" %></span>
              </span>
            <% end %>
            <button type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-slate-200 bg-white text-slate-500 shadow-sm transition hover:bg-slate-50 lg:hidden" data-action="click->admin-sidebar#close">
              <span class="sr-only">Close sidebar</span>
              <i class="fa-solid fa-xmark"></i>
            </button>
          </div>
        </div>

        <div class="flex-1 overflow-y-auto px-4 py-5">
          <div class="mb-6 overflow-hidden rounded-[1.75rem] border border-blue-100 bg-[radial-gradient(circle_at_top_right,_#dbeafe,_transparent_16rem),linear-gradient(135deg,_#ffffff,_#f8fbff)] p-5 shadow-xl shadow-blue-100/40">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-xs font-black uppercase tracking-[0.22em] text-blue-600">Workspace</p>
                <p class="mt-2 text-xl font-black text-slate-950"><%= client_user? ? "Client Portal" : "Agency OS" %></p>
              </div>
              <span class="hidden h-10 w-10 items-center justify-center rounded-2xl bg-white shadow-sm ring-1 ring-blue-100 lg:flex">
                <%= tag.img src: "/images/logo.svg", alt: "", class: "h-6 w-auto object-contain" %>
              </span>
            </div>
            <div class="mt-4 flex items-center gap-3">
              <span class="flex h-10 w-10 items-center justify-center rounded-2xl bg-blue-600 text-sm font-black text-white shadow-lg shadow-blue-600/20"><%= current_user.display_name.first.upcase %></span>
              <div class="min-w-0">
                <p class="truncate text-sm font-black text-slate-900"><%= current_user.display_name %></p>
                <p class="truncate text-xs font-semibold text-slate-500"><%= current_user.role.humanize %></p>
              </div>
            </div>
          </div>

          <nav class="space-y-6">
            <% nav_sections.each do |section, links| %>
              <div>
                <p class="mb-2 px-3 text-[0.68rem] font-black uppercase tracking-[0.2em] text-slate-400"><%= section %></p>
                <ul class="space-y-1.5 font-bold">
                  <% links.each do |label, path, icon| %>
                    <% active = request.path == path || (path != dashboard_root_path && request.path.start_with?(path)) %>
                    <li>
                      <%= link_to path, class: "group relative flex items-center gap-3 rounded-2xl px-3 py-3 transition #{active ? 'bg-slate-950 text-white shadow-xl shadow-slate-900/15' : 'text-slate-700 hover:bg-blue-50 hover:text-blue-700'}" do %>
                        <span class="flex h-10 w-10 items-center justify-center rounded-xl #{active ? 'bg-white/15 text-white' : 'bg-slate-50 text-slate-400 group-hover:bg-white group-hover:text-blue-600'}">
                          <i class="fa-solid <%= icon %> text-sm"></i>
                        </span>
                        <span class="flex-1"><%= label %></span>
                        <% if active %>
                          <span class="h-2 w-2 rounded-full bg-cyan-300"></span>
                        <% end %>
                      <% end %>
                    </li>
                  <% end %>
                </ul>
              </div>
            <% end %>
          </nav>
        </div>

        <div class="border-t border-slate-100 p-4">
          <%= link_to root_path, class: "flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-black text-slate-700 shadow-sm transition hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700" do %>
            <span>Visit public site</span>
            <i class="fa-solid fa-arrow-up-right-from-square text-xs"></i>
          <% end %>
        </div>
      </div>
    </aside>

    <main class="relative z-10 min-h-screen px-4 pb-8 pt-24 sm:px-6 lg:ml-80 lg:px-8 lg:pb-10 lg:pt-28">
      <div class="mx-auto w-full max-w-[1600px]">
        <div id="flash">
          <%= render "shared/flash" %>
        </div>
        <%= yield %>
      </div>
    </main>

    <%= render "shared/flash_toasts", notice: notice, alert: alert %>
  </body>
</html>
