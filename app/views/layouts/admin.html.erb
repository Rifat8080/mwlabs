<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Dashboard | Mwlabs" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gray-50 text-gray-950">
    <div class="min-h-screen lg:flex">
      <aside class="border-b border-gray-200 bg-gray-950 px-6 py-5 text-white lg:min-h-screen lg:w-72 lg:border-b-0">
        <%= link_to "Mwlabs Dashboard", dashboard_root_path, class: "text-xl font-bold tracking-tight" %>

        <nav class="mt-8 space-y-2 text-sm font-medium">
          <%= link_to "Dashboard", dashboard_root_path, class: "block rounded-lg bg-white/10 px-4 py-3 text-white" %>
          <%= link_to "View site", root_path, class: "block rounded-lg px-4 py-3 text-gray-300 hover:bg-white/10 hover:text-white" %>
        </nav>
      </aside>

      <div class="flex min-h-screen flex-1 flex-col">
        <header class="border-b border-gray-200 bg-white px-6 py-4">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-gray-500">Signed in as</p>
              <p class="font-medium"><%= current_user.email %></p>
            </div>

            <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "rounded-lg border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50" %>
          </div>
        </header>

        <main class="flex-1 p-6">
          <%= render "shared/flash" %>
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
