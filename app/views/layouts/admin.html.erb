<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "M&W Labs Control Center" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.svg?v=20260610" type="image/svg+xml">
    <link rel="shortcut icon" href="/favicon.ico?v=20260610">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-[radial-gradient(circle_at_top_right,_#eff6ff,_transparent_34rem),linear-gradient(180deg,_#ffffff_0%,_#f8fbff_100%)] text-slate-950">
    <% nav_sections = allowed_nav_sections %>

    <nav class="fixed left-0 right-0 top-0 z-50 border-b border-slate-100 bg-white/95 shadow-sm backdrop-blur">
      <div class="flex items-center justify-between px-4 py-3 lg:px-6">
        <div class="flex items-center gap-3">
          <button data-drawer-target="admin-sidebar" data-drawer-toggle="admin-sidebar" aria-controls="admin-sidebar" type="button" class="inline-flex items-center rounded-lg p-2 text-sm text-slate-500 hover:bg-blue-50 hover:text-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-100 lg:hidden">
            <span class="sr-only">Open sidebar</span>
            <svg class="h-6 w-6" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
              <path clip-rule="evenodd" fill-rule="evenodd" d="M2 4.75A.75.75 0 0 1 2.75 4h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 4.75ZM2 10a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 10Zm0 5.25a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75a.75.75 0 0 1-.75-.75Z"></path>
            </svg>
          </button>

          <%= link_to dashboard_root_path, class: "flex items-center gap-3" do %>
            <%= tag.img src: "/images/logo.svg", alt: "M&W Labs", class: "h-14 w-auto object-contain md:h-16" %>
          <% end %>
        </div>

        <div class="flex items-center gap-3">
          <%= link_to root_path, class: "hidden rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-extrabold text-slate-700 shadow-sm transition hover:bg-blue-50 hover:text-blue-700 sm:inline-flex sm:items-center sm:gap-2" do %>
            View site
            <i class="fa-solid fa-arrow-up-right-from-square text-xs"></i>
          <% end %>

          <button type="button" class="flex rounded-full bg-white text-sm focus:ring-4 focus:ring-blue-100" aria-expanded="false" data-dropdown-toggle="admin-user-dropdown">
            <span class="sr-only">Open user menu</span>
            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-blue-600 text-sm font-black text-white shadow-lg shadow-blue-600/20">
              <%= current_user.display_name.first.upcase %>
            </span>
          </button>

          <div id="admin-user-dropdown" class="z-50 hidden w-64 divide-y divide-slate-100 rounded-2xl border border-slate-100 bg-white shadow-xl shadow-slate-200/70">
            <div class="px-4 py-3">
              <p class="text-sm font-black text-slate-950"><%= current_user.display_name %></p>
              <p class="truncate text-xs font-semibold text-slate-500"><%= current_user.email %></p>
            </div>
            <div class="p-2">
              <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "block w-full rounded-xl px-4 py-2 text-left text-sm font-extrabold text-rose-700 hover:bg-rose-50" %>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <aside id="admin-sidebar" class="fixed left-0 top-0 z-40 h-screen w-80 -translate-x-full border-r border-slate-100 bg-white/95 pt-24 shadow-xl shadow-slate-200/60 backdrop-blur transition-transform lg:translate-x-0" aria-label="Sidebar">
      <div class="h-full overflow-y-auto px-4 pb-6">
        <div class="mb-5 rounded-[1.5rem] border border-blue-100 bg-[radial-gradient(circle_at_top_right,_#eff6ff,_transparent_18rem),#ffffff] p-4 shadow-sm">
          <p class="text-xs font-black uppercase tracking-[0.22em] text-blue-600">M&W Labs</p>
          <p class="mt-1 text-lg font-black text-slate-950"><%= client_user? ? "Client Portal" : "Agency OS" %></p>
          <p class="mt-2 inline-flex rounded-full bg-blue-50 px-3 py-1 text-[0.65rem] font-black uppercase tracking-[0.16em] text-blue-700"><%= current_user.role.humanize %></p>
        </div>

        <nav class="space-y-6">
          <% nav_sections.each do |section, links| %>
            <div>
              <p class="mb-2 px-3 text-[0.68rem] font-black uppercase tracking-[0.2em] text-slate-400"><%= section %></p>
              <ul class="space-y-1 font-bold">
                <% links.each do |label, path, icon| %>
                  <% active = current_page?(path) %>
                  <li>
                    <%= link_to path, class: "group flex items-center rounded-xl p-3 transition #{active ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/20' : 'text-slate-700 hover:bg-blue-50 hover:text-blue-700'}" do %>
                      <i class="fa-solid <%= icon %> h-5 w-5 text-center text-sm #{active ? 'text-blue-100' : 'text-slate-400 group-hover:text-blue-600'}"></i>
                      <span class="ms-3"><%= label %></span>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            </div>
          <% end %>
        </nav>
      </div>
    </aside>

    <main class="min-h-screen p-4 pt-24 sm:p-6 sm:pt-24 lg:ml-80 lg:p-8 lg:pt-28">
      <%= render "shared/flash" %>
      <%= yield %>
    </main>
  </body>
</html>
