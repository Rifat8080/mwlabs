<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Mwlabs" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-white text-gray-950">
    <header class="border-b border-gray-100">
      <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5">
        <%= link_to "Mwlabs", root_path, class: "text-lg font-bold tracking-tight" %>

        <div class="flex items-center gap-4 text-sm font-medium">
          <%= link_to "Home", root_path, class: "text-gray-600 hover:text-gray-950" %>
          <% if user_signed_in? %>
            <%= link_to "Dashboard", dashboard_root_path, class: "text-gray-600 hover:text-gray-950" %>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "rounded-lg bg-gray-950 px-4 py-2 text-white hover:bg-gray-800" %>
          <% else %>
            <%= link_to "Sign in", new_user_session_path, class: "rounded-lg bg-gray-950 px-4 py-2 text-white hover:bg-gray-800" %>
          <% end %>
        </div>
      </nav>
    </header>

    <main>
      <div class="mx-auto max-w-7xl px-6 pt-6">
        <%= render "shared/flash" %>
      </div>

      <%= yield %>
    </main>
  </body>
</html>
